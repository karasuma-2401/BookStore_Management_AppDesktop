<UserControl x:Class="BookStore_Management_AppDesktop.Views.UserControls.StatCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="250"
             Name="RootControl">

    <Border Background="#FFFFFF" 
            BorderBrush="#E2E8F0" 
            BorderThickness="1" 
            CornerRadius="10" 
            Padding="20" 
            Margin="0,0,15,0">
        <Border.RenderTransform>
            <TranslateTransform Y="0" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="10"
                Opacity="0.03"
                ShadowDepth="2"
                Color="#000000" />
        </Border.Effect>
        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                            To="-5"
                            Duration="0:0:0.15" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                            To="0"
                            Duration="0:0:0.15" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="15"
                            Opacity="0.08"
                            ShadowDepth="6"
                            Color="#000000" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Border.Triggers>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Value, ElementName=RootControl}" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="#0F172A" />
                <TextBlock Text="{Binding Title, ElementName=RootControl}" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#64748B" 
                           Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" 
                    Width="48" Height="48" 
                    Background="White" 
                    CornerRadius="8" 
                    VerticalAlignment="Center"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.05" Color="Black"/>
                </Border.Effect>

                <Path Data="{Binding IconData, ElementName=RootControl}" 
                      Fill="{Binding IconColor, ElementName=RootControl}" 
                      Stretch="Uniform" 
                      Width="24" Height="24" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>