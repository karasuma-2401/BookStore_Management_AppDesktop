<Application
    x:Class="BookStore_Management_AppDesktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BookStore_Management_AppDesktop.Converters"
    xmlns:local="clr-namespace:BookStore_Management_AppDesktop"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
            <converters:CollectionEmptyToVisibilityConverter x:Key="CollectionEmptyToVisibilityConverter" />
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <converters:StatusToSoftBackgroundConverter x:Key="StatusToSoftBackgroundConverter" />
            <converters:StatusToForegroundConverter x:Key="StatusToForegroundConverter" />
            <converters:RoleToColorConverter x:Key="RoleToColorConverter" />
            <converters:RoleToSoftBackgroundConverter x:Key="RoleToSoftBackgroundConverter" />

            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />

                <ResourceDictionary Source="/Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="/Resources/Styles/Typography.xaml" />
                <ResourceDictionary Source="/Resources/Styles/Buttons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>