<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Style x:Key="BaseButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Appearance" Value="Primary"/>
        <Setter Property="Background" Value="{DynamicResource NavyAccentBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSubTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="30,12"/>
    </Style>

    <Style x:Key="SecondaryActionButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Appearance" Value="Secondary"/>
        <Setter Property="Background" Value="{DynamicResource NavyLightBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,10"/>
    </Style>

    <Style x:Key="DangerActionButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Appearance" Value="Danger"/>
        <Setter Property="Background" Value="{DynamicResource ErrorPrimaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,10"/>
    </Style>

    <Style x:Key="RoundedTextBoxInnerStyle" TargetType="TextBox">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource NavyPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style x:Key="FormLabelStyle" TargetType="ui:TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="Margin" Value="0,10,0,6"/>
    </Style>

    <Style x:Key="CloseButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Secondary"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Content" Value="✕"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="{DynamicResource BorderLightBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavyPrimaryBrush}"/>
    </Style>

    <Style x:Key="UpdateButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Primary"/>
        <Setter Property="Width" Value="160"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{DynamicResource ActionPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavyPrimaryBrush}"/>
    </Style>

</ResourceDictionary>