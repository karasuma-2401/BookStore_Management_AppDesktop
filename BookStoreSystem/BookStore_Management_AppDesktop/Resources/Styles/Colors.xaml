<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="10" Opacity="0.1" ShadowDepth="2" Color="#0F172A" Direction="270"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="White" />
    <SolidColorBrush x:Key="TextOnCardBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="TextSecondBrush" Color="#AAAAAA" />
    <SolidColorBrush x:Key="ErrorPrimaryBrush" Color="#FF4C4C" />
    <SolidColorBrush x:Key="SuccessPrimaryBrush" Color="#00DC82" />
    <SolidColorBrush x:Key="TextThirdBrush" Color="Black"/>

    <SolidColorBrush x:Key="NavyPrimaryBrush" Color="#0A2A47" />
    <SolidColorBrush x:Key="NavyLightBrush" Color="#15436F" />
    <SolidColorBrush x:Key="NavyAccentBrush" Color="#00D4B2" />
    <SolidColorBrush x:Key="NavyGlassBrush" Color="#B30A2A47" />

    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="#38BDF8" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="White" />

    <SolidColorBrush x:Key="BorderBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="TextBodyBrush" Color="#64748B" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="White" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#0EA5E9" />

    <!-- Additional Color Resources for Better Visibility -->
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="LightGrayBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="DarkGrayBrush" Color="#374151" />

    <!-- Status Colors for Shifts -->
    <SolidColorBrush x:Key="StatusScheduledBrush" Color="#38BDF8" />
    <SolidColorBrush x:Key="StatusPresentBrush" Color="#10B981" />
    <SolidColorBrush x:Key="StatusAbsentBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="StatusCompensatedBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="StatusLateBrush" Color="#F97316" />

    <!-- New design tokens added for clean dynamic resources -->
    <SolidColorBrush x:Key="SlateDarkBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="SlateMediumBrush" Color="#2A3950" />
    <SolidColorBrush x:Key="SlateLightBrush" Color="#475569" />
    <SolidColorBrush x:Key="SlateBorderBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="LightGrayBgBrush" Color="#F8F9FA" />
    <SolidColorBrush x:Key="RoseAccentBrush" Color="#F43F5E" />
    <SolidColorBrush x:Key="LatePurpleBrush" Color="#A855F7" />
    <SolidColorBrush x:Key="CompensatedBlueBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="EmeraldGreenBrush" Color="#10B981" />

    <!-- Color Struct Definitions for use in styles, triggers, or effects -->
    <Color x:Key="TextOnCardColor">#1E293B</Color>
    <Color x:Key="SlateBorderColor">#94A3B8</Color>
    <Color x:Key="SlateDarkColor">#0F172A</Color>
    <Color x:Key="SidebarAccentColor">#38BDF8</Color>

</ResourceDictionary>