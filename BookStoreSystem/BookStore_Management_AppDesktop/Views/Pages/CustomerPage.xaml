<Page
    x:Class="BookStore_Management_AppDesktop.Views.Pages.CustomerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:BookStore_Management_AppDesktop.ViewModels"
    Title="CustomerPage"
    d:DataContext="{d:DesignInstance Type=viewmodels:CustomerViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Background="{DynamicResource ContentBackgroundBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border
            Grid.Row="0"
            Padding="25,15"
            Background="{DynamicResource SidebarBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="26"
                        FontWeight="Black"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Customer Management" />
                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="Manage all your customers and their information" />
                </StackPanel>
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:TextBox
                        Width="250"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="White"
                        Icon="{ui:SymbolIcon Search24}"
                        PlaceholderText="{Binding SearchPlaceholder}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button
                        x:Name="FilterButton"
                        Appearance="Secondary"
                        Click="FilterButton_Click"
                        Icon="{ui:SymbolIcon Filter24}">
                        <ui:Button.ContextMenu>
                            <ContextMenu x:Name="FilterMenu">
                                <ContextMenu.Resources>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="MenuItem">
                                                    <Grid Background="Transparent">
                                                        <Border
                                                            x:Name="ActiveIndicator"
                                                            Width="4"
                                                            Height="18"
                                                            Margin="2,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            Background="{DynamicResource SidebarAccentBrush}"
                                                            CornerRadius="2"
                                                            Visibility="Collapsed" />
                                                        <ContentPresenter
                                                            x:Name="HeaderHost"
                                                            Margin="15,8,15,8"
                                                            ContentSource="Header" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SidebarAccentBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem
                                    Command="{Binding ChangeFilterCommand}"
                                    CommandParameter="Name"
                                    Header="Name"
                                    Icon="{ui:SymbolIcon Symbol=Person24}"
                                    IsChecked="{Binding IsNameSelected, Mode=OneWay}" />

                                <MenuItem
                                    Command="{Binding ChangeFilterCommand}"
                                    CommandParameter="Phone"
                                    Header="Phone"
                                    Icon="{ui:SymbolIcon Symbol=Call24}"
                                    IsChecked="{Binding IsPhoneSelected, Mode=OneWay}" />

                                <MenuItem
                                    Command="{Binding ChangeFilterCommand}"
                                    CommandParameter="Email"
                                    Header="Email"
                                    Icon="{ui:SymbolIcon Symbol=Mail24}"
                                    IsChecked="{Binding IsEmailSelected, Mode=OneWay}" />

                                <MenuItem
                                    Command="{Binding ChangeFilterCommand}"
                                    CommandParameter="Debt"
                                    Header="Debt"
                                    Icon="{ui:SymbolIcon Symbol=Money24}"
                                    IsChecked="{Binding IsDebtSelected, Mode=OneWay}" />
                            </ContextMenu>
                        </ui:Button.ContextMenu>
                    </ui:Button>
                    <ui:Button
                        Appearance="Secondary"
                        Command="{Binding RefreshCommand}"
                        Icon="{ui:SymbolIcon ArrowSync24}"
                        ToolTip="Refresh" />
                    <ui:Button
                        Appearance="Primary"
                        Background="{DynamicResource NavyAccentBrush}"
                        Command="{Binding AddCustomerCommand}"
                        Content="Add Customer"
                        Icon="{ui:SymbolIcon Add24}" />
                </StackPanel>
            </Grid>
        </Border>
        <UniformGrid
            Grid.Row="1"
            Margin="20,15,20,10"
            Columns="3"
            Rows="1">
            <Border
                Margin="5"
                Padding="20"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.1"
                        ShadowDepth="2"
                        Color="Black" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="TOTAL CUSTOMERS" />
                    <TextBlock
                        FontSize="28"
                        FontWeight="Black"
                        Foreground="{DynamicResource SidebarAccentBrush}"
                        Text="{Binding Customers.Count}" />
                </StackPanel>
            </Border>
            <Border
                Margin="5"
                Padding="20"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.1"
                        ShadowDepth="2"
                        Color="Black" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="TOTAL DEBT" />
                    <TextBlock
                        FontSize="28"
                        FontWeight="Black"
                        Foreground="{DynamicResource ErrorPrimaryBrush}"
                        Text="{Binding TotalDebt, StringFormat={}{0:N0} ₫}" />
                </StackPanel>
            </Border>
            <Border
                Margin="5"
                Padding="20"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.1"
                        ShadowDepth="2"
                        Color="Black" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="AVERAGE DEBT" />
                    <TextBlock
                        FontSize="28"
                        FontWeight="Black"
                        Foreground="{DynamicResource TextPrimaryBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:N0} ₫">
                                <Binding Path="TotalDebt" />
                                <Binding Path="Customers.Count" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--  DataGrid  -->
        <Border
            Grid.Row="2"
            Margin="20,10,20,20"
            Padding="20"
            Background="{DynamicResource SidebarBackgroundBrush}"
            CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.1"
                    ShadowDepth="2"
                    Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,15"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="Customer List" />
                <DataGrid
                    x:Name="CustomerDataGrid"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="{DynamicResource DividerBrush}"
                    IsReadOnly="True"
                    ItemsSource="{Binding Customers}"
                    PreviewMouseLeftButtonDown="CustomerDataGrid_PreviewMouseLeftButtonDown"
                    RowBackground="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding CustomerId}"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Header="ID">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Name}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Header="Name">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="140"
                            Binding="{Binding Phone}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Header="Phone">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="180"
                            Binding="{Binding Email}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Header="Email">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="200"
                            Binding="{Binding Address}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Header="Address">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding Debt, StringFormat={}{0:N0} ₫}"
                            Foreground="{DynamicResource ErrorPrimaryBrush}"
                            Header="Debt">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="80" Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <ui:Button
                                            Margin="0,0,5,0"
                                            Padding="5"
                                            Appearance="Secondary"
                                            Command="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=DataContext.EditCustomerCommand}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Edit24}"
                                            ToolTip="Edit" />

                                        <ui:Button
                                            Padding="5"
                                            Appearance="Secondary"
                                            Command="{Binding RelativeSource={RelativeSource AncestorType=Page}, Path=DataContext.DeleteCustomerCommand}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Delete24}"
                                            ToolTip="Delete" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel
                    Grid.Row="2"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,15,0"
                        Appearance="Secondary"
                        Click="PreviousButton_Click"
                        Command="{Binding}"
                        Content="Previous" />

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Text="{Binding CurrentPage}" />
                        <TextBlock
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text=" of " />
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Text="{Binding TotalPages}" />
                    </StackPanel>

                    <ui:Button
                        Margin="15,0,15,0"
                        Appearance="Secondary"
                        Click="NextButton_Click"
                        Command="{Binding}"
                        Content="Next" />

                    <ComboBox
                        Width="70"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        ItemsSource="{Binding PageSizeOptions}"
                        SelectedItem="{Binding PageSize}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
