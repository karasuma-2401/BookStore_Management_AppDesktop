<Page
    x:Class="BookStore_Management_AppDesktop.Views.Pages.CustomerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BookStore_Management_AppDesktop.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="CustomerPage"
    d:DesignHeight="850"
    d:DesignWidth="1200"
    Background="#F4F7F9"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:DebtToVisibilityConverter x:Key="DebtToVisibilityConverter" />

        <Style x:Key="PrimaryActionBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryActionBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC" />
                    <Setter Property="BorderBrush" Value="#94A3B8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Padding" Value="15,0,10,0" />
            <Setter Property="Height" Value="45" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="CustomDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border
                            Padding="15,0,10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="CustomDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F4F7F9" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0F2FE" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border
                            Margin="0,0,10,10"
                            Padding="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.08"
                                    ShadowDepth="3"
                                    Color="#000000" />
                            </Border.Effect>
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#F1F5F9" />
                                <Setter Property="Foreground" Value="#0078D4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="28"
                FontWeight="Bold"
                Foreground="#0F172A"
                Text="Customer Management" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <Border
                    Width="250"
                    Height="38"
                    Margin="0,0,10,0"
                    Padding="10,0"
                    Background="#FFFFFF"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            FontSize="16"
                            Foreground="#94A3B8"
                            Symbol="Search24" />

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock
                                Margin="2,0,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                Foreground="#94A3B8"
                                IsHitTestVisible="False"
                                Text="{Binding SearchPlaceholder}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=SearchInput}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchInput}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox
                                x:Name="SearchInput"
                                Margin="0"
                                Padding="0"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                CaretBrush="#0078D4"
                                Foreground="#0F172A"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer
                                            x:Name="PART_ContentHost"
                                            Margin="0"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Background="Transparent" />
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>


                <Button
                    Margin="0,0,15,0"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryActionBtnStyle}"
                    ToolTip="Refresh Data">
                    <ui:SymbolIcon
                        FontSize="18"
                        Foreground="#0F172A"
                        Symbol="ArrowClockwise24" />
                </Button>
                <Button Command="{Binding AddCustomerCommand}" Style="{StaticResource PrimaryActionBtnStyle}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,6,0"
                            FontSize="18"
                            Foreground="#FFFFFF"
                            Symbol="Add24" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Text="Add Customer" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="15"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.03"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>

            <Grid>
                <ui:DataGrid
                    x:Name="CustomerDataGrid"
                    AlternationCount="2"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CellStyle="{StaticResource CustomDataGridCellStyle}"
                    ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}"
                    Foreground="#1E293B"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#E2E8F0"
                    IsReadOnly="True"
                    ItemsSource="{Binding Customers}"
                    PreviewMouseLeftButtonDown="CustomerDataGrid_PreviewMouseLeftButtonDown"
                    RowHeight="60"
                    RowStyle="{StaticResource CustomDataGridRowStyle}">
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding CustomerId}"
                            ElementStyle="{StaticResource DataGridTextStyle}"
                            Header="ID" />
                        <DataGridTemplateColumn Width="220" Header="Customer Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <Border
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0"
                                            Background="#F1F5F9"
                                            CornerRadius="18">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="#475569"
                                                Text="{Binding Name[0]}" />
                                        </Border>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="Bold"
                                            Foreground="#0F172A"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding Phone}"
                            ElementStyle="{StaticResource DataGridTextStyle}"
                            Header="Phone" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Email}"
                            ElementStyle="{StaticResource DataGridTextStyle}"
                            Header="Email" />

                        <DataGridTemplateColumn Width="140" Header="Debt Balance">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="10,6"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FEE2E2" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Debt}" Value="0">
                                                        <Setter Property="Background" Value="#DCFCE7" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="13" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#EF4444" />
                                                    <Setter Property="Text" Value="{Binding Debt, StringFormat='{}{0:N0} đ'}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Debt}" Value="0">
                                                            <Setter Property="Foreground" Value="#16A34A" />
                                                            <Setter Property="Text" Value="Cleared" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="120" Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                            Margin="0,0,5,0"
                                            Command="{Binding DataContext.EditCustomerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconBtnStyle}"
                                            ToolTip="Edit Customer">
                                            <ui:SymbolIcon
                                                FontSize="18"
                                                Foreground="#0284C7"
                                                Symbol="Edit24" />
                                        </Button>

                                        <Button
                                            Command="{Binding DataContext.DeleteCustomerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconBtnStyle}"
                                            ToolTip="Delete Customer"
                                            Visibility="{Binding Debt, Converter={StaticResource DebtToVisibilityConverter}}">
                                            <ui:SymbolIcon
                                                FontSize="18"
                                                Foreground="#EF4444"
                                                Symbol="Delete24" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </ui:DataGrid.Columns>
                </ui:DataGrid>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Customers.Count}" Value="0" />
                                        <Condition Binding="{Binding IsLoading}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon
                        Margin="0,0,0,15"
                        FontSize="48"
                        Foreground="#CBD5E1"
                        Symbol="FolderOpen24" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#64748B"
                        Text="No customers found." />
                </StackPanel>

                <Border
                    Background="#CCFFFFFF"
                    CornerRadius="8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ui:ProgressRing
                        Width="40"
                        Height="40"
                        Foreground="#0078D4"
                        IsIndeterminate="True" />
                </Border>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Margin="0,15,0,0"
            Background="Transparent"
            CornerRadius="8">
            <Grid>
                <StackPanel
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Foreground="#64748B"
                        Text="Rows per page:" />

                    <ComboBox
                        Width="70"
                        MinHeight="28"
                        Padding="8,0"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#CBD5E1"
                        Foreground="#0F172A"
                        ItemsSource="{Binding PageSizeOptions}"
                        SelectedItem="{Binding PageSize}" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,15,0"
                        VerticalAlignment="Center"
                        Foreground="#64748B">
                        <Run
                            FontWeight="Bold"
                            Foreground="#0F172A"
                            Text="{Binding CurrentPage}" />
                        <Run Text=" of " />
                        <Run
                            FontWeight="Bold"
                            Foreground="#0F172A"
                            Text="{Binding TotalPages}" />
                    </TextBlock>

                    <Button
                        x:Name="PreviousButton"
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Click="PreviousButton_Click"
                        Style="{StaticResource SecondaryActionBtnStyle}">
                        <ui:SymbolIcon
                            FontSize="16"
                            Foreground="#0F172A"
                            Symbol="ChevronLeft24" />
                    </Button>
                    <Button
                        x:Name="NextButton"
                        Height="32"
                        Padding="8,4"
                        Click="NextButton_Click"
                        Style="{StaticResource SecondaryActionBtnStyle}">
                        <ui:SymbolIcon
                            FontSize="16"
                            Foreground="#0F172A"
                            Symbol="ChevronRight24" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>