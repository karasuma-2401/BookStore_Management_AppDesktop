<Page
    x:Class="BookStore_Management_AppDesktop.Views.Pages.CreateImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Create Import"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Background="{DynamicResource ContentBackgroundBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="25,15,25,0"
            Background="{DynamicResource SidebarBackgroundBrush}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="26"
                    FontWeight="Black"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="CREATE NEW IMPORT" />
                <TextBlock
                    Margin="0,5,0,0"
                    FontSize="14"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="Search and add books to the draft before confirming the import" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Padding="25,20,25,20"
            Background="{DynamicResource SidebarBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Find Book (Enter name):" />
                    <ComboBox
                        Height="40"
                        DisplayMemberPath="Title"
                        IsEditable="True"
                        IsTextSearchEnabled="False"
                        ItemsSource="{Binding SearchResults}"
                        SelectedItem="{Binding SelectedSearchResult}"
                        StaysOpenOnEdit="True"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Quantity:" />
                    <ui:TextBox Height="40" Text="{Binding TempImportQuantity, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="{StaticResource FontSizeBody}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Import Price (VND):" />
                    <ui:TextBox Height="40" Text="{Binding TempImportPrice, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="3"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,10,0"
                        Background="{DynamicResource SuccessPrimaryBrush}"
                        Command="{Binding AddToDraftCommand}"
                        Content="Add to Draft"
                        Foreground="{DynamicResource TextOnLightBackgroudBrush}"
                        Icon="{ui:SymbolIcon Add24}"
                        Style="{StaticResource PrimaryActionButtonStyle}" />

                    <ui:Button
                        Command="{Binding OpenCreateNewBookDialogCommand}"
                        Icon="{ui:SymbolIcon DocumentAdd24}"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        ToolTip="Add new book to catalog" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Margin="20"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderLightBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <DataGrid
                AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                FontSize="15"
                Foreground="{DynamicResource TextOnLightBackgroudBrush}"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#E2E8F0"
                ItemsSource="{Binding DraftList}"
                RowBackground="{DynamicResource CardBackgroundBrush}"
                RowHeight="60"
                VerticalGridLinesBrush="Transparent">

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding BookId}"
                        Header="Book ID"
                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Padding" Value="10,0,0,0" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Title}"
                        Header="Book Title"
                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding CurrentQuantity}"
                        Header="Stock"
                        IsReadOnly="True" />

                    <DataGridTextColumn
                        Width="110"
                        Binding="{Binding ImportQuantity, UpdateSourceTrigger=PropertyChanged}"
                        Header="Import Qty" />
                    <DataGridTextColumn
                        Width="130"
                        Binding="{Binding ImportPrice, UpdateSourceTrigger=PropertyChanged}"
                        Header="Price" />

                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding TotalLinePrice, StringFormat={}{0:N0} VND}"
                        Header="Line Total"
                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource SuccessPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:Button
                                    Appearance="Transparent"
                                    Command="{Binding DataContext.RemoveFromDraftCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand"
                                    Foreground="{DynamicResource ErrorPrimaryBrush}"
                                    Icon="{ui:SymbolIcon Delete24}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border
            Grid.Row="3"
            Margin="20,0,20,20"
            Padding="20"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderLightBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,15,0"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeSubTitle}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextMutedBrush}"
                    Text="Total Amount:" />

                <TextBlock
                    Margin="0,0,30,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource PriceTextStyle}"
                    Text="{Binding TotalDraftAmount, StringFormat={}{0:N0} VND}" />

                <ui:Button
                    Margin="0,0,10,0"
                    Command="{Binding ClearDraftCommand}"
                    Content="CLEAR DRAFT"
                    Foreground="{DynamicResource ErrorPrimaryBrush}"
                    Icon="{ui:SymbolIcon Delete24}"
                    Style="{StaticResource SecondaryActionButtonStyle}" />

                <ui:Button
                    Command="{Binding ConfirmImportCommand}"
                    Content="CONFIRM IMPORT"
                    Icon="{ui:SymbolIcon Save24}"
                    Style="{StaticResource PrimaryActionButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>