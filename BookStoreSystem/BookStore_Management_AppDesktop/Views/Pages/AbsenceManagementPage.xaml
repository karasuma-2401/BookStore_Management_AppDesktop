<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.AbsenceManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:BookStore_Management_AppDesktop.Converters"
      mc:Ignorable="d" 
      Background="{DynamicResource ContentBackgroundBrush}" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Absence and Compensation Management">

    <Page.Resources>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15,25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Absence and Compensation Management" FontSize="26" FontWeight="Black" 
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="Month:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding CurrentMonthStart, StringFormat='MMMM yyyy'}" 
                                   Foreground="{DynamicResource SidebarAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Điều hướng tháng -->
                    <Button Style="{StaticResource PremiumColoredButtonStyle}" 
                            Command="{Binding PreviousMonthCommand}"
                            Background="#0F172A" Foreground="White" BorderBrush="#38BDF8" BorderThickness="1.5"
                            Padding="8" Margin="10,0,0,0" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ChevronLeft24" Foreground="White"/>
                    </Button>
                    
                    <Button Style="{StaticResource PremiumColoredButtonStyle}" 
                            Command="{Binding NextMonthCommand}"
                            Background="#0F172A" Foreground="White" BorderBrush="#38BDF8" BorderThickness="1.5"
                            Padding="8" Margin="5,0,0,0" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ChevronRight24" Foreground="White"/>
                    </Button>
                    
                    <Separator Width="1" Background="#475569" Margin="10,0"/>
                    
                    <Button Style="{StaticResource PremiumColoredButtonStyle}" 
                            Command="{Binding RefreshDataCommand}"
                            Background="#0F172A" Foreground="White" BorderBrush="#38BDF8" BorderThickness="1.5"
                            Padding="8" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="ArrowSync24" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" Margin="20" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="From Date" Foreground="#64748B" FontSize="11" Margin="0,0,0,3"/>
                            <DatePicker SelectedDate="{Binding FilterStartDate}" 
                                       Background="White" Foreground="#1E293B" 
                                       BorderBrush="#38BDF8" BorderThickness="1.5" 
                                       Padding="8,6" FontSize="12" Width="220" Height="40"
                                       SelectedDateFormat="Short" Language="vi-VN"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10,0,0,0">
                            <TextBlock Text="To Date" Foreground="#64748B" FontSize="11" Margin="0,0,0,3"/>
                            <DatePicker SelectedDate="{Binding FilterEndDate}" 
                                       Background="White" Foreground="#1E293B" 
                                       BorderBrush="#38BDF8" BorderThickness="1.5" 
                                       Padding="8,6" FontSize="12" Width="220" Height="40"
                                       SelectedDateFormat="Short" Language="vi-VN"/>
                        </StackPanel>

                        <Button Grid.Column="2" Style="{StaticResource PremiumColoredButtonStyle}"
                                   Command="{Binding ApplyDateFilterCommand}"
                                   Background="#6366F1" Foreground="White"
                                   BorderBrush="#4F46E5" BorderThickness="1.5"
                                   Padding="12,6" FontSize="12" Margin="10,0,0,0"
                                   Height="36" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Search24" Foreground="White" Margin="0,0,6,0"/>
                                <TextBlock Text="Filter" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Style="{StaticResource PremiumColoredButtonStyle}"
                                    Command="{Binding SelectAllCommand}"
                                    Background="Transparent" BorderBrush="{DynamicResource SidebarAccentBrush}" BorderThickness="1.5"
                                    Foreground="{DynamicResource SidebarAccentBrush}"
                                    Padding="10,0" FontSize="11" Margin="0,0,5,0" Height="36" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource SidebarAccentBrush}" Margin="0,0,6,0"/>
                                    <TextBlock Text="Select All" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PremiumColoredButtonStyle}"
                                    Command="{Binding ClearSelectionCommand}"
                                    Background="Transparent" BorderBrush="#94A3B8" BorderThickness="1.5"
                                    Foreground="#64748B"
                                    Padding="10,0" FontSize="11" Margin="0,0,5,0" Height="36" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Delete24" Foreground="#64748B" Margin="0,0,6,0"/>
                                    <TextBlock Text="Clear" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PremiumColoredButtonStyle}"
                                    Command="{Binding ApproveBulkCompensationCommand}"
                                    Background="{DynamicResource SuccessPrimaryBrush}" Foreground="White"
                                    BorderBrush="#059669" BorderThickness="1.5"
                                    Padding="14,0" FontSize="11" FontWeight="SemiBold" Height="36" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="White" Margin="0,0,6,0"/>
                                    <TextBlock Text="Bulk Approve" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <DataGrid ItemsSource="{Binding AbsentShifts}" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False" 
                              IsReadOnly="True"
                              RowHeight="60"
                              HeadersVisibility="Column"
                              Foreground="#1E293B" 
                              Background="Transparent" 
                              CanUserResizeColumns="False" 
                              RowBackground="{DynamicResource CardBackgroundBrush}"
                              AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                              HorizontalGridLinesBrush="#E2E8F0" 
                              VerticalGridLinesBrush="Transparent"
                              FontSize="14" 
                              Cursor="Hand"
                              EnableRowVirtualization="True"
                              PreviewMouseLeftButtonDown="AbsenceDataGrid_PreviewMouseLeftButtonDown">
                        
                        <DataGrid.Resources>
                            <!-- Tự động căn trái toàn bộ textblock trong các ô của DataGrid để thẳng cột với tiêu đề, đồng thời sửa màu chữ sang tối để dễ đọc -->
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="12,0"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Setter Property="Height" Value="60"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SidebarAccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                        <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.ColumnHeaderStyle>
                            <!-- Căn trái tiêu đề của các cột khớp với nội dung -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="0.8*" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Employee Name" Binding="{Binding FullName}" Width="2*"/>
                            <DataGridTextColumn Header="Work Date" Binding="{Binding WorkDate}" Width="1.5*"/>
                            <DataGridTextColumn Header="Shift" Binding="{Binding ShiftName}" Width="1.2*"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding WorkTime}" Width="1.8*"/>

                            <DataGridTemplateColumn Header="Status" Width="1.2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                CornerRadius="3" Padding="6,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold" FontSize="11" Margin="0"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Action" Width="1.2*" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0">
                                            <Button Style="{StaticResource PremiumColoredButtonStyle}"
                                                    Background="{DynamicResource SuccessPrimaryBrush}" 
                                                    Foreground="White"
                                                    BorderBrush="#059669" BorderThickness="1.5"
                                                    Padding="12,6"
                                                    ToolTip="Approve Individual Compensation"
                                                    Command="{Binding DataContext.ApproveCompensationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding .}">
                                                <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>