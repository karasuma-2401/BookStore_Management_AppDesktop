<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.SaleCartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Shopping Cart"
      Background="{DynamicResource SidebarBackgroundBrush}">
    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}" 
                           Command="{Binding ContinueShoppingCommand}"
                           Style="{StaticResource SecondaryActionButtonStyle}"
                           Margin="0,0,15,0"
                           Foreground="White"/>
                <TextBlock Text="Your Shopping Cart" 
                           Style="{StaticResource HeaderTextStyle}" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="White"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Margin="0,0,20,0" Padding="15">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=CartListView, Path=HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ui:SymbolIcon Symbol="Cart24" Filled="True" FontSize="64" Foreground="#94A3B8"/>
                        <TextBlock Text="Your cart is currently empty" FontSize="16" Margin="0,15,0,10" Foreground="#64748B" HorizontalAlignment="Center"/>
                        <ui:Button Content="Shop Now" Command="{Binding ContinueShoppingCommand}" Appearance="Primary" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ListView x:Name="CartListView" 
                              ItemsSource="{Binding CartItems}" 
                              Background="Transparent" 
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="10,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True" Height="90" Width="65" Background="#F8FAFC">
                                            <Image Source="{Binding ImagePath, TargetNullValue='https://via.placeholder.com/65x90?text=No+Image'}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" TextTrimming="CharacterEllipsis" MaxHeight="45" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding AuthorName}" FontSize="13" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding Price, StringFormat='{}{0:#,0} đ'}" FontSize="13" Foreground="#0EA5E9" FontWeight="Medium" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Button Icon="{ui:SymbolIcon Subtract24}" Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Padding="6" CornerRadius="4"/>
                                            <TextBlock Text="{Binding Quantity}" Width="40" TextAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <ui:Button Icon="{ui:SymbolIcon Add24}" Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Padding="6" CornerRadius="4"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#1E293B">
                                            <Run Text="{Binding TotalLinePrice, Mode=OneWay, StringFormat='{}{0:#,0}'}"/>
                                            <Run Text=" đ" FontSize="12" FontWeight="Normal" Foreground="#64748B"/>
                                        </TextBlock>

                                        <ui:Button Grid.Column="4" Icon="{ui:SymbolIcon Delete24}" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Appearance="Transparent" MouseOverBorderBrush="Red" Foreground="#94A3B8" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Order Summary" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Subtotal" Foreground="#64748B" FontSize="14"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Medium" Foreground="#1E293B">
                                <Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat='{}{0:#,0}'}"/> đ
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Discount" Foreground="#64748B" FontSize="14"/>
                            <TextBlock HorizontalAlignment="Right" Text="0 đ" Foreground="Green" FontSize="14"/>
                        </Grid>
                        <Separator Background="#E2E8F0" Margin="0,5,0,15"/>
                        <Grid Margin="0,0,0,25">
                            <TextBlock Text="Total Amount" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="20" FontWeight="Black" Foreground="#0EA5E9">
                                <Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat='{}{0:#,0}'}"/>
                                <Run Text=" đ" FontSize="14" FontWeight="Medium"/>
                            </TextBlock>
                        </Grid>
                        <ui:Button Content="CREATE INVOICE" Command="{Binding CreateInvoiceCommand}" Appearance="Primary" Icon="{ui:SymbolIcon Receipt24}" FontSize="15" FontWeight="Bold" Padding="15" Height="50" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Padding="20" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="Customer" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextOnCardBrush}" Margin="0,0,0,5"/>
                        <Border Height="38" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Margin="0,0,0,15">
                            <ComboBox SelectedValue="{Binding SelectedCustomerId, Mode=TwoWay}" DisplayMemberPath="CustomerName" SelectedValuePath="CustomerId" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                        </Border>

                        <TextBlock Text="Voucher Code" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextOnCardBrush}" Margin="0,0,0,5"/>
                        <Border Height="38" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <TextBlock Text="Enter discount code..." Foreground="{DynamicResource TextSecondBrush}" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding VoucherCodeInput}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VoucherCodeInput}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ui:TextBox Text="{Binding VoucherCodeInput, Mode=TwoWay}" Background="Transparent" BorderThickness="0"/>
                            </Grid>
                        </Border>
                        <ui:Button Content="Continue Shopping" Command="{Binding ContinueShoppingCommand}" Appearance="Secondary" Margin="0,15,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>