<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.SaleCartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Shopping Cart"
      Background="{DynamicResource SidebarBackgroundBrush}">
    <Page.Resources>
        <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlForeground" Color="#1E293B"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#1E293B"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#1E293B"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#94A3B8"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#94A3B8"/>
                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
            </Style.Resources>
        </Style>
    </Page.Resources>
    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}" 
                           Command="{Binding ContinueShoppingCommand}"
                           Style="{StaticResource SecondaryActionButtonStyle}"
                           Margin="0,0,15,0"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Your Shopping Cart" 
                           Style="{StaticResource HeaderTextStyle}" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Margin="0,0,20,0" Padding="15">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=CartListView, Path=HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ui:SymbolIcon Symbol="Cart24" Filled="True" FontSize="64" Foreground="{DynamicResource TextSecondBrush}"/>
                        <TextBlock Text="Your cart is currently empty" FontSize="16" Margin="0,15,0,10" Foreground="{DynamicResource TextBodyBrush}" HorizontalAlignment="Center"/>
                        <ui:Button Content="Shop Now" Command="{Binding ContinueShoppingCommand}" Appearance="Primary" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ListView x:Name="CartListView" 
                              ItemsSource="{Binding CartItems}" 
                              Background="Transparent" 
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True" Height="90" Width="65" Background="{DynamicResource CardBackgroundBrush}">
                                            <Image Source="{Binding ImagePath, TargetNullValue='https://via.placeholder.com/65x90?text=No+Image'}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextOnCardBrush}" TextTrimming="CharacterEllipsis" MaxHeight="45" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding AuthorName}" FontSize="13" Foreground="{DynamicResource TextBodyBrush}"/>
                                            <TextBlock Text="{Binding Price, StringFormat='{}{0:#,0} đ'}" FontSize="13" Foreground="{DynamicResource AccentBlueBrush}" FontWeight="Medium" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Background="Transparent" Margin="0,0,15,0">
                                            <ui:Button Icon="{ui:SymbolIcon Subtract24}" Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Padding="8" CornerRadius="4" Appearance="Secondary"/>
                                            <Border Width="45" Height="36" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="5,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Quantity, Mode=OneWay}" TextAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextOnCardBrush}"/>
                                            </Border>
                                            <ui:Button Icon="{ui:SymbolIcon Add24}" Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Padding="8" CornerRadius="4" Appearance="Secondary"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextOnCardBrush}">
                                            <Run Text="{Binding TotalLinePrice, Mode=OneWay, StringFormat='{}{0:#,0}'}"/>
                                            <Run Text=" đ" FontSize="12" FontWeight="Normal" Foreground="{DynamicResource TextBodyBrush}"/>
                                        </TextBlock>

                                        <ui:Button Grid.Column="4" Icon="{ui:SymbolIcon Delete24}" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Appearance="Transparent" Foreground="{DynamicResource TextSecondBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Order Summary" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextOnCardBrush}" Margin="0,0,0,20"/>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Subtotal" Foreground="{DynamicResource TextBodyBrush}" FontSize="14"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextOnCardBrush}">
                                <Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat='{}{0:#,0}'}"/> 
                                <Run Text="đ" Foreground="{DynamicResource TextBodyBrush}" FontSize="12"/>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Discount" Foreground="{DynamicResource TextBodyBrush}" FontSize="14"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="14" Foreground="{DynamicResource SuccessPrimaryBrush}" FontWeight="Medium">
                                <Run Text="-"/>
                                <Run Text="{Binding DiscountAmount, Mode=OneWay, StringFormat='{}{0:#,0}'}"/>
                                <Run Text=" đ" Foreground="{DynamicResource TextBodyBrush}" FontSize="12"/>
                            </TextBlock>
                        </Grid>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,5,0,15"/>
                        <Grid Margin="0,0,0,25">
                            <TextBlock Text="Total Amount" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextOnCardBrush}" VerticalAlignment="Center"/>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock FontSize="20" FontWeight="Black" Foreground="{DynamicResource AccentBlueBrush}">
                                    <Run Text="{Binding FinalTotal, Mode=OneWay, StringFormat='{}{0:#,0}'}"/>
                                </TextBlock>
                                <TextBlock FontSize="14" FontWeight="Medium" Foreground="{DynamicResource AccentBlueBrush}" Margin="5,0,0,0" VerticalAlignment="Bottom"> đ</TextBlock>
                            </StackPanel>
                        </Grid>
                        <ui:Button Content="CHECKOUT" Command="{Binding CheckoutCommand}" Appearance="Primary" Icon="{ui:SymbolIcon Cart24}" FontSize="15" FontWeight="Bold" Padding="15" Height="50" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Padding="20" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="Customer" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="38" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                <ComboBox ItemsSource="{Binding Customers}" 
                                          SelectedValue="{Binding SelectedCustomerId, Mode=TwoWay}" 
                                          DisplayMemberPath="Name" 
                                          SelectedValuePath="CustomerId" 
                                          Background="Transparent" BorderThickness="0" 
                                          Foreground="#1E293B"
                                          VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                            </Border>

                            <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Add24}" Command="{Binding OpenAddCustomerDialogCommand}" Margin="10,0,0,0" Appearance="Secondary"/>
                        </Grid>

                        <TextBlock Text="Voucher Code" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextOnCardBrush}" Margin="0,0,0,5"/>
                        <Border Height="38" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                            <ui:TextBox Text="{Binding VoucherCodeInput, Mode=TwoWay}" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="10,0,0,0"/>
                        </Border>
                        <ui:Button Content="APPLY VOUCHER" Command="{Binding ApplyVoucherCommand}" Appearance="Primary" Margin="0,0,0,15" HorizontalAlignment="Stretch" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>