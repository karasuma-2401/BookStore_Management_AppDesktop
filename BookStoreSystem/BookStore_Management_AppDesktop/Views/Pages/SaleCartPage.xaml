<Page
    x:Class="BookStore_Management_AppDesktop.Views.Pages.SaleCartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Shopping Cart"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Background="#111625"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="NativeBoolToVis" />
        <Style BasedOn="{StaticResource {x:Type ui:TextBox}}" TargetType="ui:TextBox">
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlForeground" Color="#FFFFFF" />
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#FFFFFF" />
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFFFFF" />
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#64748B" />
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#64748B" />
                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
            </Style.Resources>
        </Style>
    </Page.Resources>

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <Button Margin="0,0,15,0" Command="{Binding ContinueShoppingCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="38" />
                            <Setter Property="Height" Value="38" />
                            <Setter Property="Background" Value="#161B26" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                            <Setter Property="BorderBrush" Value="#232D42" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="19">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#232D42" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#111625" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <ui:SymbolIcon
                        FontSize="16"
                        FontWeight="Bold"
                        Symbol="ArrowLeft24" />
                </Button>
                <TextBlock
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#FFFFFF"
                    Style="{StaticResource HeaderTextStyle}"
                    Text="Bookstore Cart" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="0,0,25,0"
                Padding="20"
                Background="#161B26"
                BorderBrush="#232D42"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=CartListView, Path=HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ui:SymbolIcon
                            Margin="0,0,0,15"
                            Filled="True"
                            FontSize="64"
                            Foreground="#334155"
                            Symbol="Cart24" />
                        <TextBlock
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center"
                            FontSize="15"
                            Foreground="#94A3B8"
                            Text="Your shopping cart is empty" />
                        <Button Command="{Binding ContinueShoppingCommand}" Content="Shop Now">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Padding" Value="24,10" />
                                    <Setter Property="Background" Value="#0078D4" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#106EBE" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#005A9E" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <ListView
                        x:Name="CartListView"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding CartItems}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="0,16"
                                    BorderBrush="#232D42"
                                    BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Grid.Column="0"
                                            Width="65"
                                            Height="90"
                                            Background="#1E293B"
                                            ClipToBounds="True"
                                            CornerRadius="6">
                                            <Image Source="{Binding ImagePath, TargetNullValue='https://via.placeholder.com/65x90?text=No+Image'}" Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="20,0"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                MaxHeight="45"
                                                Margin="0,0,0,6"
                                                FontSize="15"
                                                FontWeight="Bold"
                                                Foreground="#FFFFFF"
                                                Text="{Binding Title}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Margin="0,0,0,6"
                                                FontSize="13"
                                                Foreground="#94A3B8"
                                                Text="{Binding AuthorName}" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="#94A3B8"
                                                Text="{Binding Price, StringFormat='{}{0:#,0} đ'}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            Margin="0,0,20,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Width" Value="30" />
                                                        <Setter Property="Height" Value="30" />
                                                        <Setter Property="Background" Value="#334155" />
                                                        <Setter Property="Foreground" Value="#F8FAFC" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569" />
                                                                <Setter Property="Foreground" Value="#FFFFFF" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#1E293B" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <ui:SymbolIcon
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Symbol="Subtract24" />
                                            </Button>

                                            <TextBlock
                                                Width="40"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Foreground="#FFFFFF"
                                                Text="{Binding Quantity, Mode=OneWay}"
                                                TextAlignment="Center" />

                                            <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Width" Value="30" />
                                                        <Setter Property="Height" Value="30" />
                                                        <Setter Property="Background" Value="#334155" />
                                                        <Setter Property="Foreground" Value="#F8FAFC" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#475569" />
                                                                <Setter Property="Foreground" Value="#FFFFFF" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#1E293B" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <ui:SymbolIcon
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Symbol="Add24" />
                                            </Button>
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="#FFFFFF">
                                            <Run Text="{Binding TotalLinePrice, Mode=OneWay, StringFormat='{}{0:#,0}'}" />
                                            <Run
                                                FontSize="12"
                                                FontWeight="Normal"
                                                Foreground="#94A3B8"
                                                Text=" đ" />
                                        </TextBlock>

                                        <Button
                                            Grid.Column="4"
                                            Margin="15,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Width" Value="32" />
                                                    <Setter Property="Height" Value="32" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Foreground" Value="#64748B" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2A1B24" />
                                                            <Setter Property="Foreground" Value="#FF4D4F" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter Property="Background" Value="#1F131A" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <ui:SymbolIcon FontSize="16" Symbol="Delete24" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border
                    Padding="20"
                    VerticalAlignment="Top"
                    Background="#161B26"
                    BorderBrush="#232D42"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#FFFFFF"
                            Text="Order Summary" />
                        <Grid Margin="0,0,0,14">
                            <TextBlock
                                FontSize="14"
                                Foreground="#94A3B8"
                                Text="Subtotal" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#FFFFFF">
                                <Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat='{}{0:#,0}'}" />
                                <Run
                                    FontSize="12"
                                    FontWeight="Normal"
                                    Foreground="#94A3B8"
                                    Text="đ" />
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,18">
                            <TextBlock
                                FontSize="14"
                                Foreground="#94A3B8"
                                Text="Discount" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#FF4D4F">
                                <Run Text="-" />
                                <Run Text="{Binding DiscountAmount, Mode=OneWay, StringFormat='{}{0:#,0}'}" />
                                <Run
                                    FontSize="12"
                                    FontWeight="Normal"
                                    Foreground="#94A3B8"
                                    Text=" đ" />
                            </TextBlock>
                        </Grid>
                        <Separator Margin="0,0,0,18" Background="#232D42" />
                        <Grid Margin="0,0,0,25">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="#FFFFFF"
                                Text="Total Amount" />
                            <StackPanel
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    FontSize="22"
                                    FontWeight="Black"
                                    Foreground="#0078D4">
                                    <Run Text="{Binding FinalTotal, Mode=OneWay, StringFormat='{}{0:#,0}'}" />
                                </TextBlock>
                                <TextBlock
                                    Margin="3,0,0,2"
                                    VerticalAlignment="Bottom"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#0078D4"
                                    Text="đ" />
                            </StackPanel>
                        </Grid>

                        <Button
                            Height="46"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CheckoutCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#0078D4" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#106EBE" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#005A9E" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Symbol="Cart24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="CHECKOUT" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border
                    Margin="0,16,0,0"
                    Padding="20"
                    Background="#161B26"
                    BorderBrush="#232D42"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#FFFFFF"
                            Text="Customer" />
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Height="38"
                                Background="#1E293B"
                                BorderBrush="#232D42"
                                BorderThickness="1"
                                CornerRadius="6">
                                <ComboBox
                                    Margin="5,0"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    DisplayMemberPath="Name"
                                    Foreground="#FFFFFF"
                                    ItemsSource="{Binding Customers}"
                                    SelectedValue="{Binding SelectedCustomerId, Mode=TwoWay}"
                                    SelectedValuePath="CustomerId" />
                            </Border>

                            <Button
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                Command="{Binding OpenAddCustomerDialogCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Width" Value="38" />
                                        <Setter Property="Height" Value="38" />
                                        <Setter Property="Background" Value="#252B37" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#334155" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#1E293B" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ui:SymbolIcon
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Symbol="Add24" />
                            </Button>
                        </Grid>

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#FFFFFF"
                            Text="Voucher Code" />
                        <Border
                            Height="38"
                            Margin="0,0,0,12"
                            Background="#1E293B"
                            BorderBrush="#232D42"
                            BorderThickness="1"
                            CornerRadius="6">
                            <ComboBox
                                Margin="5,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                DisplayMemberPath="Code"
                                Foreground="#FFFFFF"
                                ItemsSource="{Binding Vouchers}"
                                SelectedValue="{Binding VoucherCodeInput, Mode=TwoWay}"
                                SelectedValuePath="Code" />
                        </Border>

                        <Button
                            Height="38"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ApplyVoucherCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#252B37" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#334155" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1E293B" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Symbol="TicketHorizontal24" />
                                <TextBlock VerticalAlignment="Center" Text="APPLY VOUCHER" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
