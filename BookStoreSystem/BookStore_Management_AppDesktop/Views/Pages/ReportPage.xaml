<Page
    x:Class="BookStore_Management_AppDesktop.Views.Pages.ReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BookStore_Management_AppDesktop.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:BookStore_Management_AppDesktop.ViewModels"
    Title="Report Dashboard"
    d:DataContext="{d:DesignInstance Type=viewmodels:ReportViewModel}"
    d:DesignHeight="768"
    d:DesignWidth="1100"
    Background="{DynamicResource ContentBackgroundBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="144" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="25,15,25,15"
            Background="{DynamicResource SidebarBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="26"
                        FontWeight="Black"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Financial Report" />
                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Overview of revenue, costs and top selling books" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Month:" />
                    <ComboBox
                        Width="80"
                        Margin="0,0,20,0"
                        Background="Transparent"
                        BorderBrush="{StaticResource TextPrimaryBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        ItemsSource="{Binding Months}"
                        SelectedItem="{Binding SelectedMonth}" />

                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Year:" />
                    <ComboBox
                        Width="90"
                        Margin="0,0,20,0"
                        Background="Transparent"
                        BorderBrush="{StaticResource TextPrimaryBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        ItemsSource="{Binding Years}"
                        SelectedItem="{Binding SelectedYear}" />

                    <ui:Button
                        Margin="0,0,10,0"
                        Padding="20,8"
                        Appearance="Primary"
                        Background="{DynamicResource NavyAccentBrush}"
                        Command="{Binding GenerateReportCommand}"
                        Content="Generate Report" />

                    <ui:Button
                        Padding="20,8"
                        Appearance="Secondary"
                        BorderBrush="{StaticResource SuccessPrimaryBrush}"
                        Command="{Binding ExportToExcelCommand}"
                        Foreground="{StaticResource SuccessPrimaryBrush}"
                        Style="{DynamicResource OutlineButtonStyle}">

                        <StackPanel Orientation="Horizontal">

                            <ui:SymbolIcon Margin="0,0,8,0" Symbol="{x:Static ui:SymbolRegular.Save24}" />

                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="Export to Excel" />

                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid
            Grid.Row="1"
            Margin="20,20,20,10"
            Columns="3"
            Rows="1">
            <Border
                Margin="8"
                Padding="18"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="16">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Opacity="0.08"
                        ShadowDepth="3"
                        Color="Black" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#A0A0A0"
                            Text="TOTAL REVENUE" />

                        <TextBlock
                            Margin="0,12,0,0"
                            FontSize="30"
                            FontWeight="Black"
                            Foreground="{DynamicResource SuccessPrimaryBrush}"
                            Text="{Binding TotalRevenue, StringFormat={}{0:N0} ₫}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Width="52"
                        Height="52"
                        Background="#163D2A"
                        CornerRadius="12">

                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Foreground="#4ADE80"
                            Symbol="{x:Static ui:SymbolRegular.ArrowUp24}" />
                    </Border>
                </Grid>
            </Border>
            <Border
                Margin="8"
                Padding="18"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="16">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Opacity="0.08"
                        ShadowDepth="3"
                        Color="Black" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#A0A0A0"
                            Text="TOTAL IMPORT COST" />

                        <TextBlock
                            Margin="0,12,0,0"
                            FontSize="30"
                            FontWeight="Black"
                            Foreground="{DynamicResource ErrorPrimaryBrush}"
                            Text="{Binding TotalImportCost, StringFormat={}{0:N0} ₫}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Width="52"
                        Height="52"
                        Background="#3B1F1F"
                        CornerRadius="12">

                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Foreground="#F87171"
                            Symbol="{x:Static ui:SymbolRegular.ArrowTrendingDown24}" />
                    </Border>
                </Grid>
            </Border>
            <Border
                Margin="8"
                Padding="18"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="16">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Opacity="0.08"
                        ShadowDepth="3"
                        Color="Black" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#A0A0A0"
                            Text="BOOKS SOLD" />

                        <TextBlock
                            Margin="0,12,0,0"
                            FontSize="30"
                            FontWeight="Black"
                            Foreground="{DynamicResource SidebarAccentBrush}"
                            Text="{Binding TotalBooksSold}" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Width="52"
                        Height="52"
                        Background="#60A5FF"
                        CornerRadius="12">

                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Foreground="White"
                            Symbol="{x:Static ui:SymbolRegular.Library24}" />
                    </Border>
                </Grid>
            </Border>

        </UniformGrid>


        <Grid Grid.Row="2" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="5,0,10,0"
                Padding="20"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.1"
                        ShadowDepth="2"
                        Color="Black" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Daily Revenue Trend" />

                    <lvc:CartesianChart
                        Grid.Row="1"
                        Series="{Binding RevenueSeries}"
                        TooltipPosition="Hidden"
                        XAxes="{Binding XAxes}" />

                    <ui:ProgressRing
                        Grid.Row="1"
                        Width="60"
                        Height="60"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource NavyAccentBrush}"
                        IsIndeterminate="True"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Margin="10,0,5,0"
                Padding="20"
                Background="{DynamicResource SidebarBackgroundBrush}"
                CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.1"
                        ShadowDepth="2"
                        Color="Black" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        HorizontalAlignment="Center"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Top 5 Selling Books" />

                    <DataGrid
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding TopBooks}"
                        RowBackground="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Title}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Header="Book Title">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn
                                Width="60"
                                Binding="{Binding TotalSold}"
                                Foreground="{DynamicResource SidebarAccentBrush}"
                                Header="Sold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding RevenueGenerated, StringFormat={}{0:N0} ₫}"
                                Foreground="{DynamicResource SuccessPrimaryBrush}"
                                Header="Revenue">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>