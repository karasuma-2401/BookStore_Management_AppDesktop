<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.BookViews.BookPage"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
          xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
          xmlns:uc="clr-namespace:BookStore_Management_AppDesktop.Views.UserControls" 
          mc:Ignorable="d" 
          d:DesignHeight="700" d:DesignWidth="1000"
          Title="BookPage"
          Background="{DynamicResource ContentBackgroundBrush}"
          TextOptions.TextFormattingMode="Display"
          UseLayoutRounding="True"
          Loaded="Page_Loaded">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="NativeBoolToVis" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Books" Style="{StaticResource HeaderTextStyle}" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:TextBox PlaceholderText="Search by title or category..." 
                                Icon="{ui:SymbolIcon Search24}" 
                                Width="300" Margin="0,0,15,0" 
                                VerticalAlignment="Center" 
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Width="180" Margin="0,0,15,0"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding SelectedSort}"
                              VerticalAlignment="Center">
                        <ComboBoxItem Content="Newest" Tag="" IsSelected="True"/>
                        <ComboBoxItem Content="Price: Low to High" Tag="price_asc"/>
                        <ComboBoxItem Content="Price: High to Low" Tag="price_desc"/>
                        <ComboBoxItem Content="Title: A-Z" Tag="title_asc"/>
                    </ComboBox>

                    <Grid Width="50" Height="50" Margin="0,0,10,0">
                        <ui:Button Icon="{ui:SymbolIcon Cart24}" 
                                   Style="{StaticResource PrimaryActionButtonStyle}"
                                   ToolTip="View Shopping Cart" 
                                   Command="{Binding ViewCartCommand}"
                                   Width="46" Height="46" Padding="0" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Border Background="{DynamicResource SuccessPrimaryBrush}" 
                                CornerRadius="50"
                                Width="22" Height="22" 
                                Margin="0,0,-2,0"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Visibility="{Binding CartItemCount, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}">
                            <TextBlock Text="{Binding CartItemCount}" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       FontSize="11"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <ListView x:Name="BooksListView"
                  Grid.Row="1" Grid.Column="0"
                  ItemsSource="{Binding Books}" 
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="10,10,10,10" d:ItemsSource="{d:SampleData ItemCount=5}">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <uc:BookCard />
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <uc:PaginationControl Grid.Row="2" Grid.Column="0" Margin="25,0,25,15"
                               CurrentPage="{Binding CurrentPage}"
                               TotalPages="{Binding TotalPages}"
                               TotalItems="{Binding TotalItems}"
                               ItemName="books"
                               PreviousPageCommand="{Binding PreviousPageCommand}"
                               NextPageCommand="{Binding NextPageCommand}"/>

        <uc:BookDetailPanel Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"
                            Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource NativeBoolToVis}}"/>
    </Grid>
</Page>