<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.BookViews.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="BookPage"
      Background="{DynamicResource ContentBackgroundBrush}"
      TextOptions.TextFormattingMode="Display"
      UseLayoutRounding="True"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Books" Style="{StaticResource HeaderTextStyle}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:TextBox PlaceholderText="Search by title or category..." 
                                Icon="{ui:SymbolIcon Search24}" 
                                Width="300" Margin="0,0,15,0" 
                                VerticalAlignment="Center" 
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Width="180" Margin="0,0,15,0"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding SelectedSort}"
                              VerticalAlignment="Center">
                        <ComboBoxItem Content="Newest" Tag="" IsSelected="True"/>
                        <ComboBoxItem Content="Price: Low to High" Tag="price_asc"/>
                        <ComboBoxItem Content="Price: High to Low" Tag="price_desc"/>
                        <ComboBoxItem Content="Title: A-Z" Tag="title_asc"/>
                    </ComboBox>

                    <Grid Width="50" Height="50" Margin="0,0,10,0">
                        <ui:Button Icon="{ui:SymbolIcon Cart24}" 
                                   Style="{StaticResource PrimaryActionButtonStyle}"
                                   ToolTip="View Shopping Cart" 
                                   Command="{Binding ViewCartCommand}"
                                   Padding="12,8" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Cart Item Badge -->
                        <Border Background="{DynamicResource SuccessPrimaryBrush}" 
                                CornerRadius="50"
                                Width="24" Height="24" 
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Visibility="{Binding CartItemCount, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}">
                            <TextBlock Text="{Binding CartItemCount}" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       FontSize="11"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <ListView x:Name="BooksListView"
                  Grid.Row="1"
                  ItemsSource="{Binding Books}" 
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Padding="10,10,10,20" d:ItemsSource="{d:SampleData ItemCount=5}">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="210" 
                            Background="{DynamicResource CardBackgroundBrush}" 
                            Margin="15"
                            BorderBrush="#E2E8F0" 
                            BorderThickness="1" 
                            CornerRadius="12"
                            Cursor="Hand">

                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick" 
                                          Command="{Binding DataContext.ViewBookDetailCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>

                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="3"/>
                        </Border.Effect>

                        <StackPanel Margin="12">
                            <Border CornerRadius="8" ClipToBounds="True" Margin="0,0,0,12" Background="{DynamicResource ContentBackgroundBrush}">
                                <Image Height="250" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="{Binding ImagePath, IsAsync=True, TargetNullValue='https://via.placeholder.com/180x250?text=No+Image', FallbackValue='https://via.placeholder.com/180x250?text=No+Image'}">
                                </Image>
                            </Border>

                            <TextBlock Text="{Binding Title}" 
                                       Style="{StaticResource BookTitleTextStyle}"
                                       Height="44" 
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Price, StringFormat='{}{0:#,0}', TargetNullValue='0'}" 
                                           Style="{StaticResource PriceTextStyle}"/>
                                <TextBlock Text=" đ" 
                                           FontSize="{StaticResource FontSizeBody}" 
                                           FontWeight="SemiBold" 
                                           Foreground="{DynamicResource TextSecondBrush}"
                                           VerticalAlignment="Bottom"
                                           Margin="2,0,0,1"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Border Grid.Row="2" Background="{DynamicResource SidebarBackgroundBrush}" Margin="25,0,25,20" Padding="20,10" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextSecondBrush}">
                    <Run Text="Showing Page " />
                    <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Run Text=" of " />
                    <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Run Text="  (Total: " />
                    <Run Text="{Binding TotalItems, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Run Text=" books)" />
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" 
                               Command="{Binding PreviousPageCommand}" 
                               Style="{StaticResource SecondaryActionButtonStyle}" 
                               Margin="0,0,10,0" ToolTip="Previous Page"/>

                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" 
                               Command="{Binding NextPageCommand}" 
                               Style="{StaticResource PrimaryActionButtonStyle}" 
                               ToolTip="Next Page"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>