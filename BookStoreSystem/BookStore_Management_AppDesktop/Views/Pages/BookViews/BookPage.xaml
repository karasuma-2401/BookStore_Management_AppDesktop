<Page
    x:Class="BookStore_Management_AppDesktop.Views.Pages.BookViews.BookPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:BookStore_Management_AppDesktop.Views.UserControls"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="BookPage"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Background="{DynamicResource ContentBackgroundBrush}"
    Loaded="Page_Loaded"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="NativeBoolToVis" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="25,10"
            Background="#111625"
            BorderBrush="#232D42"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Style="{StaticResource HeaderTextStyle}"
                    Text="Books" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:TextBox
                        Width="300"
                        Margin="0,0,15,0"
                        VerticalAlignment="Center"
                        Icon="{ui:SymbolIcon Search24}"
                        PlaceholderText="Search by title or category..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox
                        Width="180"
                        Margin="0,0,15,0"
                        VerticalAlignment="Center"
                        SelectedIndex="0"
                        SelectedValue="{Binding SelectedSort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Tag">
                        <ComboBoxItem Content="Newest" Tag="{x:Null}" />
                        <ComboBoxItem Content="Price: Low to High" Tag="price_asc" />
                        <ComboBoxItem Content="Price: High to Low" Tag="price_desc" />
                        <ComboBoxItem Content="Title: A-Z" Tag="title_asc" />
                    </ComboBox>
                    <Grid
                        Width="54"
                        Height="54"
                        Margin="0,0,10,0">

                        <ui:Button
                            Width="46"
                            Height="46"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Command="{Binding ViewCartCommand}"
                            ToolTip="View Shopping Cart">
                            <ui:Button.Style>
                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                    <Setter Property="Background" Value="#0078D4" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="CornerRadius" Value="23" />

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#106EBE" />
                                            <Setter Property="Cursor" Value="Hand" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#005A9E" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <ui:SymbolIcon
                                FontSize="20"
                                FontWeight="SemiBold"
                                Symbol="Cart24" />
                        </ui:Button>
                        <Border
                            Width="19"
                            Height="19"
                            Margin="0,2,2,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#FF4D4F"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            IsHitTestVisible="False"
                            Visibility="{Binding CartItemCount, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="3"
                                    Opacity="0.3"
                                    ShadowDepth="1"
                                    Color="Black" />
                            </Border.Effect>

                            <TextBlock
                                Margin="0,0,0,0.5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="10"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding CartItemCount}" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <ListView
            x:Name="BooksListView"
            Grid.Row="1"
            Grid.Column="0"
            Padding="10,10,10,10"
            d:ItemsSource="{d:SampleData ItemCount=5}"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Books}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <uc:BookCard />
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <uc:PaginationControl
            Grid.Row="2"
            Grid.Column="0"
            Margin="25,0,25,15"
            CurrentPage="{Binding CurrentPage}"
            ItemName="books"
            NextPageCommand="{Binding NextPageCommand}"
            PreviousPageCommand="{Binding PreviousPageCommand}"
            TotalItems="{Binding TotalItems}"
            TotalPages="{Binding TotalPages}" />

        <Border
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="1"
            Background="#161B26"
            BorderBrush="#232D42"
            BorderThickness="1,0,0,0"
            Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource NativeBoolToVis}}">

            <uc:BookDetailPanel Visibility="Visible" />
        </Border>
    </Grid>
</Page>