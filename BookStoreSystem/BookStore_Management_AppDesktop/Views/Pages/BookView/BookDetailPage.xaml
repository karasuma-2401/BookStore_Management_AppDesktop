<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.BookDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="BookDetailPage"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" Icon="{ui:SymbolIcon ChevronLeft24}" 
                           Appearance="Transparent" 
                           Foreground="{DynamicResource TextPrimaryBrush}" 
                           Command="{Binding GoBackCommand}"
                           Margin="0,0,15,0" Cursor="Hand" ToolTip="Back to List Books"/>

                <TextBlock Grid.Column="1" Text="BOOK DETAILS" 
                           Style="{StaticResource HeaderTextStyle}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="40" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="12" 
                        Background="{DynamicResource CardBackgroundBrush}" 
                        BorderBrush="{DynamicResource BorderLightBrush}" 
                        BorderThickness="1" 
                        Padding="15" VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="3"/>
                    </Border.Effect>

                    <Image Source="{Binding CurrentBook.ImagePath, TargetNullValue='https://via.placeholder.com/400x600?text=No+Image'}" 
                           Stretch="Uniform" Height="450" />
                </Border>

                <StackPanel Grid.Column="1" Margin="50,0,0,0">

                    <TextBlock Text="{Binding CurrentBook.Title}" 
                               FontSize="36" FontWeight="Black" 
                               Foreground="{DynamicResource TextOnLightBackgroudBrush}" 
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,25">
                        <Run Text="Author: "/>
                        <Run Text="{Binding CurrentBook.AuthorName, TargetNullValue='updating'}" 
                             FontWeight="SemiBold" Foreground="{DynamicResource NavyLightBrush}"/>
                    </TextBlock>

                    <TextBlock Margin="0,0,0,35">
                        <Run Text="{Binding CurrentBook.Price, TargetNullValue='0'}" FontSize="40" FontWeight="Black" Foreground="{DynamicResource SuccessPrimaryBrush}"/>
                        <Run Text=" đ" FontSize="24" FontWeight="Black" Foreground="{DynamicResource NavyLightBrush}"/>
                    </TextBlock>

                    <ui:Button Content="ADD TO CART" Icon="{ui:SymbolIcon Cart24}" 
                               Style="{StaticResource PrimaryActionButtonStyle}"
                               Command="{Binding AddToCartCommand}" 
                               HorizontalAlignment="Left" Padding="50,15"/>

                    <Separator Margin="0,15" Background="{DynamicResource DividerBrush}"/>

                    <TextBlock Text="SUMMARY" 
                               Style="{StaticResource BookTitleTextStyle}" 
                               Margin="0,0,0,15"/>

                    <TextBlock Text="{Binding CurrentBook.Description, TargetNullValue='There are no reviews or descriptions for this book yet.'}" 
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>