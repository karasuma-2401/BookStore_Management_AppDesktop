<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.ShiftSchedulePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
	  xmlns:local="clr-namespace:BookStore_Management_AppDesktop.Converters"
	  mc:Ignorable="d"
	  Background="{DynamicResource ContentBackgroundBrush}"
	  d:DesignHeight="700" d:DesignWidth="1000"
	  Title="Shift Schedule Manager">

	<Page.Resources>
		<local:StatusToColorConverter x:Key="StatusToColorConverter"/>
		<local:StatusToSoftBackgroundConverter x:Key="StatusToSoftBackgroundConverter"/>
		<local:StatusToForegroundConverter x:Key="StatusToForegroundConverter"/>
	</Page.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15,25,20">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0" Text="Shift Schedule Manager" FontSize="26" FontWeight="Black"
						   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

				<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
					<!-- Bộ lọc Trạng thái -->
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
						<TextBlock Text="Status:" Foreground="{DynamicResource SlateBorderBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
						<ComboBox x:Name="StatusFilterComboBox"
								  ItemsSource="{Binding AvailableStatuses}" 
								  SelectedItem="{Binding SelectedStatusFilter}"
								  SelectionChanged="StatusFilterComboBox_SelectionChanged"
								  Width="130" Height="32" Background="{DynamicResource SlateDarkBrush}"
								  Foreground="White" BorderBrush="{DynamicResource SidebarAccentBrush}" BorderThickness="1" Padding="8,4"
								  VerticalAlignment="Center"/>
					</StackPanel>

					<!-- Bộ lọc Ca trực -->
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
						<TextBlock Text="Shift:" Foreground="{DynamicResource SlateBorderBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
						<ComboBox x:Name="ShiftFilterComboBox"
								  ItemsSource="{Binding AvailableShifts}" 
								  SelectedItem="{Binding SelectedShiftFilter}"
								  SelectionChanged="ShiftFilterComboBox_SelectionChanged"
								  Width="130" Height="32" Background="{DynamicResource SlateDarkBrush}"
								  Foreground="White" BorderBrush="{DynamicResource SidebarAccentBrush}" BorderThickness="1" Padding="8,4"
								  VerticalAlignment="Center"/>
					</StackPanel>

					<!-- Nút Xóa bộ lọc -->
					<ui:Button Content="Clear" Icon="{ui:SymbolIcon Delete24}"
							   Command="{Binding ClearFiltersCommand}"
							   Background="Transparent" Foreground="{DynamicResource SidebarAccentBrush}"
							   BorderThickness="1" BorderBrush="{DynamicResource SidebarAccentBrush}"
							   Padding="10,6" FontSize="12" Margin="0,0,20,0" VerticalAlignment="Center"/>

					<!-- Nút Export -->
					<Button Command="{Binding ExportScheduleCommand}"
							Foreground="White" BorderThickness="0"
							Padding="10,6" FontSize="12" Margin="0,0,15,0" VerticalAlignment="Center" Height="32">
						<Button.Style>
							<Style TargetType="Button">
								<Setter Property="Background" Value="#10B981"/>
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="Button">
											<Border x:Name="Border" 
													Background="{TemplateBinding Background}" 
													BorderBrush="{TemplateBinding BorderBrush}" 
													BorderThickness="{TemplateBinding BorderThickness}" 
													CornerRadius="6" 
													SnapsToDevicePixels="True"
													Padding="{TemplateBinding Padding}">
												<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
													<ui:SymbolIcon Symbol="ArrowDownload24" Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
													<ContentPresenter Content="Export" VerticalAlignment="Center"/>
												</StackPanel>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Border" Property="Background" Value="#34D399"/>
												</Trigger>
												<Trigger Property="IsPressed" Value="True">
													<Setter TargetName="Border" Property="Background" Value="#059669"/>
												</Trigger>
												<Trigger Property="IsEnabled" Value="False">
													<Setter TargetName="Border" Property="Opacity" Value="0.5"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</Button.Style>
					</Button>

					<!-- Điều hướng tháng -->
					<TextBlock Text="{Binding CurrentMonthStart, StringFormat='MMMM yyyy'}"
							   Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
					
					<ui:Button Icon="{ui:SymbolIcon ChevronLeft24}"
							   Command="{Binding PreviousMonthCommand}"
							   Background="{DynamicResource SlateDarkBrush}" Foreground="White" BorderBrush="{DynamicResource SidebarAccentBrush}" BorderThickness="1"
							   Padding="8" Margin="0,0,5,0" VerticalAlignment="Center"/>
					
					<ui:Button Icon="{ui:SymbolIcon ChevronRight24}"
							   Command="{Binding NextMonthCommand}"
							   Background="{DynamicResource SlateDarkBrush}" Foreground="White" BorderBrush="{DynamicResource SidebarAccentBrush}" BorderThickness="1"
							   Padding="8" VerticalAlignment="Center"/>
				</StackPanel>
			</Grid>
		</Border>

		<Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" Margin="20" CornerRadius="8" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1">
			<Grid>
				<Border Background="White" Opacity="0.1" CornerRadius="8" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

				<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
					<ProgressBar Width="150" Height="8" IsIndeterminate="True" Foreground="{DynamicResource SidebarAccentBrush}" Margin="0,0,0,15"/>
					<TextBlock Text="{Binding LoadingMessage}" Foreground="{DynamicResource TextBodyBrush}" TextAlignment="Center" FontSize="14"/>
				</StackPanel>

				<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
					<Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<Grid Grid.Row="0" Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<Border Grid.Column="0" Background="#200EA5E9" BorderBrush="#0EA5E9" BorderThickness="1.5" CornerRadius="6" Margin="2,0">
								<TextBlock Text="Monday" FontWeight="Bold" TextAlignment="Center" Foreground="#0EA5E9" Padding="6" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="1" Background="#2010B981" BorderBrush="#10B981" BorderThickness="1.5" CornerRadius="6" Margin="2,0">
								<TextBlock Text="Tuesday" FontWeight="Bold" TextAlignment="Center" Foreground="#10B981" Padding="6" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="2" Background="#208B5CF6" BorderBrush="#8B5CF6" BorderThickness="1.5" CornerRadius="6" Margin="2,0">
								<TextBlock Text="Wednesday" FontWeight="Bold" TextAlignment="Center" Foreground="#8B5CF6" Padding="6" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="3" Background="#20F59E0B" BorderBrush="#F59E0B" BorderThickness="1.5" CornerRadius="6" Margin="2,0">
								<TextBlock Text="Thursday" FontWeight="Bold" TextAlignment="Center" Foreground="#F59E0B" Padding="6" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="4" Background="#2014B8A6" BorderBrush="#14B8A6" BorderThickness="1.5" CornerRadius="6" Margin="2,0">
								<TextBlock Text="Friday" FontWeight="Bold" TextAlignment="Center" Foreground="#14B8A6" Padding="6" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="5" Background="#20F43F5E" BorderBrush="#F43F5E" BorderThickness="1.5" CornerRadius="6" Margin="2,0">
								<TextBlock Text="Saturday" FontWeight="Bold" TextAlignment="Center" Foreground="#F43F5E" Padding="6" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="6" Background="#20EC4899" BorderBrush="#EC4899" BorderThickness="1.5" CornerRadius="6" Margin="2,0">
								<TextBlock Text="Sunday" FontWeight="Bold" TextAlignment="Center" Foreground="#EC4899" Padding="6" HorizontalAlignment="Center"/>
							</Border>
						</Grid>

						<ItemsControl Grid.Row="1" ItemsSource="{Binding ScheduleCells}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid Columns="7" Margin="0"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>

							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" Margin="2" CornerRadius="4" Padding="8" MinHeight="150">
										<Border.InputBindings>
											<MouseBinding MouseAction="LeftDoubleClick"
														  Command="{Binding DataContext.AssignShiftCommand, RelativeSource={RelativeSource AncestorType=Page}}"
														  CommandParameter="{Binding Date}"/>
										</Border.InputBindings>
										<Border.Style>
											<Style TargetType="Border">
												<Setter Property="Background" Value="{DynamicResource LightGrayBgBrush}"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsDummy}" Value="True">
														<Setter Property="Background" Value="Transparent"/>
														<Setter Property="BorderBrush" Value="Transparent"/>
														<Setter Property="Visibility" Value="Hidden"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Border.Style>
										<Grid>
											<Grid.RowDefinitions>
												<RowDefinition Height="Auto"/>
												<RowDefinition Height="*"/>
												<RowDefinition Height="Auto"/>
											</Grid.RowDefinitions>

											<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
												<TextBlock Text="{Binding DayNumber}" FontWeight="Bold" Foreground="{DynamicResource TextOnCardBrush}" Margin="0,0,5,0"/>
												<TextBlock Text="{Binding DayOfWeek}" Foreground="{DynamicResource TextBodyBrush}" FontSize="12"/>
											</StackPanel>

											<ItemsControl Grid.Row="1" ItemsSource="{Binding Shifts}">
												<ItemsControl.ItemTemplate>
													<DataTemplate>
														<Border Background="{Binding Status, Converter={StaticResource StatusToSoftBackgroundConverter}}"
																BorderBrush="{Binding Status, Converter={StaticResource StatusToForegroundConverter}}"
																BorderThickness="1"
																Margin="0,3" CornerRadius="5" Padding="8">
															<Grid>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition Width="*"/>
																	<ColumnDefinition Width="Auto"/>
																</Grid.ColumnDefinitions>

																<StackPanel Grid.Column="0" VerticalAlignment="Center">
																	<TextBlock Text="{Binding FullName}" FontWeight="Bold" Foreground="{Binding Status, Converter={StaticResource StatusToForegroundConverter}}" FontSize="12"/>
																	<TextBlock Text="{Binding ShiftName}" Foreground="{DynamicResource SlateLightBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,1,0,0"/>
																	<TextBlock Text="{Binding WorkTime}" Foreground="{DynamicResource TextBodyBrush}" FontSize="10" Margin="0,1,0,0"/>
																	<TextBlock Text="{Binding Status}" Foreground="{Binding Status, Converter={StaticResource StatusToForegroundConverter}}" FontSize="9.5" FontWeight="SemiBold" FontStyle="Italic" Margin="0,2,0,0"/>
																</StackPanel>

																<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
																	<ui:Button Icon="{ui:SymbolIcon Delete24}"
																			   Background="Transparent" Foreground="{Binding Status, Converter={StaticResource StatusToForegroundConverter}}"
																			   BorderThickness="0" Padding="4"
																			   Margin="4,0,0,0"
																			   Command="{Binding DataContext.DeleteShiftCommand, RelativeSource={RelativeSource AncestorType=Page}}"
																			   CommandParameter="{Binding .}"/>
																</StackPanel>
															</Grid>
														</Border>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>

											<ui:Button Grid.Row="2" Content="+ Add Shift"
                                                       Background="Transparent" Foreground="{DynamicResource SidebarAccentBrush}"
                                                       BorderThickness="1" BorderBrush="{DynamicResource SidebarAccentBrush}"
                                                       Padding="4,2" FontSize="11" Margin="0,4,0,0"
                                                       Command="{Binding DataContext.AssignShiftCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding Date}"/>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Grid>
				</ScrollViewer>
			</Grid>
		</Border>
	</Grid>
</Page>