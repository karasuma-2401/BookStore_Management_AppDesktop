<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.ImportHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="#F8FAFC"
      Title="Import Management">

    <Page.Resources>
        <Style x:Key="GridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="CustomDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CalendarStyle">
                <Setter.Value>
                    <Style TargetType="Calendar">
                        <Setter Property="Background" Value="#1E293B"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#38BDF8"/>
                        <Setter Property="CalendarDayButtonStyle">
                            <Setter.Value>
                                <Style TargetType="CalendarDayButton">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#38BDF8"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#38BDF8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="32,24" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Import History" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Review your import history and transaction details" Margin="0,6,0,0" Foreground="#64748B" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding NavigateToCreateImportCommand}" Height="45" Width="160" Cursor="Hand" BorderThickness="0" Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Border x:Name="Btn" 
                                                Background="#0078D4" 
                                                CornerRadius="8"
                                                Padding="0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Direction="270" Color="#0078D4"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Add24" Foreground="White" Margin="0,0,8,0"/>
                                                <TextBlock Text="Add New Import" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Btn" Property="Background" Value="#0078D4"/>
                                            <Setter TargetName="Btn" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.35" Direction="270" Color="#0078D4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Btn" Property="Background" Value="#0078D4"/>
                                            <Setter TargetName="Btn" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.15" Direction="270" Color="#0078D4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Updated filter section matching AbsenceManagementPage pattern -->
                <Border Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,24,0,0" Margin="0,24,0,0">
                    <Grid VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="From Date" Foreground="#64748B" FontSize="11" Margin="0,0,0,8"/>
                            <DatePicker SelectedDate="{Binding FilterStartDate}" 
                                       Background="White" Foreground="#1E293B" 
                                       BorderBrush="#38BDF8" BorderThickness="1.5" 
                                       Padding="8,6" FontSize="12" Width="220" Height="40"
                                       SelectedDateFormat="Short" Language="vi-VN"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="16,0,0,0">
                            <TextBlock Text="To Date" Foreground="#64748B" FontSize="11" Margin="0,0,0,8"/>
                            <DatePicker SelectedDate="{Binding FilterEndDate}" 
                                       Background="White" Foreground="#1E293B" 
                                       BorderBrush="#38BDF8" BorderThickness="1.5" 
                                       Padding="8,6" FontSize="12" Width="220" Height="40"
                                       SelectedDateFormat="Short" Language="vi-VN"/>
                        </StackPanel>

                        <Button Grid.Column="2" Command="{Binding ApplyDateFilterCommand}" 
                                Background="Transparent" Foreground="White" 
                                Padding="0" Margin="16,0,0,0" Height="40" VerticalAlignment="Bottom"
                                Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Border x:Name="FilterBorder"
                                                Background="#0078D4"
                                                BorderBrush="#0078D4"
                                                BorderThickness="1.5"
                                                CornerRadius="6"
                                                Padding="16,8">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Direction="270" Color="#6366F1"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Search24" Foreground="White" Margin="0,0,8,0"/>
                                                <TextBlock Text="Filter" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="FilterBorder" Property="Background" Value="#5558E3"/>
                                            <Setter TargetName="FilterBorder" Property="BorderBrush" Value="#3D3DB8"/>
                                            <Setter TargetName="FilterBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.35" Direction="270" Color="#6366F1"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="FilterBorder" Property="Background" Value="#4F46E5"/>
                                            <Setter TargetName="FilterBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.15" Direction="270" Color="#6366F1"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="24" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="2" Opacity="0.05" Direction="270"/>
            </Border.Effect>

                <DataGrid x:Name="ImportHistoryGrid" ItemsSource="{Binding ImportHistory}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                      RowHeight="60" ColumnHeaderHeight="55"
                      PreviewMouseLeftButtonDown="ImportHistoryGrid_PreviewMouseLeftButtonDown">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="18,12"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.ItemContainerStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.ItemContainerStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ImportId}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Margin" Value="18,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="EMPLOYEE ID" Binding="{Binding UserId}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DATE" Width="220">
                        <DataGridTextColumn.Binding>
                            <Binding Path="ImportDate" StringFormat="dd MMMM, yyyy HH:mm"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="EMPLOYEE" Binding="{Binding EmployeeName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ITEMS" Binding="{Binding TotalItems}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="TOTAL AMOUNT" Width="200">
                        <DataGridTextColumn.Binding>
                            <Binding Path="TotalAmount" StringFormat="{}{0:N0} VND"/>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextStyle}">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#059669"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>