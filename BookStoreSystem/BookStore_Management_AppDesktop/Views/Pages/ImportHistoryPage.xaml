<Page
    x:Class="BookStore_Management_AppDesktop.Views.Pages.ImportHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Import Management"
    Background="#F8FAFC">

    <Page.Resources>
        <Style x:Key="GridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="CustomDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="40" />
            <Setter Property="Width" Value="180" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="CalendarStyle">
                <Setter.Value>
                    <Style TargetType="Calendar">
                        <Setter Property="Background" Value="#1E293B" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="BorderBrush" Value="#38BDF8" />
                        <Setter Property="CalendarDayButtonStyle">
                            <Setter.Value>
                                <Style TargetType="CalendarDayButton">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#38BDF8" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#38BDF8" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="32,24"
            Background="White"
            BorderBrush="#E2E8F0"
            BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#0F172A"
                            Text="Import History" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="13"
                            Foreground="#64748B"
                            Text="Review your import history and transaction details" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="160"
                            Height="45"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding NavigateToCreateImportCommand}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Border
                                            x:Name="Btn"
                                            Padding="0"
                                            Background="#0078D4"
                                            CornerRadius="8">
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="8"
                                                    Direction="270"
                                                    Opacity="0.2"
                                                    ShadowDepth="2"
                                                    Color="#0078D4" />
                                            </Border.Effect>
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <ui:SymbolIcon
                                                    Margin="0,0,8,0"
                                                    Foreground="White"
                                                    Symbol="Add24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="Add New Import" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Btn" Property="Background" Value="#0078D4" />
                                            <Setter TargetName="Btn" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect
                                                        BlurRadius="12"
                                                        Direction="270"
                                                        Opacity="0.35"
                                                        ShadowDepth="4"
                                                        Color="#0078D4" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Btn" Property="Background" Value="#0078D4" />
                                            <Setter TargetName="Btn" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect
                                                        BlurRadius="6"
                                                        Direction="270"
                                                        Opacity="0.15"
                                                        ShadowDepth="1"
                                                        Color="#0078D4" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!--  Updated filter section matching AbsenceManagementPage pattern  -->
                <Border
                    Margin="0,24,0,0"
                    Padding="0,24,0,0"
                    Background="#F1F5F9"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1">
                    <Grid VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="11"
                                Foreground="#64748B"
                                Text="From Date" />
                            <DatePicker
                                Width="220"
                                Height="40"
                                Padding="8,6"
                                Background="White"
                                BorderBrush="#38BDF8"
                                BorderThickness="1.5"
                                FontSize="12"
                                Foreground="#1E293B"
                                Language="vi-VN"
                                SelectedDate="{Binding FilterStartDate}"
                                SelectedDateFormat="Short" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Margin="16,0,0,0"
                            Orientation="Vertical">
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="11"
                                Foreground="#64748B"
                                Text="To Date" />
                            <DatePicker
                                Width="220"
                                Height="40"
                                Padding="8,6"
                                Background="White"
                                BorderBrush="#38BDF8"
                                BorderThickness="1.5"
                                FontSize="12"
                                Foreground="#1E293B"
                                Language="vi-VN"
                                SelectedDate="{Binding FilterEndDate}"
                                SelectedDateFormat="Short" />
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            Height="40"
                            Margin="16,0,0,0"
                            Padding="0"
                            VerticalAlignment="Bottom"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ApplyDateFilterCommand}"
                            Cursor="Hand"
                            Foreground="White">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Border
                                            x:Name="FilterBorder"
                                            Padding="16,8"
                                            Background="#0078D4"
                                            BorderBrush="#0078D4"
                                            BorderThickness="1.5"
                                            CornerRadius="6">
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="8"
                                                    Direction="270"
                                                    Opacity="0.2"
                                                    ShadowDepth="2"
                                                    Color="#0078D4" />
                                            </Border.Effect>
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <ui:SymbolIcon
                                                    Margin="0,0,8,0"
                                                    Foreground="White"
                                                    Symbol="Search24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="Filter" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="FilterBorder" Property="Background" Value="#0078D4" />
                                            <Setter TargetName="FilterBorder" Property="BorderBrush" Value="#0078D4" />
                                            <Setter TargetName="FilterBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect
                                                        BlurRadius="12"
                                                        Direction="270"
                                                        Opacity="0.35"
                                                        ShadowDepth="4"
                                                        Color="#0078D4" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="FilterBorder" Property="Background" Value="#0078D4" />
                                            <Setter TargetName="FilterBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect
                                                        BlurRadius="6"
                                                        Direction="270"
                                                        Opacity="0.15"
                                                        ShadowDepth="1"
                                                        Color="#0078D4" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Margin="24"
            Background="White"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="25"
                    Direction="270"
                    Opacity="0.05"
                    ShadowDepth="2" />
            </Border.Effect>

            <DataGrid
                x:Name="ImportHistoryGrid"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                ColumnHeaderHeight="55"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#F1F5F9"
                IsReadOnly="True"
                ItemsSource="{Binding ImportHistory}"
                PreviewMouseLeftButtonDown="ImportHistoryGrid_PreviewMouseLeftButtonDown"
                RowHeight="60">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="#64748B" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Padding" Value="18,12" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.ItemContainerStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Background" Value="White" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.ItemContainerStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding ImportId}"
                        Header="ID">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource GridTextStyle}" TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Margin" Value="18,0,0,0" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding UserId}"
                        Header="EMPLOYEE ID">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource GridTextStyle}" TargetType="TextBlock" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="220" Header="DATE">
                        <DataGridTextColumn.Binding>
                            <Binding Path="ImportDate" StringFormat="dd MMMM, yyyy HH:mm" />
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource GridTextStyle}" TargetType="TextBlock" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding EmployeeName}"
                        Header="EMPLOYEE">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource GridTextStyle}" TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding TotalItems}"
                        Header="ITEMS">
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource GridTextStyle}" TargetType="TextBlock" />
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="200" Header="TOTAL AMOUNT">
                        <DataGridTextColumn.Binding>
                            <Binding Path="TotalAmount" StringFormat="{}{0:N0} VND" />
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style BasedOn="{StaticResource GridTextStyle}" TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="#059669" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>