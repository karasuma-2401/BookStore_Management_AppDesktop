<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="BookPage"
      Background="{DynamicResource ContentBackgroundBrush}"
      TextOptions.TextFormattingMode="Display"
      UseLayoutRounding="True"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Books" FontSize="28" 
                           FontWeight="Black" 
                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:TextBox PlaceholderText="Search books..." 
                                Icon="{ui:SymbolIcon Search24}" Width="300" Margin="0,0,15,0" 
                                VerticalAlignment="Center" Cursor="IBeam"
                                Background="{DynamicResource NavyPrimaryBrush}" 
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource NavyLightBrush}" TextChanged="TextBox_TextChanged"/>

                    <ui:Button Icon="{ui:SymbolIcon Filter24}" Appearance="Secondary" 
                               Background="{DynamicResource NavyLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0"
                               Margin="0,0,10,0" ToolTip="Filter Books" Cursor="Hand"/>

                    <ui:Button Icon="{ui:SymbolIcon Cart24}" Appearance="Primary" 
                               Background="{DynamicResource NavyAccentBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold"
                               ToolTip="View Shopping Cart" Padding="12,6" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
        <ListView x:Name="BooksListView"
                  Grid.Row="1"
                  ItemsSource="{Binding Books}" 
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Padding="10,10,10,20" d:ItemsSource="{d:SampleData ItemCount=5}">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="210" 
                            Background="{DynamicResource CardBackgroundBrush}" 
                            Margin="15"
                            BorderBrush="#E2E8F0" 
                            BorderThickness="1" 
                            CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="3"/>
                        </Border.Effect>

                        <StackPanel Margin="12">
                            <Border CornerRadius="8" ClipToBounds="True" Margin="0,0,0,12" Background="{DynamicResource ContentBackgroundBrush}">

                                <Image Height="250" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="LowQuality"
                                       RenderOptions.EdgeMode="Aliased"
                                       Source="{Binding ImagePath, IsAsync=True, 
                                    TargetNullValue='https://via.placeholder.com/180x250?text=No+Image', 
                                    FallbackValue='https://via.placeholder.com/180x250?text=No+Image'}">
                                </Image>

                            </Border>

                            <TextBlock Text="{Binding Title}" 
                                       FontWeight="Bold" 
                                       FontSize="16" 
                                       Foreground="#1E293B"
                                       TextWrapping="Wrap" 
                                       Height="44" 
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,4"/>

                            <TextBlock Text="{Binding AuthorId}" 
                                       Foreground="#64748B" 
                                       FontSize="13" 
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding Price, TargetNullValue='150.000đ'}" 
                                       FontWeight="Black" 
                                       FontSize="18" 
                                       Foreground="{DynamicResource ErrorPrimaryBrush}" 
                                       Margin="0,0,0,12"/>

                            <ui:Button Content="Add to Cart"
                                       Icon="{ui:SymbolIcon Cart24}"
                                       Appearance="Primary"
                                       Background="{DynamicResource NavyAccentBrush}" Foreground="White" BorderThickness="0"
                                       HorizontalAlignment="Stretch"
                                       Cursor="Hand"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>