<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.KioskCheckInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:BookStore_Management_AppDesktop.Views.Pages"
      mc:Ignorable="d" 
      Background="{DynamicResource ContentBackgroundBrush}"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Check-in Kiosk">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Check-in Kiosk" FontSize="26" FontWeight="Black"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Quick attendance registration for store employees" FontSize="13" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Live Digital Clock -->
                <Border Grid.Column="1" Background="#0F172A" CornerRadius="8" Padding="15,8" BorderBrush="#0284C7" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Clock24" Foreground="#38BDF8" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentTimeText}" Foreground="White" FontSize="16" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0: Check-in Input Card -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="12" BorderBrush="#1E293B" BorderThickness="1" Padding="30" Margin="0,0,15,0" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Kiosk Logo / Icon -->
                        <Border Width="64" Height="64" Background="#075985" CornerRadius="32" Margin="0,0,0,20" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="PersonClock24" Foreground="#38BDF8" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="ATTENDANCE STATION" Foreground="#38BDF8" FontSize="12" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Enter Your Employee ID" Foreground="White" FontSize="20" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,25"/>

                        <!-- Input Field -->
                        <TextBlock Text="Employee ID:" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        
                        <Grid>
                            <TextBox x:Name="EmployeeIdInput"
                                     Text="{Binding EmployeeIdText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="22" FontWeight="Bold" Padding="12,10"
                                     Background="#0F172A" Foreground="White"
                                     BorderBrush="#334155" BorderThickness="2"
                                     SelectionBrush="#0284C7"
                                     HorizontalContentAlignment="Center"
                                     KeyDown="EmployeeIdInput_KeyDown"
                                     MaxLength="10"
                                     Height="54"/>
                            
                            <Border CornerRadius="4" BorderThickness="2" BorderBrush="#0284C7" 
                                    Visibility="{Binding ElementName=EmployeeIdInput, Path=IsFocused, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsHitTestVisible="False"/>
                        </Grid>

                        <!-- Error Message inside Kiosk Panel -->
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,15,0,0"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Submit Button -->
                        <ui:Button Command="{Binding CheckInCommand}"
                                   Background="#0284C7" Foreground="White"
                                   BorderThickness="0" CornerRadius="8"
                                   Height="50" Margin="0,25,0,0"
                                   HorizontalAlignment="Stretch">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ui:SymbolIcon Symbol="Checkmark24" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="CONFIRM CHECK-IN" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:ProgressRing Width="24" Height="24" IsIndeterminate="True" Foreground="White"
                                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </ui:Button>

                        <!-- Instructions -->
                        <Border Background="#0F172A" CornerRadius="8" Padding="12" Margin="0,30,0,0">
                            <StackPanel>
                                <TextBlock Text="Instructions:" Foreground="#38BDF8" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="1. Arrive within 30 minutes before your shift." Foreground="#94A3B8" FontSize="12" Margin="0,2"/>
                                <TextBlock Text="2. Enter your Employee ID and press Enter or click button." Foreground="#94A3B8" FontSize="12" Margin="0,2"/>
                                <TextBlock Text="3. On-time window closes 15 minutes after shift start." Foreground="#94A3B8" FontSize="12" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Column 1: Beautiful Slide Feedback Panel -->
                <Grid Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Top">
                    <!-- Default state (waiting) -->
                    <Border Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="12" BorderBrush="#1E293B" BorderThickness="1" Padding="40" MinHeight="350"
                            Visibility="{Binding ShowFeedback, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Key24" Foreground="#475569" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="Awaiting Input" Foreground="#64748B" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
                            <TextBlock Text="Please enter your Employee ID on the left to verify your shift." Foreground="#475569" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Success / Shift Checked feedback state -->
                    <Border CornerRadius="12" BorderThickness="1.5" MinHeight="350" Padding="30"
                            Visibility="{Binding ShowFeedback, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SuccessMessage, Converter={StaticResource BoolToVisibilityConverter}}" Value="True">
                                        <Setter Property="Background" Value="#064E3B" />
                                        <Setter Property="BorderBrush" Value="#059669" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SuccessMessage, Converter={StaticResource BoolToVisibilityConverter}}" Value="False">
                                        <Setter Property="Background" Value="#7F1D1D" />
                                        <Setter Property="BorderBrush" Value="#DC2626" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Grid>
                            <ui:Button Command="{Binding ClearFeedbackCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Padding="5">
                                <ui:SymbolIcon Symbol="Dismiss24" Foreground="White" FontSize="20"/>
                            </ui:Button>

                            <StackPanel VerticalAlignment="Center" Margin="0,10,0,0">
                                <!-- Status Icon -->
                                <Border Width="72" Height="72" CornerRadius="36" Margin="0,0,0,15" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SuccessMessage, Converter={StaticResource BoolToVisibilityConverter}}" Value="True">
                                                    <Setter Property="Background" Value="#047857"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SuccessMessage, Converter={StaticResource BoolToVisibilityConverter}}" Value="False">
                                                    <Setter Property="Background" Value="#B91C1C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <Grid>
                                        <!-- Success Icon -->
                                        <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="White" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding SuccessMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <!-- Warning/Error Icon -->
                                        <ui:SymbolIcon Symbol="Dismiss24" Foreground="White" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding SuccessMessage, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}"/>
                                    </Grid>
                                </Border>

                                <!-- Header Status Title -->
                                <TextBlock Text="{Binding SuccessMessage}" Foreground="White" FontSize="22" FontWeight="Black" TextAlignment="Center" TextWrapping="Wrap" Margin="0,5,0,20"/>

                                <!-- Detail List -->
                                <Border Background="#0F172A" CornerRadius="10" BorderBrush="#334155" BorderThickness="1" Padding="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Employee Name -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Employee:" Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold" Padding="0,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EmployeeName}" Foreground="White" FontSize="15" FontWeight="Bold" Padding="15,5,0,5" TextAlignment="Right"/>

                                        <!-- Shift Name -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Shift Name:" Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold" Padding="0,5"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ShiftName}" Foreground="#38BDF8" FontSize="15" FontWeight="Bold" Padding="15,5,0,5" TextAlignment="Right"/>

                                        <!-- Shift Time -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Shift Time:" Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold" Padding="0,5"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WorkTime}" Foreground="White" FontSize="14" Padding="15,5,0,5" TextAlignment="Right"/>

                                        <!-- Check-in Time -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Checked In At:" Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold" Padding="0,5"
                                                   Visibility="{Binding CheckInTimeText, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CheckInTimeText}" Foreground="#10B981" FontSize="14" FontWeight="SemiBold" Padding="15,5,0,5" TextAlignment="Right"
                                                   Visibility="{Binding CheckInTimeText, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <!-- Attendance Status Tag -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Status:" Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold" Padding="0,5"
                                                   Visibility="{Binding Status, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        
                                        <Border Grid.Row="4" Grid.Column="1" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,5,0,5"
                                                Visibility="{Binding Status, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Present">
                                                            <Setter Property="Background" Value="#064E3B"/>
                                                            <Setter Property="BorderBrush" Value="#059669"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Late">
                                                            <Setter Property="Background" Value="#78350F"/>
                                                            <Setter Property="BorderBrush" Value="#D97706"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Scheduled">
                                                            <Setter Property="Background" Value="#1E293B"/>
                                                            <Setter Property="BorderBrush" Value="#64748B"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
