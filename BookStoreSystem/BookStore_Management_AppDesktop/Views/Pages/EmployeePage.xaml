<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.EmployeePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:BookStore_Management_AppDesktop.Converters"
      mc:Ignorable="d" 
      Background="{DynamicResource ContentBackgroundBrush}" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="EmployeePage">

    <Page.Resources>
        <converters:EmployeeStatusConverter x:Key="EmployeeStatusConverter"/>
        <converters:EmployeeStatusColorConverter x:Key="EmployeeStatusColorConverter"/>
        <Style x:Key="HoverRiseCardStyle" TargetType="Border">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0" Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-5" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Gộp Row 0 và Row 1 cũ làm một để loại bỏ đường kẻ phân tách -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bọc toàn bộ phần Header và nút Add vào chung 1 Border duy nhất -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15,25,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Vùng Header cũ giữ nguyên -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Employee Management" FontSize="26" FontWeight="Black" 
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <ui:TextBox PlaceholderText="Search employees..." 
                                Icon="{ui:SymbolIcon Search24}" Width="250" Margin="0,0,15,0" 
                                VerticalAlignment="Center" Cursor="Pen"
                                Background="Transparent" Foreground="White"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <ui:Button x:Name="FilterButton"
                                Icon="{ui:SymbolIcon Filter24}" 
                                Appearance="Secondary" 
                                BorderBrush="#38BDF8" BorderThickness="1.5"
                                Margin="0,0,10,0" 
                                Click="FilterButton_Click">
                        <ui:Button.ContextMenu>
                            <ContextMenu x:Name="FilterMenu">
                                <ContextMenu.Resources>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="MenuItem">
                                                    <Grid Background="Transparent">
                                                        <Border x:Name="ActiveIndicator" 
                                                                HorizontalAlignment="Left" 
                                                                Width="4" 
                                                                Height="18" 
                                                                Margin="2,0,0,0"
                                                                CornerRadius="2"
                                                                Background="{DynamicResource SidebarAccentBrush}" 
                                                                Visibility="Collapsed"/>

                                                        <ContentPresenter x:Name="HeaderHost" 
                                                                          ContentSource="Header" 
                                                                          Margin="15,8,15,8"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SidebarAccentBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Full Name" 
                                          IsChecked="{Binding IsFullNameSelected, Mode=OneWay}"
                                          Command="{Binding ChangeFilterCommand}" 
                                          CommandParameter="Full Name"
                                          Icon="{ui:SymbolIcon Symbol=Person24}"/>

                                <MenuItem Header="Salary" 
                                          IsChecked="{Binding IsSalarySelected, Mode=OneWay}"
                                          Command="{Binding ChangeFilterCommand}" 
                                          CommandParameter="Salary"
                                          Icon="{ui:SymbolIcon Symbol=Money24}"/>

                                <MenuItem Header="Address" 
                                          IsChecked="{Binding IsAddressSelected, Mode=OneWay}"
                                          Command="{Binding ChangeFilterCommand}" 
                                          CommandParameter="Address"
                                          Icon="{ui:SymbolIcon Symbol=Location24}"/>
                            </ContextMenu>
                        </ui:Button.ContextMenu>
                    </ui:Button>
                </StackPanel>

                <ui:Button Grid.Row="1" Grid.Column="0" Content="Add New Employee"
                           Icon="{ui:SymbolIcon Add24}" Height="40"
                           Style="{StaticResource PremiumSolidButtonStyle}"
                           HorizontalAlignment="Left" Margin="0,15,0,0"
                           Command="{Binding OpenAddEmployeeWindowCommand}"/>
            </Grid>
        </Border>

        <!-- Overview statistics cards section -->
        <Grid Grid.Row="1" Margin="20,15,20,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Employees -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,10,5" Style="{StaticResource HoverRiseCardStyle}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource AccentBlueBrush}" CornerRadius="8,0,0,8"/>
                    <Grid Grid.Column="1" Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Total Employees" Foreground="#64748B" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalAllEmployees}" Foreground="#1E293B" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <ui:SymbolIcon Grid.Column="1" Symbol="People24" FontSize="28" Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 2: Active Employees -->
            <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="10,0,10,5" Style="{StaticResource HoverRiseCardStyle}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource SuccessPrimaryBrush}" CornerRadius="8,0,0,8"/>
                    <Grid Grid.Column="1" Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Active Employees" Foreground="#64748B" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalActiveEmployees}" Foreground="{DynamicResource SuccessPrimaryBrush}" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <ui:SymbolIcon Grid.Column="1" Symbol="CheckmarkCircle24" FontSize="28" Foreground="{DynamicResource SuccessPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 3: Resigned Employees -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="10,0,0,5" Style="{StaticResource HoverRiseCardStyle}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource ErrorPrimaryBrush}" CornerRadius="8,0,0,8"/>
                    <Grid Grid.Column="1" Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Resigned Employees" Foreground="#64748B" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalResignedEmployees}" Foreground="{DynamicResource ErrorPrimaryBrush}" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <ui:SymbolIcon Grid.Column="1" Symbol="Dismiss24" FontSize="28" Foreground="{DynamicResource ErrorPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Phần DataGrid chuyển lên Grid.Row="2" -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" Margin="20" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="EmployeeDataGrid" 
                          ItemsSource="{Binding Employees}" 
                          AutoGenerateColumns="False" 
                          Grid.Row="0"
                          CanUserAddRows="False" 
                          IsReadOnly="True" 
                          RowHeight="70" 
                          HeadersVisibility="Column"
                          Foreground="#1E293B" 
                          Background="Transparent" 
                          CanUserResizeColumns="False" 
                          CanUserReorderColumns="False" 
                          RowBackground="{DynamicResource CardBackgroundBrush}"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                          HorizontalGridLinesBrush="#E2E8F0" 
                          VerticalGridLinesBrush="Transparent"
                          FontSize="15" 
                          Cursor="Hand"
                          EnableRowVirtualization="True"
                          PreviewMouseLeftButtonDown="EmployeeDataGrid_PreviewMouseLeftButtonDown">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Padding" Value="12,12"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Margin" Value="12,0"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ContentBackgroundBrush}"/>
                            <Setter Property="Height" Value="60"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource SidebarAccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="1.5"/>
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User ID" Binding="{Binding UserId}" Width="1.2*" MinWidth="90">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Emp ID" Binding="{Binding EmployeeId}" Width="1.2*" MinWidth="90">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="0.8*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="1.5*"/>

                        <DataGridTextColumn Header="Salary" Binding="{Binding Salary, StringFormat={}{0:N0} VNĐ}" Width="1.8*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="2.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip" Value="{Binding Address}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Status" Width="1.2*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusToSoftBackgroundConverter}}"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource EmployeeStatusConverter}}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToForegroundConverter}}"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Margin="0"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Actions" Width="1.5*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Edit Button -->
                                        <Button Style="{StaticResource PremiumActionIconButtonStyle}"
                                                Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource SuccessPrimaryBrush}"
                                                BorderBrush="{DynamicResource SuccessPrimaryBrush}" BorderThickness="1.5"
                                                ToolTip="Edit"
                                                Margin="0,0,6,0">
                                            <ui:SymbolIcon Symbol="Edit24" FontSize="18" Foreground="{DynamicResource SuccessPrimaryBrush}"/>
                                        </Button>

                                        <!-- Change Password Button -->
                                        <Button Style="{StaticResource PremiumActionIconButtonStyle}"
                                                Command="{Binding DataContext.ChangePasswordCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource AccentBlueBrush}"
                                                BorderBrush="{DynamicResource AccentBlueBrush}" BorderThickness="1.5"
                                                ToolTip="Change Password"
                                                Margin="0,0,6,0">
                                            <ui:SymbolIcon Symbol="Password24" FontSize="18" Foreground="{DynamicResource AccentBlueBrush}"/>
                                        </Button>

                                        <!-- Delete Button -->
                                        <Button Style="{StaticResource PremiumActionIconButtonStyle}"
                                                Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource ErrorPrimaryBrush}"
                                                BorderBrush="{DynamicResource ErrorPrimaryBrush}" BorderThickness="1.5"
                                                ToolTip="Delete">
                                            <ui:SymbolIcon Symbol="Delete24" FontSize="18" Foreground="{DynamicResource ErrorPrimaryBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Row="1" Margin="0 30 20 20" >
                    <TextBlock Text="Lines per page" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,15,0"/>

                    <Grid VerticalAlignment="Center" Margin="0,0,40,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PageSize}" VerticalAlignment="Center" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,5,0"/>
                            <ui:SymbolIcon Symbol="ChevronDown24" Filled="False" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding PageSizeOptions}" 
                                  SelectedItem="{Binding PageSize}" 
                                  Width="50" Height="25" Background="Transparent" BorderThickness="0" Opacity="0.01" Cursor="Hand"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                        <TextBlock Text="{Binding CurrentPageStart}" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="13"/>
                        <TextBlock Text="-" Foreground="{DynamicResource TextOnLightBackgroudBrush}" Margin="2,0"/>
                        <TextBlock Text="{Binding CurrentPageEnd}" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="13"/>
                        <TextBlock Text="of" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="8,0"/>
                        <TextBlock Text="{Binding TotalEmployees}" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon Symbol=ChevronLeft24}" Appearance="Transparent" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" Padding="5" 
                                   BorderBrush="#38BDF8" BorderThickness="1.5" Margin="0,0,5,0"
                                   Command="{Binding PreviousPageCommand}"/>
                        <ui:Button Icon="{ui:SymbolIcon Symbol=ChevronRight24}" Appearance="Transparent" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" Padding="5" 
                                   BorderBrush="#38BDF8" BorderThickness="1.5"
                                   Command="{Binding NextPageCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>