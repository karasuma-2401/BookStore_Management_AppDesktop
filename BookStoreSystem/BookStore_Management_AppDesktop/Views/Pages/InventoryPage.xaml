<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="InventoryPage" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Inventory Management" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <ui:Button Content="Add New Book" Click="btnAddBook_Click"  Icon="{ui:SymbolIcon Add24}" Appearance="Primary" Margin="20,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Books}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" RowHeight="60" HeadersVisibility="Column"
                  Foreground="Black"
                  Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1" FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="60"/>

                <DataGridTemplateColumn Header="Cover" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImagePath, IsAsync=True, TargetNullValue='https://link-anh-mac-dinh.jpg', FallbackValue='https://link-anh-mac-dinh.jpg'}" 
                   Width="45" Height="60" Stretch="Uniform" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Author ID" Binding="{Binding AuthorId}" Width="100"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding Quantity}" Width="100"/>

                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                <ui:Button Icon="{ui:SymbolIcon Edit24}" 
                           Appearance="Primary" 
                           Margin="0,0,10,0"
                           Command="{Binding DataContext.EditBookCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                           CommandParameter="{Binding}" />

                                <ui:Button Icon="{ui:SymbolIcon Delete24}" 
                           Appearance="Danger" 
                           Command="{Binding DataContext.DeleteBookCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                           CommandParameter="{Binding}" />

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>