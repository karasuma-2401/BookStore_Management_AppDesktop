<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:uc="clr-namespace:BookStore_Management_AppDesktop.Views.UserControls"
      Title="InventoryPage" 
      Background="{DynamicResource ContentBackgroundBrush}" 
      TextOptions.TextFormattingMode="Display"
      UseLayoutRounding="True"
      Loaded="Page_Loaded"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Inventory Management" 
                           Style="{StaticResource HeaderTextStyle}" />

                <ComboBox Grid.Column="1" 
                          Width="180" Margin="0,0,15,0" VerticalAlignment="Center"
                          SelectedValuePath="Tag"
                          SelectedValue="{Binding SelectedSort}">
                    <ComboBoxItem Content="Price: High to Low" Tag="price_desc" IsSelected="True"/>
                    <ComboBoxItem Content="Price: Low to High" Tag="price_asc"/>
                    <ComboBoxItem Content="Title: A - Z" Tag="title_asc"/>
                </ComboBox>

                <ui:TextBox Grid.Column="2" 
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Search title, ID, or stock.." 
                            Icon="{ui:SymbolIcon Search24}"
                            Width="250" 
                            VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,15,20,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <uc:StatCardControl 
                    Width="240" Height="95" Margin="0,0,20,0"
                    Title="Total Books" 
                    Value="{Binding TotalBooksCount}" 
                    CardBackground="#EBF5FF"
                    IconColor="#3498DB"
                    IconData="M18,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V4A2,2 0 0,0 18,2M18,20H6V4H8V12L10.5,9.5L13,12V4H18V20Z" />

                <uc:StatCardControl 
                    Width="240" Height="95"
                    Title="Low Stock" 
                    Value="{Binding LowStockBooksCount}" 
                    CardBackground="#FFF4E6"
                    IconColor="#F39C12"
                    IconData="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <ui:Button Command="{Binding ExportInventoryCommand}"
                           Appearance="Secondary"
                           Height="50"
                           Padding="18,0"
                           Margin="0,0,12,0"
                           Background="{DynamicResource CardBackgroundBrush}"
                           BorderBrush="#E2E8F0"
                           BorderThickness="1"
                           Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="20" Margin="0,0,10,0" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        <TextBlock Text="Export to Excel" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextOnLightBackgroudBrush}"/>
                    </StackPanel>
                </ui:Button>

                <ui:Button Command="{Binding OpenAuthorManagementCommand}"
                           Appearance="Secondary"
                           Height="50"
                           Padding="18,0"
                           Margin="0,0,12,0"
                           Background="{DynamicResource CardBackgroundBrush}"
                           BorderBrush="#E2E8F0"
                           BorderThickness="1"
                           Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="People24" FontSize="20" Margin="0,0,10,0" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        <TextBlock Text="Authors" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextOnLightBackgroudBrush}"/>
                    </StackPanel>
                </ui:Button>

                <ui:Button Command="{Binding OpenCategoryManagementCommand}"
                           Appearance="Secondary"
                           Height="50"
                           Padding="18,0"
                           Background="{DynamicResource CardBackgroundBrush}"
                           BorderBrush="#E2E8F0"
                           BorderThickness="1"
                           Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Grid24" FontSize="20" Margin="0,0,10,0" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                        <TextBlock Text="Categories" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextOnLightBackgroudBrush}"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" Margin="20,15,20,10" CornerRadius="8">
            <DataGrid ItemsSource="{Binding Books}" AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      IsReadOnly="True" 
                      CanUserSortColumns="False" 
                      RowHeight="65" HeadersVisibility="Column"
                      Foreground="{DynamicResource TextOnLightBackgroudBrush}" 
                      Background="Transparent" 
                      CanUserResizeColumns="False" 
                      RowBackground="{DynamicResource CardBackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                      BorderBrush="#E2E8F0" BorderThickness="1" 
                      HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="Transparent"
                      FontSize="{StaticResource FontSizeBody}" Cursor="Hand"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,0,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Book Details" Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="5,0">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextOnLightBackgroudBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding DisplayAuthorNames}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Category" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding CategoryNames}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F1F5F9" CornerRadius="4" Padding="8,3" Margin="0,2,6,2">
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#475569" FontWeight="Medium"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='{}{0:#,0} đ'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextOnLightBackgroudBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Stock Status" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                    <ui:SymbolIcon x:Name="StockIcon" Symbol="CheckmarkCircle24" FontSize="18" Margin="0,0,8,0" Foreground="{DynamicResource SuccessPrimaryBrush}"/>
                                    <TextBlock x:Name="StockText" Text="{Binding Quantity, StringFormat='{}{0} In Stock'}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SuccessPrimaryBrush}"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Quantity}" Value="0">
                                        <Setter TargetName="StockIcon" Property="Symbol" Value="DismissCircle24"/>
                                        <Setter TargetName="StockIcon" Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}"/>
                                        <Setter TargetName="StockText" Property="Text" Value="Out of Stock"/>
                                        <Setter TargetName="StockText" Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Quantity}" Value="1">
                                        <Setter TargetName="StockIcon" Property="Symbol" Value="Warning24"/>
                                        <Setter TargetName="StockIcon" Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}"/>
                                        <Setter TargetName="StockText" Property="Text" Value="Low Stock (1 left)"/>
                                        <Setter TargetName="StockText" Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Quantity}" Value="2">
                                        <Setter TargetName="StockIcon" Property="Symbol" Value="Warning24"/>
                                        <Setter TargetName="StockIcon" Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}"/>
                                        <Setter TargetName="StockText" Property="Text" Value="Low Stock (2 left)"/>
                                        <Setter TargetName="StockText" Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Action" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.EditBookCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ToolTip="Edit Book"
                                        Width="75" Height="36">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" 
                                                    Background="White" 
                                                    BorderBrush="{DynamicResource SuccessPrimaryBrush}" 
                                                    BorderThickness="1.5" 
                                                    CornerRadius="8" 
                                                    SnapsToDevicePixels="True">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Edit24" FontSize="16" Foreground="{DynamicResource SuccessPrimaryBrush}" Margin="0,0,5,0"/>
                                                    <TextBlock Text="Edit" Foreground="{DynamicResource SuccessPrimaryBrush}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#F0FDF4"/>
                                                    <Setter TargetName="BtnBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#DCFCE7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <uc:PaginationControl Grid.Row="3" Margin="20,0,20,20"
                               CurrentPage="{Binding CurrentPage}"
                               TotalPages="{Binding TotalPages}"
                               TotalItems="{Binding TotalItems}"
                               ItemName="items"
                               PreviousPageCommand="{Binding PreviousPageCommand}"
                               NextPageCommand="{Binding NextPageCommand}"/>
    </Grid>
</Page>