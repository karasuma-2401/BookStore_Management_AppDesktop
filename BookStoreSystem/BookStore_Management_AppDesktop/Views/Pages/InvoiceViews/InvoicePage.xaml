<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.InvoiceViews.InvoicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Background="{DynamicResource ContentBackgroundBrush}"
      d:DesignHeight="700"
      d:DesignWidth="1000"
      Title="InvoicePage">

    <Page.Resources>
        <Style x:Key="FilterMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0,25,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Rectangle x:Name="ActiveIndicator" 
                                           Width="3.5" 
                                           HorizontalAlignment="Left" 
                                           Fill="#00A3FF" 
                                           Visibility="Collapsed"
                                           Margin="1,6,0,6"/>

                                <ContentPresenter ContentSource="Header" 
                                                  Margin="{TemplateBinding Padding}" 
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#00A3FF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D3748" TargetName="MenuBorder"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="15,0,25,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ActionBorder" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="IconPresenter" 
                                                  ContentSource="Icon" 
                                                  Width="18" 
                                                  Height="18" 
                                                  Grid.Column="0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                                <ContentPresenter ContentSource="Header" 
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D3748" TargetName="ActionBorder"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                Padding="25,15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Invoice Management"
                           FontSize="26"
                           FontWeight="Black"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:TextBox 
                                PlaceholderText="Search invoices..."
                                Width="250"
                                Margin="0,0,15,0"
                                VerticalAlignment="Center"
                                Padding="12,8"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <ui:Button x:Name="FilterButton"
                               Icon="{ui:SymbolIcon Filter24}" 
                               Appearance="Secondary" 
                               BorderBrush="#38BDF8" BorderThickness="1.5"
                               Margin="0,0,10,0" 
                               Click="FilterButton_Click">
                        <ui:Button.ContextMenu>
                            <ContextMenu x:Name="FilterMenu" 
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Background="#1E2530" BorderThickness="0">
                                <MenuItem Header="Items"
                                          Style="{StaticResource FilterMenuItemStyle}"
                                          IsChecked="{Binding IsItemsSelected}"
                                          Command="{Binding ChangeFilterCommand}"
                                          CommandParameter="Items"/>
                                <MenuItem Header="Invoice Date"
                                          Style="{StaticResource FilterMenuItemStyle}"
                                          IsChecked="{Binding IsInvoiceDateSelected}"
                                          Command="{Binding ChangeFilterCommand}"
                                          CommandParameter="Invoice Date"/>
                            </ContextMenu>
                        </ui:Button.ContextMenu>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Overview statistics cards section -->
        <Grid Grid.Row="1" Margin="20,15,20,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Invoices -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,10,5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource AccentBlueBrush}" CornerRadius="8,0,0,8"/>
                    <Grid Grid.Column="1" Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Total Invoices" Foreground="#64748B" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalAllInvoices}" Foreground="#1E293B" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <ui:SymbolIcon Grid.Column="1" Symbol="Receipt24" FontSize="28" Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 2: Total Revenue -->
            <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="10,0,10,5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource SuccessPrimaryBrush}" CornerRadius="8,0,0,8"/>
                    <Grid Grid.Column="1" Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Total Revenue" Foreground="#64748B" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalRevenue, StringFormat='{}{0:N0} VNĐ'}" Foreground="{DynamicResource SuccessPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                        <ui:SymbolIcon Grid.Column="1" Symbol="Money24" FontSize="28" Foreground="{DynamicResource SuccessPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Card 3: Canceled Invoices -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="10,0,0,5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource ErrorPrimaryBrush}" CornerRadius="8,0,0,8"/>
                    <Grid Grid.Column="1" Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Canceled Invoices" Foreground="#64748B" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding CanceledInvoicesCount}" Foreground="{DynamicResource ErrorPrimaryBrush}" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <ui:SymbolIcon Grid.Column="1" Symbol="Dismiss24" FontSize="28" Foreground="{DynamicResource ErrorPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundBrush}"
                Margin="20"
                CornerRadius="8"
                BorderBrush="#E2E8F0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="InvoiceDataGrid"
                          ItemsSource="{Binding Invoices}"
                          AutoGenerateColumns="False"
                          Grid.Row="0"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="70"
                          HeadersVisibility="Column"
                          Foreground="#1E293B"
                          Background="Transparent"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False"
                          RowBackground="{DynamicResource CardBackgroundBrush}"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                          HorizontalGridLinesBrush="#E2E8F0"
                          VerticalGridLinesBrush="Transparent"
                          FontSize="15"
                          Cursor="Hand"
                          EnableRowVirtualization="True"
                          PreviewMouseLeftButtonDown="InvoiceDataGrid_PreviewMouseLeftButtonDown">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Padding" Value="12,12"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Margin" Value="12,0"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ContentBackgroundBrush}"/>
                            <Setter Property="Height" Value="60"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource SidebarAccentBrush}"/>
                                    <Setter Property="BorderThickness" Value="1.5"/>
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Invoice ID" Binding="{Binding InvoiceId}" Width="1.3*" MinWidth="110">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Creator" Width="2*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{Binding StaffRole, Converter={StaticResource RoleToColorConverter}}"
                                            BorderThickness="1.5"
                                            Background="{Binding StaffRole, Converter={StaticResource RoleToSoftBackgroundConverter}}"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StaffName}"
                                                   Foreground="{Binding StaffRole, Converter={StaticResource RoleToColorConverter}}"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Margin="0"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Invoice Date" Binding="{Binding InvoiceDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="1.8*"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat='{}{0:N0} VNĐ'}" Width="1.5*"/>
                        
                        <DataGridTextColumn Header="Items" Binding="{Binding TotalItems}" Width="1*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="Status" Width="1.3*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusToSoftBackgroundConverter}}"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToForegroundConverter}}"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Margin="0"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Actions" Width="1.5*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- View Detail Button -->
                                        <Button Style="{StaticResource PremiumActionIconButtonStyle}"
                                                Command="{Binding DataContext.ViewInvoiceDetailCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource SuccessPrimaryBrush}"
                                                BorderBrush="{DynamicResource SuccessPrimaryBrush}" BorderThickness="1.5"
                                                ToolTip="View Detail"
                                                Margin="0,0,6,0">
                                            <ui:SymbolIcon Symbol="Edit24" FontSize="18" Foreground="{DynamicResource SuccessPrimaryBrush}"/>
                                        </Button>

                                        <!-- Cancel Button -->
                                        <Button Style="{StaticResource PremiumActionIconButtonStyle}"
                                                Command="{Binding DataContext.CancelInvoiceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource ErrorPrimaryBrush}"
                                                BorderBrush="{DynamicResource ErrorPrimaryBrush}" BorderThickness="1.5"
                                                ToolTip="Cancel Invoice">
                                            <ui:SymbolIcon Symbol="Delete24" FontSize="18" Foreground="{DynamicResource ErrorPrimaryBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Row="1" Margin="0 30 20 20">
                    <TextBlock Text="Lines per page" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,15,0"/>
                    <Grid VerticalAlignment="Center" Margin="0,0,40,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PageSize}" VerticalAlignment="Center" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,5,0"/>
                            <ui:SymbolIcon Symbol="ChevronDown24" Filled="False" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding PageSizeOptions}" SelectedItem="{Binding PageSize}" Width="50" Height="25" Background="Transparent" BorderThickness="0" Opacity="0.01" Cursor="Hand"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                        <TextBlock Text="{Binding CurrentPageStart}" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="13"/>
                        <TextBlock Text="-" Foreground="{DynamicResource TextOnLightBackgroudBrush}" Margin="2,0"/>
                        <TextBlock Text="{Binding CurrentPageEnd}" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="13"/>
                        <TextBlock Text="of" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="8,0"/>
                        <TextBlock Text="{Binding TotalInvoices}" Foreground="{DynamicResource TextOnLightBackgroudBrush}" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon Symbol=ChevronLeft24}" Appearance="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" Padding="5" BorderBrush="#38BDF8" BorderThickness="1.5" Margin="0,0,5,0" Command="{Binding PreviousPageCommand}"/>
                        <ui:Button Icon="{ui:SymbolIcon Symbol=ChevronRight24}" Appearance="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" Padding="5" BorderBrush="#38BDF8" BorderThickness="1.5" Command="{Binding NextPageCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>