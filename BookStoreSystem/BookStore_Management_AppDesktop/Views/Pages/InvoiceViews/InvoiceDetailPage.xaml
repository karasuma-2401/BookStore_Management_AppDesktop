<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.InvoiceViews.InvoiceDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1100"
      Title="InvoiceDetailPage"
      Background="{DynamicResource ContentBackgroundBrush}">



    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" 
                           Icon="{ui:SymbolIcon ChevronLeft24}" 
                           Appearance="Transparent" 
                           Background="Transparent" 
                           BorderBrush="#CBD5E1"
                           BorderThickness="1.5"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Command="{Binding BackToListCommand}"
                           Margin="0,0,15,0" 
                           Cursor="Hand"/>

                <TextBlock Grid.Column="1" 
                           Text="Invoice Details" 
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Invoice.VoucherCode}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Invoice.VoucherCode}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Background="{DynamicResource ActionPrimaryBrush}" CornerRadius="6" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="TicketHorizontal24" Foreground="{DynamicResource NavyPrimaryBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding Invoice.VoucherCode, StringFormat='Voucher: {0}'}" 
                                       Foreground="{DynamicResource SuccessPrimaryBrush}" 
                                       FontWeight="Black" 
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Thâu nhỏ nút export và căn lề phải trong Column 3 -->
                <Button Grid.Column="3"
                        Style="{StaticResource PremiumColoredButtonStyle}"
                        Background="{DynamicResource NavyAccentBrush}"
                        BorderBrush="#008A72"
                        BorderThickness="1.5"
                        Command="{Binding ExportInvoiceCommand}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Padding="15,8"
                        Width="160"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Print24" Foreground="{DynamicResource TextThirdBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Export Invoice" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource TextThirdBrush}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="25,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Invoice Summary Cards -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.6*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: Basic Information -->
                        <Border Grid.Column="0" 
                                Background="{DynamicResource CardBackgroundBrush}" 
                                BorderBrush="#2064748B" 
                                BorderThickness="1.5" 
                                CornerRadius="8" 
                                Margin="10,0,10,5" 
                                Padding="15,20" 
                                VerticalAlignment="Stretch">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
                            </Border.Effect>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="Person24" Foreground="{DynamicResource NavyPrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Customer: " FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Invoice.CustomerName}" FontWeight="Bold" Foreground="{DynamicResource TextOnCardBrush}" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="People24" Foreground="{DynamicResource NavyPrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Staff: " FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Invoice.StaffName}" Foreground="{DynamicResource TextOnCardBrush}" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Calendar24" Foreground="{DynamicResource NavyPrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Date: " FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Invoice.InvoiceDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Foreground="{DynamicResource TextOnCardBrush}" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Total Invoice -->
                        <Border Grid.Column="1" 
                                Background="#0D3B82F6" 
                                BorderBrush="#403B82F6" 
                                BorderThickness="1.5" 
                                CornerRadius="8" 
                                Margin="10,0,10,5" 
                                Padding="15,20" 
                                VerticalAlignment="Stretch">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
                            </Border.Effect>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Money24" Foreground="#3B82F6" FontSize="28" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                <TextBlock Text="Total Invoice" Foreground="{DynamicResource TextBodyBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Invoice.Total, StringFormat='{}{0:N0} VNĐ'}" FontWeight="Bold" Foreground="{DynamicResource TextOnCardBrush}" FontSize="16" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Paid Amount -->
                        <Border Grid.Column="2" 
                                Background="#0D10B981" 
                                BorderBrush="#4010B981" 
                                BorderThickness="1.5" 
                                CornerRadius="8" 
                                Margin="10,0,10,5" 
                                Padding="15,20" 
                                VerticalAlignment="Stretch">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
                            </Border.Effect>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource SuccessPrimaryBrush}" FontSize="28" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                <TextBlock Text="Paid Amount" Foreground="{DynamicResource TextBodyBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Invoice.PaidAmount, StringFormat='{}{0:N0} VNĐ'}" FontWeight="Bold" Foreground="{DynamicResource SuccessPrimaryBrush}" FontSize="16" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 4: Balance Due -->
                        <Border Grid.Column="3" 
                                Background="#0DEF4444"
                                BorderBrush="#40EF4444"
                                BorderThickness="1.5" 
                                CornerRadius="8" 
                                Margin="10,0,10,5" 
                                Padding="15,12" 
                                VerticalAlignment="Stretch">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="Balance Due" Foreground="{DynamicResource TextBodyBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Invoice.RemainingAmount, StringFormat='{}{0:N0} VNĐ'}" FontWeight="Black" Foreground="{DynamicResource ErrorPrimaryBrush}" FontSize="18" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <Button Grid.Row="1" 
                                        Style="{StaticResource PremiumColoredButtonStyle}"
                                        Background="{DynamicResource NavyAccentBrush}"
                                        BorderBrush="#008A72"
                                        BorderThickness="1.5"
                                        Command="{Binding RecordPaymentCommand}"
                                        Visibility="{Binding IsPaymentButtonVisible, Converter={StaticResource BoolToVis}}"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        Padding="15,8"
                                        Height="38">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Add24" Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="Record Payment" VerticalAlignment="Center" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock Text="Purchased Items" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource NavyPrimaryBrush}" 
                               Margin="10,0,0,15"/>

                    <!-- Purchased Items Cards Container (Visible only when history is hidden) -->
                    <ItemsControl ItemsSource="{Binding Invoice.Items}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHistoryExpanded}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="336" 
                                        Background="{DynamicResource CardBackgroundBrush}" 
                                        Margin="10" 
                                        Padding="22" 
                                        CornerRadius="8" 
                                        BorderThickness="1" 
                                        BorderBrush="{DynamicResource BorderLightBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.14" Color="#000000"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ui:TextBlock Grid.Row="0" 
                                                      Text="Book Information" 
                                                      FontSize="16" 
                                                      FontWeight="Bold" 
                                                      Foreground="{DynamicResource TextOnCardBrush}" 
                                                      Margin="0,0,0,15"/>

                                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                            <ui:TextBlock Text="Invoice ID" Style="{DynamicResource FormLabelStyle}" Margin="0,0,0,6"/>
                                            <ui:TextBox Style="{DynamicResource RoundedTextBoxInnerStyle}"
                                                        Text="{Binding DataContext.Invoice.InvoiceId, RelativeSource={RelativeSource AncestorType=Page}, Mode=OneWay}" 
                                                        IsReadOnly="True" 
                                                        Background="{DynamicResource ContentBackgroundBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                            <ui:TextBlock Text="Book Title" Style="{DynamicResource FormLabelStyle}" Margin="0,0,0,6"/>
                                            <ui:TextBox Style="{DynamicResource RoundedTextBoxInnerStyle}"
                                                        Text="{Binding BookTitle, Mode=OneWay}" 
                                                        IsReadOnly="True" 
                                                        Background="{DynamicResource ContentBackgroundBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Margin="0,0,0,10">
                                            <ui:TextBlock Text="Quantity" Style="{DynamicResource FormLabelStyle}" Margin="0,0,0,6"/>
                                            <ui:TextBox Style="{DynamicResource RoundedTextBoxInnerStyle}"
                                                        Text="{Binding Quantity, Mode=OneWay}"
                                                        Background="{DynamicResource CardBackgroundBrush}"
                                                        BorderThickness="1"
                                                        IsReadOnly="True"
                                                        BorderBrush="{DynamicResource BorderLightBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="4" Margin="0,0,0,10">
                                            <ui:TextBlock Text="Unit Price" Style="{DynamicResource FormLabelStyle}" Margin="0,0,0,6"/>
                                            <ui:TextBox Style="{DynamicResource RoundedTextBoxInnerStyle}"
                                                        Text="{Binding SalePrice, StringFormat='{}{0:N0} đ', Mode=OneWay}" 
                                                        IsReadOnly="True" 
                                                        Background="{DynamicResource ContentBackgroundBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="5" Margin="0,0,0,20">
                                            <ui:TextBlock Text="Subtotal" Style="{DynamicResource FormLabelStyle}" Margin="0,0,0,6" FontWeight="SemiBold"/>
                                            <ui:TextBox Style="{DynamicResource RoundedTextBoxInnerStyle}"
                                                        Text="{Binding SubTotal, StringFormat='{}{0:N0} đ', Mode=OneWay}" 
                                                        IsReadOnly="True" 
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource NavyPrimaryBrush}"
                                                        Background="{DynamicResource ContentBackgroundBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Purchased Items Grid Container (Visible only when history is expanded to save space) -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" 
                            Margin="10,0,10,20" 
                            Padding="15" 
                            CornerRadius="8" 
                            BorderThickness="1" 
                            BorderBrush="{DynamicResource BorderLightBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHistoryExpanded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DataGrid ItemsSource="{Binding Invoice.Items}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Background="Transparent" 
                                  RowBackground="{DynamicResource CardBackgroundBrush}"
                                  AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                                  HorizontalGridLinesBrush="#E2E8F0" 
                                  VerticalGridLinesBrush="Transparent"
                                  FontSize="14"
                                  Foreground="#1E293B"
                                  CanUserResizeColumns="False"
                                  CanUserReorderColumns="False"
                                  RowHeight="50">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                </Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SidebarAccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Book Title" Binding="{Binding BookTitle}" Width="3*"/>
                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="1*">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Unit Price" Binding="{Binding SalePrice, StringFormat='{}{0:N0} VNĐ'}" Width="1.8*"/>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding SubTotal, StringFormat='{}{0:N0} VNĐ'}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource NavyPrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Toggle Payment History Button -->
                    <Button Style="{StaticResource PremiumColoredButtonStyle}"
                            Background="{DynamicResource NavyLightBrush}"
                            BorderBrush="{DynamicResource NavyPrimaryBrush}"
                            BorderThickness="1.5"
                            Command="{Binding ToggleHistoryCommand}"
                            Visibility="{Binding IsPaymentHistoryVisible, Converter={StaticResource BoolToVis}}"
                            Margin="10,0,10,15"
                            Padding="15,8"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="History24" Foreground="White" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ToggleHistoryButtonText, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <!-- Payment History Section -->
                    <StackPanel Visibility="{Binding IsHistoryExpanded, Converter={StaticResource BoolToVis}}" Margin="0,15,0,0">
                        <Grid Margin="10,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Payment History" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource NavyPrimaryBrush}" 
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="1" 
                                    Style="{StaticResource PremiumColoredButtonStyle}"
                                    Background="{DynamicResource NavyLightBrush}"
                                    BorderBrush="{DynamicResource NavyPrimaryBrush}"
                                    BorderThickness="1.5"
                                    Command="{Binding ExportPaymentHistoryCommand}"
                                    Margin="0,0,10,0"
                                    Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="Export Payment History" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Background="{DynamicResource CardBackgroundBrush}" 
                                Margin="10" 
                                Padding="15" 
                                CornerRadius="8" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderLightBrush}">
                            <DataGrid ItemsSource="{Binding PaymentHistory}" 
                                      AutoGenerateColumns="False" 
                                      CanUserAddRows="False" 
                                      IsReadOnly="True" 
                                      HeadersVisibility="Column"
                                      Background="Transparent" 
                                      RowBackground="{DynamicResource CardBackgroundBrush}"
                                      AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                                      HorizontalGridLinesBrush="#E2E8F0" 
                                      VerticalGridLinesBrush="Transparent"
                                      FontSize="14"
                                      Foreground="#1E293B"
                                      CanUserResizeColumns="False"
                                      CanUserReorderColumns="False"
                                      RowHeight="50">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </Style>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    </Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ContentBackgroundBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource SidebarAccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Payment ID" Binding="{Binding PaymentId}" Width="1.2*" MinWidth="100">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="2.5*">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Staff" Binding="{Binding StaffName}" Width="2*"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='{}{0:N0} VNĐ'}" Width="2*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessPrimaryBrush}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>