<Page x:Class="BookStore_Management_AppDesktop.Views.Pages.PayrollPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
	  mc:Ignorable="d"
	  Background="{DynamicResource ContentBackgroundBrush}"
	  d:DesignHeight="700" d:DesignWidth="1000"
	  Title="Payroll Management">

	<Page.Resources>
	</Page.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" Padding="25,15,25,20">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0" Text="Payroll Management" FontSize="26" FontWeight="Black"
                            Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

				<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
					<!-- Bộ lọc Tháng -->
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
						<TextBlock Text="Month:" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
						<ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding SelectedMonth}"
								  Width="90" Height="32" Background="#0F172A"
								  Foreground="White" BorderBrush="#38BDF8" BorderThickness="1.5" Padding="8,4"
								  VerticalAlignment="Center"/>
					</StackPanel>

					<!-- Bộ lọc Năm -->
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
						<TextBlock Text="Year:" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
						<ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding SelectedYear}"
								  Width="90" Height="32" Background="#0F172A"
								  Foreground="White" BorderBrush="#38BDF8" BorderThickness="1.5" Padding="8,4"
								  VerticalAlignment="Center"/>
					</StackPanel>

					<ui:Button Content="Export" Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                               Command="{Binding ExportPayrollCommand}"
                               Background="{DynamicResource SidebarAccentBrush}"
                               Foreground="White"
                               BorderBrush="#0284C7" BorderThickness="1.5"
                               Appearance="Primary"
                               Cursor="Hand"
                               FontWeight="SemiBold"
                               Padding="15,8"
                               VerticalAlignment="Center"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Overview statistics cards section -->
		<Grid Grid.Row="1" Margin="20,15,20,5">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Card 1: Total Employees -->
			<Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
				<Border.Effect>
					<DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
				</Border.Effect>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="6"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Border Grid.Column="0" Background="{DynamicResource AccentBlueBrush}" CornerRadius="8,0,0,8"/>
					<Grid Grid.Column="1" Margin="15,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" VerticalAlignment="Center">
							<TextBlock Text="Total Employees" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<TextBlock Text="{Binding TotalEmployees}" Foreground="#1E293B" FontSize="22" FontWeight="Bold"/>
						</StackPanel>
						<ui:SymbolIcon Grid.Column="1" Symbol="People24" FontSize="24" Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
					</Grid>
				</Grid>
			</Border>

			<!-- Card 2: Total Payroll -->
			<Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="10,0,10,0">
				<Border.Effect>
					<DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
				</Border.Effect>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="6"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Border Grid.Column="0" Background="#6366F1" CornerRadius="8,0,0,8"/>
					<Grid Grid.Column="1" Margin="15,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" VerticalAlignment="Center">
							<TextBlock Text="Total Payroll" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<TextBlock Text="{Binding TotalPayroll, StringFormat='{}{0:N0} VNĐ'}" Foreground="#6366F1" FontSize="24" FontWeight="Bold"/>
						</StackPanel>
						<ui:SymbolIcon Grid.Column="1" Symbol="Money24" FontSize="24" Foreground="#6366F1" VerticalAlignment="Center" Margin="5,0,0,0"/>
					</Grid>
				</Grid>
			</Border>

			<!-- Card 3: Period -->
			<Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="10,0,0,0">
				<Border.Effect>
					<DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" Color="Black"/>
				</Border.Effect>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="6"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Border Grid.Column="0" Background="{DynamicResource WarningBrush}" CornerRadius="8,0,0,8"/>
					<Grid Grid.Column="1" Margin="15,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" VerticalAlignment="Center">
							<TextBlock Text="Period" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
							<TextBlock Text="{Binding SelectedMonth, StringFormat='Month {0}'}" Foreground="#1E293B" FontSize="16" FontWeight="SemiBold"/>
						</StackPanel>
						<ui:SymbolIcon Grid.Column="1" Symbol="Calendar24" FontSize="24" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
					</Grid>
				</Grid>
			</Border>
		</Grid>

		<!-- Phần DataGrid chuyển xuống Grid.Row="2" -->
		<Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" Margin="20" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
					<DataGrid ItemsSource="{Binding PayrollData}"
							  AutoGenerateColumns="False"
							  CanUserAddRows="False"
							  IsReadOnly="True"
							  RowHeight="70"
							  HeadersVisibility="Column"
							  Foreground="#1E293B"
							  Background="Transparent"
							  CanUserResizeColumns="False"
							  CanUserReorderColumns="False"
							  RowBackground="{DynamicResource CardBackgroundBrush}"
							  AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
							  HorizontalGridLinesBrush="#E2E8F0"
							  VerticalGridLinesBrush="Transparent"
							  FontSize="13"
							  Cursor="Hand"
							  EnableRowVirtualization="True"
							  PreviewMouseLeftButtonDown="PayrollDataGrid_PreviewMouseLeftButtonDown">
						<DataGrid.Resources>
							<Style TargetType="DataGridCell">
								<Setter Property="Background" Value="Transparent"/>
								<Setter Property="BorderThickness" Value="0"/>
								<Setter Property="VerticalAlignment" Value="Center"/>
								<Setter Property="Padding" Value="12,0"/>
								<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
								<Style.Triggers>
									<Trigger Property="IsSelected" Value="True">
										<Setter Property="Foreground" Value="#1E293B"/>
										<Setter Property="Background" Value="Transparent"/>
									</Trigger>
									<DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
										<Setter Property="FontWeight" Value="Bold"/>
										<Setter Property="Foreground" Value="#1E293B"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
							<Style TargetType="DataGridColumnHeader">
								<Setter Property="Background" Value="Transparent"/>
								<Setter Property="Foreground" Value="#64748B"/>
								<Setter Property="FontWeight" Value="Bold"/>
								<Setter Property="FontSize" Value="14"/>
								<Setter Property="Padding" Value="12,12"/>
								<Setter Property="HorizontalContentAlignment" Value="Left"/>
								<Setter Property="VerticalContentAlignment" Value="Center"/>
								<Setter Property="BorderThickness" Value="0,0,0,1"/>
								<Setter Property="BorderBrush" Value="#E2E8F0"/>
							</Style>
							<Style TargetType="TextBlock">
								<Setter Property="VerticalAlignment" Value="Center"/>
								<Setter Property="HorizontalAlignment" Value="Left"/>
								<Setter Property="Margin" Value="12,0"/>
								<Setter Property="Foreground" Value="#1E293B"/>
							</Style>
							<Style x:Key="CenteredHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
								<Setter Property="HorizontalContentAlignment" Value="Center"/>
							</Style>
							<Style x:Key="CenteredTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
								<Setter Property="HorizontalAlignment" Value="Center"/>
								<Setter Property="TextAlignment" Value="Center"/>
								<Setter Property="Margin" Value="0"/>
							</Style>
						</DataGrid.Resources>
						<DataGrid.RowStyle>
							<Style TargetType="DataGridRow">
								<Setter Property="Background" Value="Transparent"/>
								<Setter Property="BorderThickness" Value="1.5"/>
								<Setter Property="BorderBrush" Value="Transparent"/>
								<Setter Property="Height" Value="60"/>
								<Style.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
									</Trigger>
									<Trigger Property="IsSelected" Value="True">
										<Setter Property="BorderBrush" Value="{DynamicResource SidebarAccentBrush}"/>
										<Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
										<Setter Property="Foreground" Value="#1E293B"/>
									</Trigger>
								</Style.Triggers>
							</Style>
						</DataGrid.RowStyle>
						<DataGrid.Columns>
							<DataGridTextColumn Header="Employee ID" Binding="{Binding EmployeeId}" Width="1.2*" MinWidth="100"
												HeaderStyle="{StaticResource CenteredHeaderStyle}" ElementStyle="{StaticResource CenteredTextStyle}"/>
							<DataGridTextColumn Header="Employee Name" Binding="{Binding FullName}" Width="2*">
								<DataGridTextColumn.ElementStyle>
									<Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
										<Setter Property="FontWeight" Value="SemiBold"/>
									</Style>
								</DataGridTextColumn.ElementStyle>
							</DataGridTextColumn>
							<DataGridTextColumn Header="Total Assigned" Binding="{Binding TotalAssignedShifts}" Width="1.2*"
												HeaderStyle="{StaticResource CenteredHeaderStyle}" ElementStyle="{StaticResource CenteredTextStyle}"/>
							<DataGridTextColumn Header="Worked" Binding="{Binding WorkedShifts}" Width="1*"
												HeaderStyle="{StaticResource CenteredHeaderStyle}" ElementStyle="{StaticResource CenteredTextStyle}"/>
							<DataGridTextColumn Header="Absent" Binding="{Binding AbsentShifts}" Width="1*"
												HeaderStyle="{StaticResource CenteredHeaderStyle}" ElementStyle="{StaticResource CenteredTextStyle}"/>
							<DataGridTextColumn Header="Rate Per Shift" Binding="{Binding BaseSalary, StringFormat='{}{0:N0} VNĐ'}" Width="1.3*"/>
							<DataGridTemplateColumn Header="Actual Salary" Width="1.5*">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding ActualSalary, StringFormat='{}{0:N0} VNĐ'}" 
												   Foreground="#00DC82" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>
				</ScrollViewer>

				<Border Grid.Row="1" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,15">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
							<StackPanel Margin="0,0,20,0">
								<TextBlock Text="Total Payroll" Foreground="#64748B" FontSize="13" Margin="0,0,0,3" TextAlignment="Right"/>
								<TextBlock Text="{Binding TotalPayroll, StringFormat='{}{0:N0} VNĐ'}"
										   Foreground="#6366F1" FontSize="26" FontWeight="Bold" TextAlignment="Right"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</Grid>
		</Border>
	</Grid>
</Page>