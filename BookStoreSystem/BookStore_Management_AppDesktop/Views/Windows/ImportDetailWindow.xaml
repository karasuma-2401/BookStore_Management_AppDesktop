<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.ImportDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Import Detail" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Margin="20" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="5" Direction="270" Color="#0F172A"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Border Grid.Row="0" Background="#F8FAFC" Padding="28,24" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" MouseLeftButtonDown="Window_MouseLeftButtonDown" Cursor="SizeAll" Background="Transparent">
                        <TextBlock Text="Import Detail" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Review imported books and quantities" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1" Click="BtnClose_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top">
                        <ui:SymbolIcon Symbol="Dismiss24" Foreground="#94A3B8" FontSize="20"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Summary Section -->
            <Border Grid.Row="1" Background="White" Padding="28,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Import ID -->
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Text="Import ID" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding ImportId}" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>

                    <!-- Import Date -->
                    <StackPanel Grid.Column="1" Margin="0,0,30,0">
                        <TextBlock Text="Import Date" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding ImportDate, StringFormat='dd MMM yyyy, HH:mm'}" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                    </StackPanel>

                    <!-- Employee Name -->
                    <StackPanel Grid.Column="2" Margin="0,0,30,0">
                        <TextBlock Text="Employee" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding EmployeeName}" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </StackPanel>

                    <!-- Total Items -->
                    <StackPanel Grid.Column="4" Margin="0,0,30,0">
                        <TextBlock Text="Total Items" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TotalItems}" FontSize="16" FontWeight="Bold" Foreground="#6366F1"/>
                    </StackPanel>

                    <!-- Total Amount -->
                    <StackPanel Grid.Column="5" HorizontalAlignment="Right">
                        <TextBlock Text="Total Amount" Foreground="#64748B" FontSize="11" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} VND'}" FontSize="16" FontWeight="Bold" Foreground="#059669"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Data Grid Section -->
            <Border Grid.Row="2" Background="White" Padding="28,24">
                <DataGrid ItemsSource="{Binding OriginalData.Details}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          IsReadOnly="True" RowHeight="70" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0"
                          FontSize="14" Cursor="Hand">

                    <DataGrid.Resources>
                        <Style x:Key="LeftAlignedHeaderStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>

                        <Style x:Key="CenterAlignedHeaderStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>

                        <Style x:Key="RightAlignedHeaderStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                        </Style>

                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            <Setter Property="Height" Value="70"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="BOOK ID" Binding="{Binding BookId}" Width="90" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#0F172A"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="BOOK TITLE" Binding="{Binding BookTitle}" Width="1.5*" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#0F172A"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="PUBLISH YEAR" Binding="{Binding PublishYear}" Width="120" HeaderStyle="{StaticResource CenterAlignedHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="QUANTITY" Binding="{Binding Quantity}" Width="100" HeaderStyle="{StaticResource CenterAlignedHeaderStyle}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#6366F1"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="IMPORT PRICE" Width="140" HeaderStyle="{StaticResource RightAlignedHeaderStyle}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="ImportPrice" StringFormat="{}{0:N0} VND"/>
                            </DataGridTextColumn.Binding>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#059669"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TOTAL" Width="150" HeaderStyle="{StaticResource RightAlignedHeaderStyle}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="TotalPrice" StringFormat="{}{0:N0} VND"/>
                            </DataGridTextColumn.Binding>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#059669"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Footer Section -->
            <Border Grid.Row="3" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="28,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Export Button (same style as ReportPage) -->
                    <Button Click="BtnExport_Click" Height="38" Padding="18,0" Cursor="Hand" BorderThickness="1" Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ExportBtn" Padding="{TemplateBinding Padding}" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6">
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <ui:SymbolIcon Margin="0,0,8,0" FontSize="18" Foreground="#16A34A" Symbol="DocumentArrowDown24" />
                                        <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Text="Export" Foreground="#0F172A" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ExportBtn" Property="Background" Value="#F8FAFC"/>
                                        <Setter TargetName="ExportBtn" Property="BorderBrush" Value="#94A3B8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ExportBtn" Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Close Button -->
                    <Button Click="BtnClose_Click" Height="38" Padding="18,0" Cursor="Hand" BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Btn" Padding="{TemplateBinding Padding}" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6">
                                    <TextBlock Text="Close" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Btn" Property="Background" Value="#F8FAFC"/>
                                        <Setter TargetName="Btn" Property="BorderBrush" Value="#94A3B8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Btn" Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>