<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.ImportDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Import Detail" Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Margin="15">
        <Border CornerRadius="15" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="15" BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1" Background="{DynamicResource NavyPrimaryBrush}">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20" 
                            MouseLeftButtonDown="Window_MouseLeftButtonDown" Cursor="SizeAll" Background="Transparent">
                    <TextBlock Text="IMPORT DETAIL" Style="{StaticResource HeaderTextStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Review imported books and quantities" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ImportId, StringFormat='Import ID: {0}'}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding EmployeeName, StringFormat='Employee: {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding ImportDate, StringFormat='Date: {0:dd/MM/yyyy HH:mm}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding TotalAmount, StringFormat='Total: {0:N0} VND'}" Foreground="{DynamicResource SuccessPrimaryBrush}" FontWeight="Bold" FontSize="15" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2" ItemsSource="{Binding OriginalData.Details}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          IsReadOnly="True" RowHeight="50" HeadersVisibility="Column"
                          Foreground="#1E293B" Background="{DynamicResource CardBackgroundBrush}" 
                          RowBackground="Transparent" AlternatingRowBackground="#F8FAFC"
                          BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1"
                          HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="Transparent"
                          FontSize="14">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Book ID" Binding="{Binding BookId}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Title" Binding="{Binding BookTitle}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Import Price" Binding="{Binding ImportPrice, StringFormat={}{0:N0} VND}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="3" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <ui:Button Content="Close" Click="BtnClose_Click" 
                               Appearance="Secondary" Width="120" Height="40" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>