<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Notification" Height="220" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Margin="15">
        <Border CornerRadius="12" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.4" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="12" 
                Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderLightBrush}" 
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="65"/>
                </Grid.RowDefinitions>

                <Border BorderBrush="{DynamicResource DividerBrush}" 
                        BorderThickness="0,0,0,1" 
                        Background="{DynamicResource ContentBackgroundBrush}" 
                        CornerRadius="12,12,0,0">
                    <TextBlock Text="Notification" 
                               FontWeight="Bold" FontSize="16" 
                               Foreground="{DynamicResource TextOnLightBackgroudBrush}" 
                               VerticalAlignment="Center" Margin="20,0,0,0"/>
                </Border>

                <TextBlock x:Name="txtMessage" Grid.Row="1" 
                           Text="Content" 
                           TextWrapping="Wrap" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center" 
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" 
                           FontSize="15" Margin="20"/>

                <Border Grid.Row="2" 
                        Background="{DynamicResource ContentBackgroundBrush}" 
                        BorderBrush="{DynamicResource DividerBrush}" 
                        BorderThickness="0,1,0,0" 
                        CornerRadius="0,0,12,12">

                    <ui:Button Content="OK" 
                               Style="{StaticResource PrimaryActionButtonStyle}"
                               Width="120" 
                               Padding="20,8"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               Click="btnOk_Click"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>