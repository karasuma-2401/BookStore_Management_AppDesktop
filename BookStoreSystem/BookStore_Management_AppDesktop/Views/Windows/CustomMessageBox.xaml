<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Thông báo" Height="200" Width="350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Border CornerRadius="8" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                <TextBlock Text="Thông Báo" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Border>

            <TextBlock x:Name="txtMessage" Grid.Row="1" Text="Nội dung sẽ nằm ở đây" 
                       TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" 
                       FontSize="14" Margin="20"/>

            <ui:Button Grid.Row="2" Content="OK" Appearance="Primary" Width="100" 
                       HorizontalAlignment="Center" Click="BtnOk_Click"/>
        </Grid>
    </Border>
</Window>