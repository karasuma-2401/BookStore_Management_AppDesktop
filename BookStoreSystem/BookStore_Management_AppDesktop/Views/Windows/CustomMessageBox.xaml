<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Thông báo" Height="220" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Margin="15">
        <Border CornerRadius="12" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.4" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="12" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="65"/>
                </Grid.RowDefinitions>

                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Background="#F8FAFC" CornerRadius="12,12,0,0">
                    <TextBlock Text="Notification" FontWeight="Bold" FontSize="16" Foreground="#0F172A" VerticalAlignment="Center" Margin="20,0,0,0"/>
                </Border>

                <TextBlock x:Name="txtMessage" Grid.Row="1" Text="Content" 
                           TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"
                           Foreground="#334155" FontSize="15" Margin="20"/>

                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">

                    <ui:Button Content="OK" Appearance="Primary" Width="120" Height="36"
                               Background="#00C2A8" Foreground="White" FontWeight="Bold" BorderThickness="0"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Click="BtnOk_Click" Cursor="Hand"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>