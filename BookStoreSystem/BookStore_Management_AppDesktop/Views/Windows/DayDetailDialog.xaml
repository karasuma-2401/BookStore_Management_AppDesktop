<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.DayDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Title="Day Shift Details" Height="480" Width="620">
    <Grid Margin="15">
        <Border CornerRadius="15" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="15" BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1" Background="{DynamicResource NavyPrimaryBrush}">
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" MouseLeftButtonDown="Header_MouseLeftButtonDown" Cursor="SizeAll" Background="Transparent">
                        <TextBlock Text="SHIFT DETAIL" FontSize="24" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="DateTextBlock" Text="Monday, 01 June 2026" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Dismiss24}" Click="Close_Click" 
                               Appearance="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" 
                               Padding="6" VerticalAlignment="Top"/>
                </Grid>

                <!-- Shifts List -->
                <ItemsControl x:Name="ShiftsItemsControl" Grid.Row="1">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource SlateMediumBrush}" BorderThickness="0,0,0,1" Padding="0,12" VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Shift Info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ShiftName}" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding WorkTime}" FontSize="12" Foreground="{DynamicResource SlateBorderBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <!-- Assigned Info or ComboBox Selector -->
                                    <Grid Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                        <!-- If Ca Trống: ComboBox to select employee (Default: Collapsed) -->
                                        <ComboBox x:Name="EmployeeComboBox" 
                                                  ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=EmployeesList}"
                                                  DisplayMemberPath="FullName"
                                                  SelectedValuePath="EmployeeId"
                                                  Height="35" 
                                                  Background="{DynamicResource SidebarBackgroundBrush}"
                                                  Foreground="White"
                                                  Visibility="Collapsed">
                                        </ComboBox>

                                        <!-- If Ca Đã Gán: Employee info and Status tag (Default: Visible) -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    x:Name="AssignedInfoPanel" Visibility="Visible">
                                            <TextBlock Text="{Binding FullName}" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                            <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center" x:Name="StatusBadge" Background="{DynamicResource SlateLightBrush}">
                                                <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- If Ca Trống & Past Date: show simple TextBlock (Default: Collapsed) -->
                                        <TextBlock x:Name="EmptyPastDateTextBlock" 
                                                   Text="No schedule assigned" 
                                                   FontSize="14" 
                                                   FontStyle="Italic"
                                                   Foreground="{DynamicResource SlateBorderBrush}" 
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Grid>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Assign Button (Default: Collapsed) -->
                                        <ui:Button Content="Assign" 
                                                   Click="Assign_Click"
                                                   Appearance="Primary" 
                                                   Background="{DynamicResource NavyAccentBrush}" 
                                                   Padding="12,6" FontSize="12"
                                                   x:Name="AssignBtn"
                                                   Visibility="Collapsed"/>

                                        <!-- Delete Assignment Button (Default: Visible) -->
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" 
                                                   Click="Delete_Click"
                                                   Appearance="Transparent" 
                                                   Foreground="{DynamicResource RoseAccentBrush}"
                                                   Padding="6"
                                                   ToolTip="Cancel shift assignment"
                                                   x:Name="DeleteBtn"
                                                   Visibility="Visible"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <!-- When AssignmentId is null (Empty ca) -->
                                <DataTrigger Binding="{Binding AssignmentId}" Value="{x:Null}">
                                    <Setter TargetName="EmployeeComboBox" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="AssignBtn" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="AssignedInfoPanel" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="DeleteBtn" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>

                                <!-- When AssignmentId is null AND IsPastDate is True -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding AssignmentId}" Value="{x:Null}"/>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=IsPastDate}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="EmployeeComboBox" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="AssignBtn" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="AssignedInfoPanel" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="DeleteBtn" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="EmptyPastDateTextBlock" Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>

                                <!-- When IsPastDate is True (regardless of assignment), disable deletion of past shifts -->
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=IsPastDate}" Value="True">
                                    <Setter TargetName="DeleteBtn" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>

                                <!-- Status Badge Colors -->
                                <DataTrigger Binding="{Binding Status}" Value="Present">
                                    <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource StatusPresentBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Late">
                                    <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource LatePurpleBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Absent">
                                    <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource StatusAbsentBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Compensated">
                                    <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource CompensatedBlueBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Footer / Close -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <ui:Button Content="Close" Click="Close_Click" Appearance="Secondary" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
