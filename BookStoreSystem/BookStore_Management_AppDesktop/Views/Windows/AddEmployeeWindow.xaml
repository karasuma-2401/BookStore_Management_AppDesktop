<Window
    x:Class="BookStore_Management_AppDesktop.Views.Windows.AddEmployeeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Add Employee"
    Width="400"
    Height="650"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Grid Margin="15">
        <Border Background="Black" CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="15"
                    Opacity="0.5"
                    ShadowDepth="2"
                    Color="Black" />
            </Border.Effect>
        </Border>

        <Border
            Background="{DynamicResource NavyPrimaryBrush}"
            BorderBrush="{DynamicResource NavyLightBrush}"
            BorderThickness="1"
            CornerRadius="15">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="StackPanel_MouseLeftButtonDown">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="28"
                        FontWeight="Black"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="ADD EMPLOYEE" />
                    <TextBlock
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="Book Store Management System" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock
                        Margin="0,5,0,5"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="UserID" />
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*" />
                            <ColumnDefinition Width="53*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Height="35"
                            Margin="0,0,10,0"
                            IsEditable="True"
                            IsReadOnly="True"
                            IsTextSearchEnabled="True"
                            ItemsSource="{Binding UserList}"
                            SelectedItem="{Binding SelectedUserId}"
                            StaysOpenOnEdit="True"
                            Text="{Binding SearchUserIDText, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:Button
                            Grid.Column="2"
                            Height="30"
                            HorizontalAlignment="Center"
                            Appearance="Primary"
                            Background="{DynamicResource NavyLightBrush}"
                            Command="{Binding AddUserIDCommand}"
                            Content="Add"
                            Cursor="Hand"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Icon="{ui:SymbolIcon Add24}" />
                    </Grid>
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Full Name" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource NavyLightBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        PlaceholderText="Enter full name..."
                        Text="{Binding NewEmployee.FullName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Age" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource NavyLightBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        PlaceholderText="Enter age..."
                        Text="{Binding NewEmployee.Age, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Phone" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource NavyLightBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        PlaceholderText="Enter phone..."
                        Text="{Binding NewEmployee.Phone, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Address" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource NavyLightBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        PlaceholderText="Enter address..."
                        Text="{Binding NewEmployee.Address, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="Salary" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource NavyLightBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        PlaceholderText="Enter salary..."
                        Text="{Binding NewEmployee.Salary, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,15,0"
                        Appearance="Transparent"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Cancel"
                        Foreground="{DynamicResource TextSecondaryBrush}" />

                    <ui:Button
                        Width="120"
                        Appearance="Primary"
                        Background="{DynamicResource NavyAccentBrush}"
                        Command="{Binding AddEmployeeCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Add Employee" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>