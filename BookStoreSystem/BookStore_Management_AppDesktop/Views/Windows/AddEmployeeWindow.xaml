<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Title="Add Employee" Height="550" Width="400">
    <Grid Margin="15">
        <Border CornerRadius="15" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="15" BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1" Background="{DynamicResource NavyPrimaryBrush}">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25" 
                            MouseLeftButtonDown="Window_MouseLeftButtonDown" Cursor="SizeAll" Background="Transparent">
                    <TextBlock Text="ADD EMPLOYEE" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="UserID" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                              IsEditable="True" 
                              IsTextSearchEnabled="False"
                              StaysOpenOnEdit="True"
                              ItemsSource="{Binding UserIDView}" 
                              DisplayMemberPath="AuthorName" 
                              Text="{Binding SearchUserIDText, UpdateSourceTrigger=PropertyChanged}"
                              SelectedItem="{Binding SelectedUserID}"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,10,0" Height="30"/>

                        <ui:Button Grid.Column="1"
                               Icon="{ui:SymbolIcon Add24}"
                               Content="Add"
                               Appearance="Primary"
                               Command="{Binding AddUserIDCommand}"
                               Background="{DynamicResource NavyLightBrush}" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Height="30" Cursor="Hand"/>  
                    </Grid>
                    <TextBlock Text="Full Name" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewEmployee.FullName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter full name..." Margin="0,0,0,10"/>

                    <TextBlock Text="Age" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewEmployee.Age, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter age..." Margin="0,0,0,10"/>

                    <TextBlock Text="Phone" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewEmployee.Phone, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter phone..." Margin="0,0,0,10"/>

                    <TextBlock Text="Address" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewEmployee.Address, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter address..." Margin="0,0,0,10"/>

                    <TextBlock Text="Salary" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewEmployee.Salary, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter salary..." Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2">
                    <ui:Button Content="Cancel" Command="{Binding CancelCommand}" 
                               CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                               Appearance="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,15,0"/>

                    <ui:Button Content="Add Employee" Command="{Binding SaveCommand}" 
                               CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                               Appearance="Primary" Background="{DynamicResource NavyAccentBrush}" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>