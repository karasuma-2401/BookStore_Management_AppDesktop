<Window
    x:Class="BookStore_Management_AppDesktop.Views.Windows.AddEmployeeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Add Employee"
    Width="400"
    Height="680"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.Resources>
        <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#1E293B"/>
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlForeground" Color="#1E293B" />
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#1E293B" />
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#1E293B" />
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#94A3B8" />
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#94A3B8" />
                <SolidColorBrush x:Key="TextControlBackground" Color="#F8FAFC" />
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#F1F5F9" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" />
                <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#E2E8F0" />
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#64748B" />
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#00D4B2" />
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#00D4B2" />
                <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#CBD5E1" />
                <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#64748B" />
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Resources>
                <!-- Override system and theme brushes to force a light theme dropdown -->
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#1E293B" />
                <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="White" />
                <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="#F8FAFC" />
                <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="#E2E8F0" />
                <SolidColorBrush x:Key="SystemControlPageBackgroundChromeLowBrush" Color="White" />
                <SolidColorBrush x:Key="ComboBoxBackground" Color="White" />
                <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#F1F5F9" />
                <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#E2E8F0" />
                <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="#E2E8F0" />
                <SolidColorBrush x:Key="ComboBoxForeground" Color="#1E293B" />
                <SolidColorBrush x:Key="ComboBoxForegroundPointerOver" Color="#1E293B" />
                <SolidColorBrush x:Key="ComboBoxForegroundPressed" Color="#1E293B" />
                <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="#94A3B8" />
                <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="White" />
                <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="White" />
                <SolidColorBrush x:Key="ComboBoxPopupForeground" Color="#1E293B" />
                <SolidColorBrush x:Key="ControlSolidFillColorDefaultBrush" Color="White" />
                
                <!-- Custom light ComboBoxItem style with elegant hover and select triggers -->
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#1E293B" />
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ItemBorder" 
                                        Background="{TemplateBinding Background}" 
                                        BorderThickness="0" 
                                        CornerRadius="6" 
                                        Margin="3,2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9" />
                                        <Setter Property="TextElement.Foreground" Value="#00D4B2" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#E0FDF9" />
                                        <Setter Property="TextElement.Foreground" Value="#00BFA0" />
                                        <Setter Property="TextElement.FontWeight" Value="SemiBold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Border Background="Black" CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="15"
                    Opacity="0.15"
                    ShadowDepth="2"
                    Color="Black" />
            </Border.Effect>
        </Border>

        <Border
            Background="White"
            BorderBrush="#CBD5E1"
            BorderThickness="1.5"
            CornerRadius="15">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="StackPanel_MouseLeftButtonDown">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="28"
                        FontWeight="Black"
                        Foreground="#1E293B"
                        Text="ADD EMPLOYEE" />
                    <TextBlock
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="#64748B"
                        Text="Book Store Management System" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock
                        Margin="0,5,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="UserID" />
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*" />
                            <ColumnDefinition Width="53*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Height="35"
                            Margin="0,0,10,0"
                            IsEditable="True"
                            IsReadOnly="True"
                            IsTextSearchEnabled="True"
                            ItemsSource="{Binding UserList}"
                            SelectedItem="{Binding SelectedUserId}"
                            StaysOpenOnEdit="True"
                            Text="{Binding SearchUserIDText, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:Button
                            Grid.Column="2"
                            Height="40"
                            HorizontalAlignment="Center"
                            Style="{StaticResource PremiumSolidButtonStyle}"
                            Command="{Binding AddUserIDCommand}"
                            Content="Add"
                            Icon="{ui:SymbolIcon Add24}" />
                    </Grid>
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Full Name" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        PlaceholderText="Enter full name..."
                        Text="{Binding NewEmployee.FullName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Age" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        PlaceholderText="Enter age..."
                        Text="{Binding NewEmployee.Age, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Phone" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        PlaceholderText="Enter phone..."
                        Text="{Binding NewEmployee.Phone, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Address" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        PlaceholderText="Enter address..."
                        Text="{Binding NewEmployee.Address, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Salary" />
                    <ui:TextBox
                        Margin="0,0,0,10"
                        PlaceholderText="Enter salary..."
                        Text="{Binding NewEmployee.Salary, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,15,0"
                        Style="{StaticResource CancelButtonStyle}"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Cancel" />

                    <ui:Button
                        Width="145"
                        Height="38"
                        Style="{StaticResource PremiumSolidButtonStyle}"
                        Command="{Binding AddEmployeeCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Add Employee" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>