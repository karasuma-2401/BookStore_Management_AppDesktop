<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="BookStore Management" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource NavyPrimaryBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Column="0"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           OpenPaneLength="250"
                           Background="{DynamicResource SidebarBackgroundBrush}">

            <ui:NavigationView.PaneHeader>
                <Grid Margin="15,20,0,20">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Library24" FontSize="25" Foreground="{DynamicResource NavyAccentBrush}" Margin="0,0,10,0"/>

                        <TextBlock Text="BOOKSTORE" 
                                   Style="{StaticResource HeaderTextStyle}" 
                                   Opacity="0">
                            <TextBlock.RenderTransform>
                                <TranslateTransform X="-30"/>
                            </TextBlock.RenderTransform>

                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>    
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity" From="0" To="1"
                                                Duration="0:0:1.0"/>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                From="-30" To="0"
                                                Duration="0:0:1.0"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </ui:NavigationView.PaneHeader>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Tag="Books" Icon="{ui:SymbolIcon Book24}" Command="{Binding NavigateCommand}" CommandParameter="Books">
                    <TextBlock Text="Books" FontSize="{StaticResource FontSizeSubTitle}" FontWeight="SemiBold"/>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Tag="Employees" Icon="{ui:SymbolIcon People24}" Command="{Binding NavigateCommand}" CommandParameter="Employees">
                    <TextBlock Text="Employees" FontSize="{StaticResource FontSizeSubTitle}" FontWeight="SemiBold"/>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Tag="Customers" Icon="{ui:SymbolIcon Person24}">
                    <TextBlock Text="Customers" FontSize="{StaticResource FontSizeSubTitle}" FontWeight="SemiBold"/>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Tag="Invoice" Icon="{ui:SymbolIcon Document24}">
                    <TextBlock Text="Invoice" FontSize="{StaticResource FontSizeSubTitle}" FontWeight="SemiBold"/>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Tag="Inventory" Icon="{ui:SymbolIcon Box24}" Command="{Binding NavigateCommand}" CommandParameter="Inventory">
                    <TextBlock Text="Inventory" FontSize="{StaticResource FontSizeSubTitle}" FontWeight="SemiBold"/>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Tag="Settings" Icon="{ui:SymbolIcon Settings24}" Command="{Binding NavigateCommand}" CommandParameter="Settings">
                    <TextBlock Text="Settings" FontSize="{StaticResource FontSizeSubTitle}" FontWeight="SemiBold"/>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
        <Border Grid.Column="1" 
                CornerRadius="8" 
                Background="{DynamicResource ContentBackgroundBrush}">
            <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>