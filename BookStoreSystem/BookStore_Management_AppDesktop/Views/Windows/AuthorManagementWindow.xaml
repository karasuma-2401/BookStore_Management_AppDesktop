<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.AuthorManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Authors Management" Height="550" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ContentBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0" 
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Search authors by name..." 
                        Icon="{ui:SymbolIcon Search24}"
                        VerticalAlignment="Center"
                        Margin="0,0,15,0"/>

            <ui:Button Grid.Column="1"
                       Command="{Binding AddAuthorCommand}"
                       Appearance="Primary"
                       Height="38" Padding="15,0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="Add Author" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </ui:Button>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding Authors}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" CanUserSortColumns="False" 
                          RowHeight="55" HeadersVisibility="Column"
                          Foreground="{DynamicResource TextOnLightBackgroudBrush}" 
                          Background="Transparent" BorderThickness="0"
                          HorizontalGridLinesBrush="#E2E8F0" VerticalGridLinesBrush="Transparent"
                          FontSize="{StaticResource FontSizeBody}" Cursor="Hand">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding AuthorId}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="15,0,0,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Author Name" Binding="{Binding Name}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Actions" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#F1F5F9" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True">
                                        <Menu Background="Transparent" BorderThickness="0">
                                            <MenuItem Padding="10,6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                <MenuItem.Header>
                                                    <ui:SymbolIcon Symbol="MoreVertical24" FontSize="18" Foreground="#475569"/>
                                                </MenuItem.Header>

                                                <MenuItem Header="Rename" 
                                                          Icon="{ui:SymbolIcon Edit24}"
                                                          Foreground="{DynamicResource SuccessPrimaryBrush}"
                                                          Command="{Binding DataContext.EditAuthorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          CommandParameter="{Binding}"/>

                                                <Separator Background="#E2E8F0"/>

                                                <MenuItem Header="Delete" 
                                                          Icon="{ui:SymbolIcon Delete24}" 
                                                          Foreground="{DynamicResource ErrorPrimaryBrush}"
                                                          Command="{Binding DataContext.DeleteAuthorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          CommandParameter="{Binding}"/>
                                            </MenuItem>
                                        </Menu>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <ui:ProgressRing IsIndeterminate="True" 
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" 
                                 Width="40" Height="40"/>
            </Grid>
        </Border>
    </Grid>
</Window>