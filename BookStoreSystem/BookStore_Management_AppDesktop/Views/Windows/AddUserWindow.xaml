<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Title="Add User" Height="600" Width="400">
    <Grid Margin="15">
        <Border CornerRadius="15" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="15" BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1" Background="{DynamicResource NavyPrimaryBrush}">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25" 
                            MouseLeftButtonDown="Header_MouseLeftButtonDown" Cursor="SizeAll" Background="Transparent">
                    <TextBlock Text="CREATE USER" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Book Store Management System" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Username" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewUser.Username, UpdateSourceTrigger=PropertyChanged}" 
                                PlaceholderText="Enter username..." Margin="0,0,0,12" 
                                Icon="{ui:SymbolIcon Person24}"/>

                    <TextBlock Text="Password" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:PasswordBox Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Enter password..." Margin="0,0,0,12" 
                                    Icon="{ui:SymbolIcon Password24}"/>

                    <TextBlock Text="Full Name" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewUser.FullName, UpdateSourceTrigger=PropertyChanged}" 
                                PlaceholderText="Enter full name..." Margin="0,0,0,12"/>

                    <TextBlock Text="Email Address" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding NewUser.Email, UpdateSourceTrigger=PropertyChanged}" 
                                PlaceholderText="example@mail.com..." Margin="0,0,0,12"/>

                    <TextBlock Text="Role" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox SelectedValue="{Binding NewUser.RoleId}" 
                              SelectedValuePath="Content"
                              Height="35" Background="{DynamicResource SidebarBackgroundBrush}">
                        <ComboBoxItem Content="staff" IsSelected="True"/>
                        <ComboBoxItem Content="admin"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="0,15,0,0">
                    <ui:Button Content="Cancel" Click="Cancel_Click"
                               Appearance="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,15,0"/>

                    <ui:Button Content="Create Account" Command="{Binding SaveCommand}" 
                               CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                               Appearance="Primary" Background="{DynamicResource NavyAccentBrush}" Width="130"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>