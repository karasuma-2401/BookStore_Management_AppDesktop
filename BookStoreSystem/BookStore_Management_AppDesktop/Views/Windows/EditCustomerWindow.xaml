<Window
    x:Class="BookStore_Management_AppDesktop.Views.Windows.EditCustomerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Edit Customer"
    Width="450"
    Height="600"
    Background="White"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
        <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#1E293B"/>
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlForeground" Color="#1E293B" />
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#1E293B" />
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#1E293B" />
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#94A3B8" />
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#94A3B8" />
                <SolidColorBrush x:Key="TextControlBackground" Color="#F8FAFC" />
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#F1F5F9" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" />
                <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#E2E8F0" />
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#64748B" />
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#00D4B2" />
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#00D4B2" />
                <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#CBD5E1" />
                <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#64748B" />
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Padding="30,20"
            Background="#F8FAFC">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#1E293B"
                    Text="Edit Customer" />
                <StackPanel Margin="0,0,0,15">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Customer ID" />
                    <ui:TextBox
                        x:Name="IdTextBox"
                        IsEnabled="False" />
                </StackPanel>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Full Name *" />
                    <ui:TextBox
                        x:Name="NameTextBox"
                        PlaceholderText="Enter customer name" />
                </StackPanel>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Phone" />
                    <ui:TextBox
                        x:Name="PhoneTextBox"
                        PlaceholderText="Enter phone number" />
                </StackPanel>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Email" />
                    <ui:TextBox
                        x:Name="EmailTextBox"
                        PlaceholderText="Enter email address" />
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Address" />
                    <ui:TextBox
                        x:Name="AddressTextBox"
                        Height="80"
                        AcceptsReturn="True"
                        PlaceholderText="Enter address" />
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="SemiBold"
                        Foreground="#1E293B"
                        Text="Total Debt" />
                    <ui:TextBox
                        x:Name="DebtTextBox"
                        IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <Border
            Grid.Row="1"
            Padding="30,15"
            Background="White"
            BorderBrush="#E2E8F0"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <ui:Button
                    x:Name="CancelButton"
                    Width="100"
                    Height="38"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Content="Cancel"
                    Style="{StaticResource CancelButtonStyle}" />

                <ui:Button
                    x:Name="SaveButton"
                    Width="100"
                    Height="38"
                    Click="SaveButton_Click"
                    Content="Update"
                    Style="{StaticResource PremiumSolidButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>