<Window
    x:Class="BookStore_Management_AppDesktop.Views.Windows.AddBookWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Add New Book"
    Width="750"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#0F172A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="#0F172A" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🎯 Style cho TextBox có lỗi validation: viền chuyển sang màu đỏ -->
        <Style x:Key="FormTextBoxErrorStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasPublishYearError}" Value="True">
                    <Setter Property="BorderBrush" Value="#EF4444" />
                    <Setter Property="BorderThickness" Value="1.5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasPublishYearError}" Value="False">
                    <Setter Property="BorderBrush" Value="#0F172A" />
                    <Setter Property="BorderThickness" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DropdownListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="12,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryActionBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC" />
                    <Setter Property="BorderBrush" Value="#94A3B8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Padding="25" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.04" ShadowDepth="4" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Margin="0,0,15,0" Background="#F0FDF4" CornerRadius="8">
                            <ui:SymbolIcon FontSize="22" Foreground="#16A34A" Symbol="AddSquare24" />
                        </Border>
                        <TextBlock VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#0F172A" Text="Create New Book" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding CancelCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="32" Height="32" Background="Transparent" CornerRadius="16" x:Name="BtnBg">
                                    <ui:SymbolIcon FontSize="14" Foreground="#94A3B8" Symbol="Dismiss24" x:Name="Icon"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBg" Property="Background" Value="#F1F5F9"/>
                                        <Setter TargetName="Icon" Property="Foreground" Value="#0F172A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" VerticalAlignment="Top" Height="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="4" Color="#0F172A" Direction="270"/>
                        </Border.Effect>
                        <Border Background="#F8FAFC" BorderBrush="#0F172A" BorderThickness="1" CornerRadius="8" Padding="1" ClipToBounds="True">
                            <Grid>
                                <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform" Source="{Binding LocalImagePath}" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding LocalImagePath, Converter={StaticResource BoolToVis}, ConverterParameter=Inverted}">
                                    <ui:SymbolIcon Symbol="Image24" FontSize="40" Foreground="#CBD5E1" Margin="0,0,0,10"/>
                                    <TextBlock Text="No Image Selected" Foreground="#94A3B8" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <StackPanel Grid.Column="2">

                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="Book Title "/>
                                <Run Text="*" Foreground="#EF4444"/>
                            </ui:TextBlock>
                            <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="Publish Year "/>
                                <Run Text="*" Foreground="#EF4444"/>
                            </ui:TextBlock>
                            <TextBox x:Name="PublishYearTextBox"
                                     Text="{Binding PublishYear, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBoxErrorStyle}"
                                     MaxLength="4"
                                     PreviewTextInput="PublishYearTextBox_PreviewTextInput"
                                     DataObject.Pasting="PublishYearTextBox_Pasting"
                                     ToolTip="Nhập năm xuất bản (VD: 2024). Chỉ được nhập số, tối đa 4 chữ số."/>
                            <!-- 🎯 TextBlock cảnh báo: chỉ hiển thị khi có lỗi -->
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding PublishYearError}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="#EF4444"
                                       Visibility="{Binding HasPublishYearError, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="Author(s) - Search or add new..." />
                                <Run Text="*" Foreground="#EF4444"/>
                            </ui:TextBlock>
                            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Padding="6,4">
                                <WrapPanel Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding SelectedBookAuthors}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E0F2FE" CornerRadius="4" Padding="8,4" Margin="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#0369A1" FontWeight="Medium" VerticalAlignment="Center"/>
                                                        <Button Width="16" Height="16" Margin="6,0,0,0" Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding DataContext.RemoveAuthorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="10" Foreground="#0369A1"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Width="220" Margin="2">
                                        <TextBox x:Name="AuthorInputBox" 
                                                 Text="{Binding AuthorSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FormTextBoxStyle}"
                                                 Height="34" Padding="32,0,10,0" />

                                        <ui:SymbolIcon Symbol="Search24" FontSize="16" Foreground="#64748B" Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                        <Popup IsOpen="{Binding IsAuthorDropdownOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=AuthorInputBox}" Placement="Bottom">
                                            <Border Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Margin="0,4,0,0" MaxHeight="200" Width="{Binding ActualWidth, ElementName=AuthorInputBox}">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Direction="270"/>
                                                </Border.Effect>
                                                <ListBox ItemsSource="{Binding AvailableAuthors}" SelectedItem="{Binding SelectedAuthorComboItem}" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource DropdownListItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon x:Name="Icon" Symbol="Person24" Foreground="#64748B" FontSize="16" Margin="0,0,10,0"/>
                                                                <TextBlock x:Name="Txt" Text="{Binding Name}" Foreground="#0F172A" FontSize="13" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding AuthorId}" Value="-1">
                                                                    <Setter TargetName="Icon" Property="Symbol" Value="AddSquare24"/>
                                                                    <Setter TargetName="Icon" Property="Foreground" Value="#059669"/>
                                                                    <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="#059669"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </WrapPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}">
                                <Run Text="Genres &amp; Categories - Search or add new..." />
                                <Run Text="*" Foreground="#EF4444"/>
                            </ui:TextBlock>
                            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Padding="6,4">
                                <WrapPanel Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding SelectedBookCategories}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F3E8FF" CornerRadius="4" Padding="8,4" Margin="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#6B21A8" FontWeight="Medium" VerticalAlignment="Center"/>
                                                        <Button Width="16" Height="16" Margin="6,0,0,0" Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding DataContext.RemoveCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="10" Foreground="#6B21A8"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Width="220" Margin="2">
                                        <TextBox x:Name="CategoryInputBox" 
                                                 Text="{Binding CategorySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FormTextBoxStyle}"
                                                 Height="34" Padding="32,0,10,0" />

                                        <ui:SymbolIcon Symbol="Search24" FontSize="16" Foreground="#64748B" Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                        <Popup IsOpen="{Binding IsCategoryDropdownOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=CategoryInputBox}" Placement="Bottom">
                                            <Border Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Margin="0,4,0,0" MaxHeight="200" Width="{Binding ActualWidth, ElementName=CategoryInputBox}">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Direction="270"/>
                                                </Border.Effect>
                                                <ListBox ItemsSource="{Binding AvailableCategories}" SelectedItem="{Binding SelectedCategoryComboItem}" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource DropdownListItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon x:Name="Icon" Symbol="Grid24" Foreground="#64748B" FontSize="16" Margin="0,0,10,0"/>
                                                                <TextBlock x:Name="Txt" Text="{Binding Name}" Foreground="#0F172A" FontSize="13" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding CategoryId}" Value="-1">
                                                                    <Setter TargetName="Icon" Property="Symbol" Value="AddSquare24"/>
                                                                    <Setter TargetName="Icon" Property="Foreground" Value="#059669"/>
                                                                    <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="#059669"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </WrapPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}" Text="Image Cover Path (URL)" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding LocalImagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" FontSize="12"/>
                                <Button Grid.Column="2" Height="40" Padding="15,0" Command="{Binding ChangeBookImageCommand}" Style="{StaticResource SecondaryActionBtnStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" Margin="0,0,6,0" Foreground="#475569"/>
                                        <TextBlock Text="Browse..." VerticalAlignment="Center" FontSize="13" Foreground="#475569" FontWeight="Medium"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Padding="0,15,0,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding CancelCommand}" Content="Cancel" Style="{StaticResource SecondaryActionBtnStyle}" />

                        <Button Grid.Column="2" Command="{Binding SaveBookChangesCommand}" Style="{StaticResource PrimaryActionBtnStyle}">
                            <Grid>
                                <TextBlock Text="Create Book" Foreground="#FFFFFF" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Foreground="#FFFFFF" Margin="0,0,8,0"/>
                                    <TextBlock Text="Saving..." Foreground="#FFFFFF" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>