<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Add New Book" Height="700" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="15">
        <Border CornerRadius="15" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="15" BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1" Background="{DynamicResource NavyPrimaryBrush}">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25" 
                            MouseLeftButtonDown="Window_MouseLeftButtonDown" Cursor="SizeAll" Background="Transparent">
                    <TextBlock Text="ADD BOOK" FontSize="36" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Book Store Management System" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">

                    <TextBlock Text="Title" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <ui:TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter book title..." 
                                Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource NavyLightBrush}" Padding="10,8"/>

                    <TextBlock Text="Author" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  IsEditable="True" 
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True"
                                  ItemsSource="{Binding AuthorsView}" 
                                  DisplayMemberPath="AuthorName" 
                                  Text="{Binding SearchAuthorText, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedItem="{Binding SelectedAuthor}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,10,0" Height="35"/>

                        <ui:Button Grid.Column="1"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Content="Add"
                                   Appearance="Primary"
                                   Command="{Binding AddAuthorCommand}"
                                   Background="{DynamicResource NavyLightBrush}" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Visibility="{Binding IsShowAddButton, Converter={StaticResource BoolToVis}}" 
                                   Height="35" Cursor="Hand"/>
                    </Grid>

                    <TextBlock Text="Quantity" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    <ui:TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. 50" 
                                Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource NavyLightBrush}" Padding="10,8"/>

                    <TextBlock Text="Cover Image" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0" Text="{Binding LocalImagePath}" IsReadOnly="True" PlaceholderText="No image selected..." 
                                    Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource NavyLightBrush}" Margin="0,0,10,0" Padding="10,8"/>
                        <ui:Button Grid.Column="1" Content="Browse" Command="{Binding SelectImageCommand}" 
                                   Appearance="Primary" Foreground="{DynamicResource TextPrimaryBrush}" 
                                   Background="{DynamicResource NavyLightBrush}" 
                                   Cursor="Hand"/>
                    </Grid>

                    <Border BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1" CornerRadius="8" 
                            Width="140" Height="190" HorizontalAlignment="Center" 
                            Background="{DynamicResource SidebarBackgroundBrush}" Margin="0,10,0,0">
                        <Image Source="{Binding LocalImagePath}" Stretch="Uniform" Margin="2"/>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <ui:ProgressRing IsIndeterminate="True" 
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" 
                                     HorizontalAlignment="Left" Width="24" Height="24" Foreground="{DynamicResource NavyAccentBrush}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="Cancel" Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                                   Appearance="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand" Margin="0,0,15,0"/>

                        <ui:Button Content="Save Book" Command="{Binding SaveCommand}" 
                                   Appearance="Primary" Background="{DynamicResource NavyAccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" Cursor="Hand" Width="120" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>