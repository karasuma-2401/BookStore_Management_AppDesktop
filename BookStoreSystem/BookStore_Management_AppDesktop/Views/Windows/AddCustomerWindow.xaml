<Window
    x:Class="BookStore_Management_AppDesktop.Views.Windows.AddCustomerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Add New Customer"
    Width="500"
    Height="400"
    Background="{DynamicResource SidebarBackgroundBrush}" 
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="30,20" Background="{DynamicResource ContentBackgroundBrush}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,10"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="Add New Customer" />

                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Full Name *" />
                    <ui:TextBox x:Name="NameTextBox" PlaceholderText="Enter customer name" />
                </StackPanel>

                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Phone" />
                    <ui:TextBox x:Name="PhoneTextBox" PlaceholderText="Enter phone number" />
                </StackPanel>

                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Email" />
                    <ui:TextBox x:Name="EmailTextBox" PlaceholderText="Enter email address" />
                </StackPanel>

                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="Address" />
                    <ui:TextBox x:Name="AddressTextBox" Height="80" AcceptsReturn="True" PlaceholderText="Enter address" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border
                Grid.Row="1"
                Padding="30,20"
                Background="{DynamicResource ContentBackgroundBrush}" 
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <ui:Button
                    x:Name="CancelButton"
                    Width="100"
                    Margin="0,0,12,0"
                    Appearance="Primary"
                    Click="CancelButton_Click"
                    Content="Cancel" />

                <ui:Button
                    x:Name="SaveButton"
                    Width="100"
                    Appearance="Primary"
                    Click="SaveButton_Click"
                    Content="Save"
                    Icon="{ui:SymbolIcon Save24}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>