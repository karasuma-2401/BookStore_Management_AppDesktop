<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.AvatarEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        x:Name="AvatarWindow"
        Height="650" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <!-- Card container -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="20" BorderBrush="{DynamicResource SidebarAccentBrush}" BorderThickness="1">
            <Grid>
                <!-- Close Button góc trên bên phải -->
                <ui:Button Content="✕"
                           Width="50" Height="50"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Margin="0,5,15,0"
                           Appearance="Secondary"
                           CornerRadius="15"
                           Background="Transparent"
                           BorderThickness="0"
                           Command="{Binding CloseWindowCommand}"
                           CommandParameter="{Binding ElementName=AvatarWindow}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.6"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

                <StackPanel Margin="25">
                    <!-- Title -->
                    <TextBlock Text="Update Avatar" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Avatar Preview -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Ellipse Width="160" Height="160" Stroke="{DynamicResource SidebarAccentBrush}" StrokeThickness="3"/>
                        <Ellipse Width="148" Height="148">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding TempAvatarPath, TargetNullValue='/Resources/Images/Promise Me.webp'}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>

                    <!-- Upload from computer -->
                    <ui:Button Content="Choose from Computer"
                               Command="{Binding UploadFromComputerCommand}"
                               HorizontalAlignment="Stretch"
                               Appearance="Primary"
                               CornerRadius="10"/>

                    <!-- Avatar list -->
                    <TextBlock Text="Select from available avatars:" Margin="0,20,0,10" Foreground="{DynamicResource TextSecondBrush}"/>
                    <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Padding="5">
                        <ScrollViewer Height="180" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DefaultAvatars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Button Appearance="Transparent" Margin="5" 
                                                   Command="{Binding DataContext.SelectDefaultAvatarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}">
                                            <Ellipse Width="70" Height="70">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </ui:Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Buttons Save-->
                    <Grid Margin="0,25,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Save Button -->
                        <ui:Button Grid.Column="1"
                                   Content="Save Changes"
                                   Appearance="Primary"
                                   CornerRadius="10"
                                   HorizontalAlignment="Stretch"
                                   Margin="5,0,0,10"
                                   Command="{Binding SaveAvatarChangeCommand}"
                                   CommandParameter="{Binding ElementName=AvatarWindow}"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>