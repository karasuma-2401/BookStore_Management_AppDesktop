<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.AvatarEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        x:Name="AvatarWindow"
        Height="650" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Border Background="{DynamicResource NavyPrimaryBrush}" 
                CornerRadius="20" 
                BorderBrush="{DynamicResource TextSecondaryBrush}" 
                BorderThickness="1.5">
            <Grid>
                <StackPanel Margin="25">
                    <TextBlock Text="Update Avatar" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Ellipse Width="160" Height="160" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2"/>
                        <Ellipse Width="148" Height="148">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding TempAvatarPath, TargetNullValue='/Resources/Images/Promise Me.webp'}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>

                    <ui:Button Content="Choose from Computer"
                               Command="{Binding UploadFromComputerCommand}"
                               HorizontalAlignment="Stretch"
                               Appearance="Primary"
                               Height="42"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Background="{DynamicResource NavyLightBrush}"
                               BorderBrush="{DynamicResource TextSecondaryBrush}" 
                               BorderThickness="1.2"
                               CornerRadius="8"/>

                    <TextBlock Text="Select from available avatars:" Margin="0,20,0,10" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium"/>

                    <Border Background="{DynamicResource ContentBackgroundBrush}" 
                            CornerRadius="12" 
                            Padding="8"
                            BorderBrush="{DynamicResource TextSecondaryBrush}" 
                            BorderThickness="1.5">
                        <ScrollViewer Height="180" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DefaultAvatars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Button Appearance="Transparent" Margin="5" Padding="2"
                                                   Command="{Binding DataContext.SelectDefaultAvatarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}">
                                            <Ellipse Width="70" Height="70" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </ui:Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Margin="0,25,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button Content="Cancel"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       BorderBrush="{DynamicResource TextSecondaryBrush}"
                                       BorderThickness="1"
                                       Margin="0,0,10,10"
                                       Padding="15,0"
                                       Command="{Binding CloseWindowCommand}" CommandParameter="{Binding ElementName=AvatarWindow}"
                                       Height="30"/>

                            <ui:Button Content="Save Changes"
                                       Width="150" Height="30"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Background="{DynamicResource NavyAccentBrush}"
                                       BorderBrush="{DynamicResource TextSecondaryBrush}"
                                       BorderThickness="1.2"
                                       Appearance="Primary"
                                       CornerRadius="8"
                                       Margin="0,0,0,10"
                                       Command="{Binding SaveAvatarChangeCommand}"
                                       CommandParameter="{Binding ElementName=AvatarWindow}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>