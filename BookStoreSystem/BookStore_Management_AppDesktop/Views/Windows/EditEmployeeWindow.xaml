<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.EditEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Title="Edit Employee" Height="650" Width="400">
    <Grid Margin="15">
        <Border CornerRadius="15" Background="Black">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.5" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="15" BorderBrush="{DynamicResource NavyLightBrush}" BorderThickness="1" Background="{DynamicResource NavyPrimaryBrush}">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25" 
                            MouseLeftButtonDown="Header_MouseLeftButtonDown" Cursor="SizeAll" Background="Transparent">
                    <TextBlock Text="EDIT EMPLOYEE" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Modify staff details" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Employee ID" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,5,0,5"/>
                    <ui:TextBox Text="{Binding DisplayEmployeeId, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Margin="0,0,0,15"/>

                    <TextBlock Text="Full Name" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter full name..." Margin="0,0,0,10"/>

                    <TextBlock Text="Age" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding Age, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" PlaceholderText="Enter age..." Margin="0,0,0,10"/>

                    <TextBlock Text="Phone" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter phone number..." Margin="0,0,0,10"/>

                    <TextBlock Text="Address" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Enter address..." Margin="0,0,0,10"/>

                    <TextBlock Text="Salary" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ui:TextBox Text="{Binding Salary, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" PlaceholderText="Enter salary..." Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2">
                    <ui:Button Content="Cancel" Command="{Binding CancelCommand}" 
                               Appearance="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,15,0"/>

                    <ui:Button Content="Update" Command="{Binding SaveCommand}" 
                               Appearance="Primary" Background="{DynamicResource NavyAccentBrush}" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>