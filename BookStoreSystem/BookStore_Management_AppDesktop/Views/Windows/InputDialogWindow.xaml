<Window x:Class="BookStore_Management_AppDesktop.Views.Windows.InputDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{Binding WindowTitle, RelativeSource={RelativeSource Self}}" 
        Height="180" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow"
        Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="MessageLabel" Text="Input:" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource TextOnLightBackgroudBrush}"/>

        <ui:TextBox Grid.Row="1" x:Name="InputTxt" VerticalAlignment="Top" GotFocus="InputTxt_GotFocus"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <ui:Button Content="Cancel" Click="Cancel_Click" Margin="0,0,10,0" Appearance="Secondary" Width="80"/>
            <ui:Button Content="OK" Click="Ok_Click" Appearance="Primary" Width="80" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>