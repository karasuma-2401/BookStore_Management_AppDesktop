<Window
    x:Class="BookStore_Management_AppDesktop.Views.Windows.BookDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Book Details"
    Width="750"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Padding="25" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.04" ShadowDepth="4" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Margin="0,0,15,0" Background="#E0F2FE" CornerRadius="8">
                            <ui:SymbolIcon FontSize="20" Foreground="#0284C7" Symbol="BookOpen24" />
                        </Border>
                        <TextBlock VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#0F172A" Text="Book Information" />
                    </StackPanel>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Click="CloseButton_Click" ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="32" Height="32" Background="Transparent" CornerRadius="16" x:Name="BtnBg">
                                    <ui:SymbolIcon FontSize="14" Foreground="#94A3B8" Symbol="Dismiss24" x:Name="Icon"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBg" Property="Background" Value="#F1F5F9"/>
                                        <Setter TargetName="Icon" Property="Foreground" Value="#0F172A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" VerticalAlignment="Top" Height="300" x:Name="ImageCard">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="4" Color="#0F172A" Direction="270"/>
                        </Border.Effect>
                        <Border Background="#F8FAFC" BorderBrush="#0F172A" BorderThickness="1" CornerRadius="8" Padding="1" ClipToBounds="True">
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"
                                   Source="{Binding CurrentDetailBook.ImagePath, TargetNullValue='https://via.placeholder.com/190x270?text=No+Image', FallbackValue='https://via.placeholder.com/190x270?text=No+Image'}" />
                        </Border>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}" Text="Book Title" />
                            <TextBox Text="{Binding CurrentDetailBook.Title, Mode=OneWay}" Style="{StaticResource FormTextBoxStyle}" FontWeight="Bold"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <ui:TextBlock Style="{StaticResource FormLabelStyle}" Text="Book ID" />
                                <TextBox Text="{Binding CurrentDetailBook.BookId, Mode=OneWay, StringFormat='#{0}'}" Style="{StaticResource FormTextBoxStyle}" Foreground="#64748B"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <ui:TextBlock Style="{StaticResource FormLabelStyle}" Text="Publish Year" />
                                <TextBox Text="{Binding CurrentDetailBook.PublishYear, Mode=OneWay, TargetNullValue='N/A'}" Style="{StaticResource FormTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}" Text="Authors" />
                            <TextBox Text="{Binding CurrentDetailBook.DisplayAuthorNames, Mode=OneWay}" Style="{StaticResource FormTextBoxStyle}" Foreground="#0078D4" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}" Text="Categories" />
                            <TextBox Text="{Binding CurrentDetailBook.DisplayCategoryNames, Mode=OneWay}" Style="{StaticResource FormTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,5">
                            <ui:TextBlock Style="{StaticResource FormLabelStyle}" Text="Book Summary" />
                            <TextBox Text="{Binding CurrentDetailBook.Description, Mode=OneWay, TargetNullValue='There are no descriptions for this book.'}" 
                                     Height="80" VerticalContentAlignment="Top" Padding="12,8" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource FormTextBoxStyle}" FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Padding="0,15,0,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,2" Text="Total Price"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="24" FontWeight="Black" Foreground="#0F172A" 
                                           Text="{Binding TotalPrice, StringFormat='{}{0:#,0}', TargetNullValue='0'}" />
                                <TextBlock Margin="2,0,0,3" VerticalAlignment="Bottom" FontSize="14" FontWeight="Black" Foreground="#0078D4" Text="VND" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#F0F9FF" CornerRadius="24" Padding="4" Margin="0,0,15,0" Height="48">
                                <StackPanel Orientation="Horizontal">
                                    <Button Width="36" Height="36" Command="{Binding DecreaseQuantityCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                    <ui:SymbolIcon FontSize="12" Foreground="#0284C7" Symbol="Subtract24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <TextBlock Width="34" VerticalAlignment="Center" FontSize="16" FontWeight="Black" Foreground="#0F172A" 
                                               Text="{Binding SelectedQuantity}" TextAlignment="Center" />

                                    <Button Width="36" Height="36" Command="{Binding IncreaseQuantityCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                    <ui:SymbolIcon FontSize="12" Foreground="#0284C7" Symbol="Add24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Button Width="48" Height="48" Command="{Binding AddToCartCommand}" Click="AddToCartButton_Click" ToolTip="Add to Cart">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0078D4" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform X="0" Y="0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="24">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="12" Opacity="0.2" ShadowDepth="4" Direction="270" Color="#0078D4"/>
                                                        </Border.Effect>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BgBorder" Property="Background" Value="#005A9E" />
                                                            <Setter TargetName="BgBorder" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270" Color="#0078D4"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TranslateTransform X="0" Y="-4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <Grid Width="24" Height="24" Margin="0,0,2,0">
                                    <ui:SymbolIcon Symbol="Cart24" FontSize="22" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                                    <ui:SymbolIcon Symbol="Add24" FontSize="12" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>