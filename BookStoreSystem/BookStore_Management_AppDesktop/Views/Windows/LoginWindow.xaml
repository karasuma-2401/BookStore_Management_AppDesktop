<ui:FluentWindow
    x:Class="BookStore_Management_AppDesktop.Views.Windows.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:BookStore_Management_AppDesktop.ViewModels"
    Title="Book Store Login"
    Width="1100"
    Height="700"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="None"
    WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.DataContext>
        <viewmodels:LoginViewModel />
    </ui:FluentWindow.DataContext>

    <Grid>
        <Border Background="{DynamicResource NavyPrimaryBrush}" />

        <ItemsControl
            Grid.Column="0"
            Margin="-50"
            ItemsSource="{Binding CarouselBooks}"
            Opacity="0.65">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Image
                        Width="140"
                        Height="200"
                        Margin="15"
                        Source="{Binding}"
                        Stretch="UniformToFill">
                        <Image.Clip>
                            <RectangleGeometry
                                RadiusX="10"
                                RadiusY="10"
                                Rect="0,0,140,200" />
                        </Image.Clip>
                    </Image>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border
            Grid.Column="1"
            Width="420"
            Height="520"
            Margin="15,0,15,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderBrush="#4DFFFFFF"
            BorderThickness="2"
            CornerRadius="24">
            <Border.Background>
                <SolidColorBrush Opacity="0.65" Color="#0F172A" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="40"
                    Opacity="0.65"
                    ShadowDepth="15"
                    Color="Black" />
            </Border.Effect>
            <StackPanel Margin="40,50,40,40" VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    FontSize="42"
                    FontWeight="ExtraBold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Text="LOGIN" />
                <TextBlock
                    Margin="0,0,0,40"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="{DynamicResource TextSecondBrush}"
                    Text="Book Store Management System" />

                <ui:TextBox
                    Margin="0,0,0,20"
                    Padding="12"
                    FontSize="15"
                    Icon="Person24"
                    PlaceholderText="Username"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <ui:PasswordBox
                    Margin="0,0,0,35"
                    Padding="12"
                    FontSize="15"
                    Icon="Key24"
                    Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Password" />

                <ui:Button
                    Padding="0,14"
                    HorizontalAlignment="Stretch"
                    Appearance="Primary"
                    Background="{DynamicResource NavyAccentBrush}"
                    Command="{Binding LoginCommand}"
                    Content="Log in"
                    CornerRadius="8"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="{DynamicResource NavyPrimaryBrush}" />

                <StackPanel
                    Margin="0,35,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource TextSecondBrush}"
                        Text="Don't have an account? " />
                    <ui:Button
                        Padding="5,0"
                        Appearance="Transparent"
                        Command="{Binding NavigateToSignUpCommand}"
                        Content="Sign up now"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource NavyAccentBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>