<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.BookDetailPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="900"
    d:DesignWidth="420"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="NativeBoolToVis" />

        <Style x:Key="MobileTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="Margin" Value="0,0,15,0" />
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#475569" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#0F172A" />
                    <Setter Property="BorderBrush" Value="#0F172A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Width="420" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.04" ShadowDepth="4" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="25,20" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Border Width="40" Height="40" Margin="0,0,15,0" Background="#F3E8FF" CornerRadius="8">
                            <ui:SymbolIcon FontSize="20" Foreground="#9333EA" Symbol="BookOpen24" />
                        </Border>
                        <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Text="Book Details" />
                    </StackPanel>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding CloseDetailPanelCommand}" ToolTip="Close Panel">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Width" Value="32" />
                                <Setter Property="Height" Value="32" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                                <ui:SymbolIcon FontSize="14" Symbol="Dismiss24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F1F5F9" />
                                        <Setter Property="Foreground" Value="#0F172A" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
                <StackPanel>

                    <Separator Background="#E2E8F0" Height="1" Margin="0,0,0,25"/>

                    <Border Width="190" Height="270" Margin="0,0,0,25" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="25" Opacity="0.1" ShadowDepth="6" Color="#0F172A" Direction="270"/>
                        </Border.Effect>
                        <Border Background="White" BorderBrush="#0F172A" BorderThickness="1" CornerRadius="10" Padding="1" ClipToBounds="True">
                            <Image RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"
                                   Source="{Binding CurrentDetailBook.ImagePath, TargetNullValue='https://via.placeholder.com/190x270?text=No+Image', FallbackValue='https://via.placeholder.com/190x270?text=No+Image'}" />
                        </Border>
                    </Border>

                    <Separator Background="#E2E8F0" Height="1" Margin="0,5,0,20"/>

                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"
                               FontSize="22" FontWeight="Black" Foreground="#0F172A"
                               Text="{Binding CurrentDetailBook.Title}" TextWrapping="Wrap" />

                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,10" FontSize="14" FontWeight="SemiBold" Foreground="#0078D4">
                        <Run Text="{Binding CurrentDetailBook.DisplayAuthorNames, TargetNullValue='Unknown Author'}"/>
                    </TextBlock>

                    <TextBlock HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,5"
                               Text="{Binding CurrentDetailBook.PublishYear, StringFormat='Published {0}', TargetNullValue='N/A'}" />

                    <Separator Background="#E2E8F0" Height="1" Margin="0,20,0,20"/>

                    <TabControl Background="Transparent" BorderThickness="0" Margin="0,5,0,0">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid KeyboardNavigation.TabNavigation="Local">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TabPanel x:Name="HeaderPanel" Grid.Row="0" IsItemsHost="True" HorizontalAlignment="Center" KeyboardNavigation.TabIndex="1" />
                                    <ContentPresenter x:Name="PART_SelectedContentHost" Grid.Row="1" ContentSource="SelectedContent" KeyboardNavigation.TabIndex="2" />
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>

                        <TabItem Style="{StaticResource MobileTabItemStyle}" Header="About Book">
                            <StackPanel Margin="0,20,0,0" Width="330" HorizontalAlignment="Center">
                                <TextBlock Text="Genres &amp; Categories" FontSize="15" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentDetailBook.DisplayCategoryNames, TargetNullValue='Uncategorized'}" 
                                           FontSize="14" LineHeight="22" Foreground="#475569" TextWrapping="Wrap" Margin="0,0,0,18"/>

                                <TextBlock Text="Book Identity" FontSize="15" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentDetailBook.BookId, StringFormat='ID: #{0}'}" 
                                           FontSize="14" Foreground="#475569"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Style="{StaticResource MobileTabItemStyle}" Header="Summary">
                            <StackPanel Margin="0,20,0,0" Width="330" HorizontalAlignment="Center">
                                <TextBlock Text="About Book this eBook" FontSize="15" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,10"/>
                                <TextBlock FontSize="13" LineHeight="22" Foreground="#475569" TextWrapping="Wrap"
                                           Text="{Binding CurrentDetailBook.Description, TargetNullValue='There are no descriptions or reviews for this book yet.'}" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#FFFFFF" Padding="25,20" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,2" Text="Total Price"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="22" FontWeight="Black" Foreground="#0F172A" 
                                       Text="{Binding TotalPrice, StringFormat='{}{0:#,0}', TargetNullValue='0'}" />
                            <TextBlock Margin="2,0,0,3" VerticalAlignment="Bottom" FontSize="14" FontWeight="Black" Foreground="#0078D4" Text="đ" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#F0F9FF" CornerRadius="28" Padding="6" Margin="0,0,15,0" Height="56">
                            <StackPanel Orientation="Horizontal">
                                <Button Width="40" Height="40" Command="{Binding DecreaseQuantityCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                                <ui:SymbolIcon FontSize="14" Foreground="#0284C7" Symbol="Subtract24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <TextBlock Width="36" VerticalAlignment="Center" FontSize="18" FontWeight="Black" Foreground="#0F172A" 
                                           Text="{Binding SelectedQuantity}" TextAlignment="Center" />

                                <Button Width="40" Height="40" Command="{Binding IncreaseQuantityCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                                <ui:SymbolIcon FontSize="14" Foreground="#0284C7" Symbol="Add24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button Width="56" Height="56" Command="{Binding AddToCartCommand}" ToolTip="Add to Cart">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#0078D4" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform X="0" Y="0"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="28">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="12" Opacity="0.2" ShadowDepth="4" Direction="270" Color="#0078D4"/>
                                                    </Border.Effect>
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BgBorder" Property="Background" Value="#005A9E" />
                                                        <Setter TargetName="BgBorder" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270" Color="#0078D4"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="BgBorder" Property="Background" Value="#004578" />
                                                        <Setter TargetName="BgBorder" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="4" Opacity="0.2" ShadowDepth="2" Direction="270" Color="#0078D4"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="0" Y="-4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform X="0" Y="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <Grid Width="28" Height="28" Margin="0,0,2,0">
                                <ui:SymbolIcon Symbol="Cart24" FontSize="26" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                                <ui:SymbolIcon Symbol="Add24" FontSize="14" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.RowSpan="2" Background="White" Opacity="0.95"
                  Visibility="{Binding IsDetailLoading, Converter={StaticResource NativeBoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:ProgressRing Width="36" Height="36" Margin="0,0,0,12" IsIndeterminate="True" />
                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Text="Fetching book details..." />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>