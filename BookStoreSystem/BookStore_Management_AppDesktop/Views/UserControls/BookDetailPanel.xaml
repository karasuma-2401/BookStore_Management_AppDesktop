<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.BookDetailPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="900"
    d:DesignWidth="420"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="NativeBoolToVis" />
    </UserControl.Resources>

    <Border
        Width="420"
        Background="{DynamicResource SidebarBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1,0,0,0">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Opacity="0.2"
                ShadowDepth="-3"
                Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="20,15"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        Style="{StaticResource HeaderTextStyle}"
                        Text="BOOK DETAILS" />
                    <Button
                        HorizontalAlignment="Right"
                        Command="{Binding CloseDetailPanelCommand}"
                        ToolTip="Close Panel">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Width" Value="32" />
                                <Setter Property="Height" Value="32" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Foreground" Value="#A0AABF" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E81123" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#F1707A" />
                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <ui:SymbolIcon
                            FontSize="14"
                            FontWeight="SemiBold"
                            Symbol="Dismiss24" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer
                Grid.Row="1"
                Padding="20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border
                        Width="220"
                        Height="300"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        ClipToBounds="True"
                        CornerRadius="8">
                        <Image
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="{Binding CurrentDetailBook.ImagePath, TargetNullValue='https://via.placeholder.com/220x300?text=No+Image', FallbackValue='https://via.placeholder.com/220x300?text=No+Image'}"
                            Stretch="UniformToFill" />
                    </Border>

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,0,0,12"
                        FontSize="22"
                        FontWeight="Black"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Style="{StaticResource BookTitleTextStyle}"
                        Text="{Binding CurrentDetailBook.Title}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Style="{StaticResource BodyTextStyle}">
                        <Run Foreground="{DynamicResource TextSecondBrush}" Text="Author: " />
                        <Run
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource SidebarAccentBrush}"
                            Text="{Binding CurrentDetailBook.AuthorName, TargetNullValue='Updating Author'}" />
                    </TextBlock>

                    <TextBlock
                        Margin="0,0,0,20"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Style="{StaticResource BodyTextStyle}">
                        <Run Foreground="{DynamicResource TextSecondBrush}" Text="Categories: " />
                        <Run
                            FontStyle="Italic"
                            FontWeight="Medium"
                            Foreground="{DynamicResource TextSecondBrush}"
                            Text="{Binding CurrentDetailBook.CategoryNames}" />
                    </TextBlock>

                    <Border
                        Margin="0,0,0,25"
                        Padding="15,12"
                        Background="#1E293B"
                        BorderBrush="White"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <TextBlock
                                FontSize="28"
                                FontWeight="Black"
                                Foreground="White"
                                Style="{StaticResource PriceTextStyle}"
                                Text="{Binding CurrentDetailBook.Price, StringFormat='{}{0:#,0}', TargetNullValue='0'}" />
                            <TextBlock
                                Margin="4,0,0,3"
                                VerticalAlignment="Bottom"
                                FontSize="18"
                                FontWeight="Black"
                                Foreground="#FF4D4F"
                                Text="đ" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock
                                Margin="0,0,0,3"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="Purchase Quantity" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="{DynamicResource TextSecondBrush}"
                                    Text="In Stock: " />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#0078D4"
                                    Text="{Binding CurrentDetailBook.Quantity}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">

                            <Button Command="{Binding DecreaseQuantityCommand}" ToolTip="Decrease Quantity">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Width" Value="32" />
                                        <Setter Property="Height" Value="32" />
                                        <Setter Property="Background" Value="#334155" />
                                        <Setter Property="Foreground" Value="#F8FAFC" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#475569" />
                                                <Setter Property="Foreground" Value="#FFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#1E293B" />
                                                <Setter Property="Foreground" Value="#94A3B8" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ui:SymbolIcon
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Symbol="Subtract24" />
                            </Button>

                            <TextBlock
                                Width="40"
                                Margin="6,0"
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="#FFFFFF"
                                Text="{Binding SelectedQuantity}"
                                TextAlignment="Center" />

                            <Button Command="{Binding IncreaseQuantityCommand}" ToolTip="Increase Quantity">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Width" Value="32" />
                                        <Setter Property="Height" Value="32" />
                                        <Setter Property="Background" Value="#334155" />
                                        <Setter Property="Foreground" Value="#F8FAFC" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#475569" />
                                                <Setter Property="Foreground" Value="#FFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#1E293B" />
                                                <Setter Property="Foreground" Value="#F8FAFC" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ui:SymbolIcon
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Symbol="Add24" />
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Button
                        Height="42"
                        Margin="0,0,0,25"
                        HorizontalAlignment="Stretch"
                        Command="{Binding AddToCartCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0078D4" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#106EBE" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#005A9E" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Symbol="Cart24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="Bold"
                                Text="ADD TO BASKET" />
                        </StackPanel>
                    </Button>

                    <Separator
                        Margin="0,0,0,15"
                        Background="{DynamicResource BorderBrush}"
                        Opacity="0.4" />

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Style="{StaticResource BookTitleTextStyle}"
                        Text="BOOK SUMMARY" />
                    <TextBlock
                        FontSize="14"
                        Style="{StaticResource BodyTextStyle}"
                        Text="{Binding CurrentDetailBook.Description, TargetNullValue='There are no descriptions or reviews for this book yet.'}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <Grid
                Grid.Row="1"
                Background="{DynamicResource SidebarBackgroundBrush}"
                Opacity="0.8"
                Visibility="{Binding IsDetailLoading, Converter={StaticResource NativeBoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:ProgressRing
                        Width="40"
                        Height="40"
                        Margin="0,0,0,10"
                        IsIndeterminate="True" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource TextSecondBrush}"
                        Text="Fetching book details..." />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>