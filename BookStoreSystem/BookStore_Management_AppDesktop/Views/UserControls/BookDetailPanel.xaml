<UserControl x:Class="BookStore_Management_AppDesktop.Views.UserControls.BookDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="NativeBoolToVis" />
    </UserControl.Resources>

    <Border Background="{DynamicResource SidebarBackgroundBrush}" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1,0,0,0"
            Width="420">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="15" ShadowDepth="-3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,15">
                <Grid>
                    <TextBlock Text="QUICK VIEW" Style="{StaticResource HeaderTextStyle}" FontSize="16" VerticalAlignment="Center"/>
                    <ui:Button Icon="{ui:SymbolIcon Dismiss24}" 
                               Command="{Binding CloseDetailPanelCommand}" 
                               Appearance="Transparent" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Right"
                               Padding="8" Cursor="Hand" ToolTip="Close Panel"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>
                    <Border CornerRadius="8" ClipToBounds="True" Margin="0,0,0,20" 
                            Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            HorizontalAlignment="Center" Width="220" Height="300">
                        <Image Source="{Binding CurrentDetailBook.ImagePath, TargetNullValue='https://via.placeholder.com/220x300?text=No+Image', FallbackValue='https://via.placeholder.com/220x300?text=No+Image'}" 
                               Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="{Binding CurrentDetailBook.Title}" 
                               Style="{StaticResource BookTitleTextStyle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="Black" 
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <TextBlock Margin="0,0,0,12" FontSize="13" Style="{StaticResource BodyTextStyle}">
                        <Run Text="Author: " Foreground="{DynamicResource TextSecondBrush}"/>
                        <Run Text="{Binding CurrentDetailBook.AuthorName, TargetNullValue='Updating Author'}" 
                             FontWeight="SemiBold" Foreground="{DynamicResource SidebarAccentBrush}"/>
                    </TextBlock>

                    <TextBlock Margin="0,0,0,20" FontSize="13" Style="{StaticResource BodyTextStyle}">
                        <Run Text="Categories: " Foreground="{DynamicResource TextSecondBrush}"/>
                        <Run Text="{Binding CurrentDetailBook.CategoryNames}" 
                             FontWeight="Medium" FontStyle="Italic" Foreground="{DynamicResource TextSecondBrush}"/>
                    </TextBlock>

                    <Border Background="#1E293B" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15,10" Margin="0,0,0,25">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentDetailBook.Price, StringFormat='{}{0:#,0}', TargetNullValue='0'}" 
                                       Style="{StaticResource PriceTextStyle}"
                                       FontSize="28" FontWeight="Black" Foreground="{DynamicResource SuccessPrimaryBrush}"/>
                            <TextBlock Text=" đ" FontSize="18" FontWeight="Black" Foreground="{DynamicResource SidebarAccentBrush}" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Purchase Quantity" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextSecondBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Purchase Quantity" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextSecondBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource NavyLightBrush}" CornerRadius="8" Padding="4">
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="−" Padding="14,6" Appearance="Transparent" Foreground="White"
                                           Command="{Binding DecreaseQuantityCommand}" FontSize="14" FontWeight="Bold"/>
                                <Rectangle Width="1" Margin="4,0" Fill="White" Opacity="0.2"/>
                                <TextBlock Text="{Binding SelectedQuantity}" Width="45" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextAlignment="Center" FontWeight="Bold" FontSize="15" Foreground="White"/>
                                <Rectangle Width="1" Margin="4,0" Fill="White" Opacity="0.2"/>
                                <ui:Button Content="+" Padding="14,6" Appearance="Transparent" Foreground="White"
                                           Command="{Binding IncreaseQuantityCommand}" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="13" Foreground="{DynamicResource TextSecondBrush}">
                            <Run Text="In Stock: "/>
                            <Run Text="{Binding CurrentDetailBook.Quantity}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </TextBlock>
                    </Grid>
                    <ui:Button Content="ADD TO BASKET" Icon="{ui:SymbolIcon Cart24}" 
                               Style="{StaticResource PrimaryActionButtonStyle}"
                               Command="{Binding AddToCartCommand}" 
                               HorizontalAlignment="Stretch" Height="45" Margin="0,0,0,25"/>

                    <Separator Margin="0,0,0,15" Background="{DynamicResource BorderBrush}" Opacity="0.4"/>

                    <TextBlock Text="BOOK SUMMARY" Style="{StaticResource BookTitleTextStyle}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding CurrentDetailBook.Description, TargetNullValue='There are no descriptions or reviews for this book yet.'}" 
                               Style="{StaticResource BodyTextStyle}" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1" Background="{DynamicResource SidebarBackgroundBrush}" Opacity="0.8"
                  Visibility="{Binding IsDetailLoading, Converter={StaticResource NativeBoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" Margin="0,0,0,10"/>
                    <TextBlock Text="Fetching book details..." FontSize="12" Foreground="{DynamicResource TextSecondBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>