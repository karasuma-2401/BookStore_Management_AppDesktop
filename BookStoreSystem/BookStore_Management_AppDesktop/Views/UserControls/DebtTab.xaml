<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.DebtTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <Style x:Key="CustomDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Padding" Value="15,0,10,0" />
            <Setter Property="Height" Value="45" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="CustomDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border
                            Padding="15,0,10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="CustomDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F4F7F9" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0F2FE" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,20,0,0">
        <Border
            Padding="15"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.03"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>

            <ui:DataGrid
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CanUserAddRows="False"
                CellStyle="{StaticResource CustomDataGridCellStyle}"
                ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}"
                Foreground="#1E293B"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#E2E8F0"
                IsReadOnly="True"
                ItemsSource="{Binding DebtReports}"
                RowHeight="55"
                RowStyle="{StaticResource CustomDataGridRowStyle}">
                <ui:DataGrid.Columns>
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding ReportId}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Report ID" />
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding CustomerId}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Customer ID" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding OpeningDebt, StringFormat='{}{0:N0} đ'}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Opening Debt" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ChangeAmount, StringFormat='{}{0:N0} đ'}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Change" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ClosingDebt, StringFormat='{}{0:N0} đ'}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Closing Debt" />
                    <DataGridTemplateColumn Width="150" Header="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="12,6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    CornerRadius="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FEE2E2" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ClosingDebt}" Value="0">
                                                    <Setter Property="Background" Value="#DCFCE7" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="12" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#EF4444" />
                                                <Setter Property="Text" Value="In Debt" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClosingDebt}" Value="0">
                                                        <Setter Property="Foreground" Value="#16A34A" />
                                                        <Setter Property="Text" Value="Cleared" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Border>
    </Grid>
</UserControl>