<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.DebtTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BookStore_Management_AppDesktop.Converters"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <conv:NumberSignConverter x:Key="NumberSignConverter" />

        <Style x:Key="CustomDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Padding" Value="15,0,10,0" />
            <Setter Property="Height" Value="45" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style
            x:Key="CenterDataGridHeaderStyle"
            BasedOn="{StaticResource CustomDataGridHeaderStyle}"
            TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,0,0,0" />
        </Style>

        <Style
            x:Key="RightDataGridHeaderStyle"
            BasedOn="{StaticResource CustomDataGridHeaderStyle}"
            TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Padding" Value="0,0,20,0" />
        </Style>

        <Style x:Key="CustomDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border
                            Padding="15,0,10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F4F7F9" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0F2FE" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0F2FE" />
                    <Setter Property="BorderBrush" Value="#0078D4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style
            x:Key="CenterGridTextStyle"
            BasedOn="{StaticResource DataGridTextStyle}"
            TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DataGridCurrencyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,20,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Border
                    Width="40"
                    Height="40"
                    Margin="0,0,12,0"
                    Background="#F3E8FF"
                    CornerRadius="8">
                    <ui:SymbolIcon
                        FontSize="20"
                        Foreground="#9333EA"
                        Symbol="Receipt24" />
                </Border>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#0F172A">
                    <Run Text="Customer Debt Overview (" />
                    <Run Text="{Binding SelectedMonth}" />
                    <Run Text="/" />
                    <Run Text="{Binding SelectedYear}" />
                    <Run Text=")" />
                </TextBlock>
            </StackPanel>

            <Border
                Grid.Column="1"
                Padding="6"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <ui:SymbolIcon
                        Margin="10,0,8,0"
                        FontSize="18"
                        Foreground="#64748B"
                        Symbol="CalendarLtr24" />

                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Foreground="#64748B"
                        Text="Month" />
                    <ComboBox
                        Width="70"
                        Height="32"
                        Margin="0,0,15,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1.5"
                        Foreground="#0F172A"
                        ItemsSource="{Binding Months}"
                        SelectedItem="{Binding SelectedMonth}" />

                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Foreground="#64748B"
                        Text="Year" />
                    <ComboBox
                        Width="80"
                        Height="32"
                        Margin="0,0,15,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1.5"
                        Foreground="#0F172A"
                        ItemsSource="{Binding Years}"
                        SelectedItem="{Binding SelectedYear}" />

                    <Button
                        Height="35"
                        Padding="15,0"
                        Background="#0078D4"
                        BorderThickness="0"
                        Command="{Binding GenerateReportCommand}"
                        Cursor="Hand"
                        Foreground="#FFFFFF">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <ui:SymbolIcon
                                            Margin="0,0,6,0"
                                            FontSize="16"
                                            Foreground="#FFFFFF"
                                            Symbol="Filter24" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="Filter" />
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#106EBE" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="15"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.03"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>
            <ui:DataGrid
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserReorderColumns="False"
                CellStyle="{StaticResource CustomDataGridCellStyle}"
                ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}"
                Foreground="#1E293B"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#E2E8F0"
                IsReadOnly="True"
                ItemsSource="{Binding DebtReports}"
                LoadingRow="DataGrid_LoadingRow"
                RowHeight="50"
                RowStyle="{StaticResource CustomDataGridRowStyle}">
                <ui:DataGrid.Columns>
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"
                        ElementStyle="{StaticResource CenterGridTextStyle}"
                        Header="No."
                        HeaderStyle="{StaticResource CenterDataGridHeaderStyle}" />

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding CustomerId}"
                        ElementStyle="{StaticResource CenterGridTextStyle}"
                        Header="Customer Id"
                        HeaderStyle="{StaticResource CenterDataGridHeaderStyle}" />

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding OpeningDebt, StringFormat='{}{0:N0} đ'}"
                        ElementStyle="{StaticResource DataGridCurrencyStyle}"
                        Header="Opening Debt"
                        HeaderStyle="{StaticResource RightDataGridHeaderStyle}" />

                    <DataGridTemplateColumn
                        Width="*"
                        Header="Change Amount"
                        HeaderStyle="{StaticResource RightDataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="0,0,20,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="{Binding ChangeAmount, StringFormat='{}{0:N0} đ'}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E293B" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ChangeAmount, Converter={StaticResource NumberSignConverter}, ConverterParameter='Positive'}" Value="True">
                                                    <Setter Property="Foreground" Value="#EF4444" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ChangeAmount, Converter={StaticResource NumberSignConverter}, ConverterParameter='Negative'}" Value="True">
                                                    <Setter Property="Foreground" Value="#10B981" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ClosingDebt, StringFormat='{}{0:N0} đ'}"
                        ElementStyle="{StaticResource DataGridCurrencyStyle}"
                        Header="Closing Debt"
                        HeaderStyle="{StaticResource RightDataGridHeaderStyle}" />
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Border>
    </Grid>
</UserControl>