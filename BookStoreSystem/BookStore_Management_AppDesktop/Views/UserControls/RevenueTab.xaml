<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.RevenueTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <!--  Style cho 4 thẻ thống kê ở trên  -->
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,15,0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.03"
                        ShadowDepth="2"
                        Color="#000000" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect
                                BlurRadius="15"
                                Opacity="0.08"
                                ShadowDepth="6"
                                Color="#000000" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                To="-5"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                To="0"
                                Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SummaryValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SummaryLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid
            Grid.Row="0"
            Margin="0,0,-15,20"
            Columns="4">
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryValueTextStyle}" Text="{Binding TotalRevenue, StringFormat='{}{0:N0}'}" />
                        <TextBlock Style="{StaticResource SummaryLabelTextStyle}" Text="Total Revenue" />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        Width="48"
                        Height="48"
                        Background="#E0F2FE"
                        CornerRadius="8">
                        <ui:SymbolIcon
                            FontSize="24"
                            Foreground="#0284C7"
                            Symbol="Money24" />
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryValueTextStyle}" Text="{Binding TotalImportCost, StringFormat='{}{0:N0}'}" />
                        <TextBlock Style="{StaticResource SummaryLabelTextStyle}" Text="Import Cost" />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        Width="48"
                        Height="48"
                        Background="#FEF3C7"
                        CornerRadius="8">
                        <ui:SymbolIcon
                            FontSize="24"
                            Foreground="#D97706"
                            Symbol="Cart24" />
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryValueTextStyle}" Text="{Binding Profit, StringFormat='{}{0:N0}'}" />
                        <TextBlock Style="{StaticResource SummaryLabelTextStyle}" Text="Net Profit" />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        Width="48"
                        Height="48"
                        Background="#DCFCE7"
                        CornerRadius="8">
                        <ui:SymbolIcon
                            FontSize="24"
                            Foreground="#16A34A"
                            Symbol="ArrowUp24" />
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryValueTextStyle}" Text="{Binding TotalBooksSold}" />
                        <TextBlock Style="{StaticResource SummaryLabelTextStyle}" Text="Books Sold" />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        Width="48"
                        Height="48"
                        Background="#F3E8FF"
                        CornerRadius="8">
                        <ui:SymbolIcon
                            FontSize="24"
                            Foreground="#9333EA"
                            Symbol="Library24" />
                    </Border>
                </Grid>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <!--  Biểu đồ  -->
            <Border
                Grid.Column="0"
                Margin="0,0,15,0"
                Padding="20"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.03"
                        ShadowDepth="2"
                        Color="#000000" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#0F172A"
                        Text="Revenue Trend" />
                    <lvc:CartesianChart
                        Grid.Row="1"
                        Series="{Binding RevenueSeries}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}" />
                </Grid>
            </Border>

            <!--  Danh sách Top Selling Books phong cách MỚI  -->
            <Border
                Grid.Column="1"
                Padding="20"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.03"
                        ShadowDepth="2"
                        Color="#000000" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#0F172A"
                        Text="Top Selling Books" />

                    <ListView
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding TopBooks}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <!--  Khung Card từng cuốn sách  -->
                                <Border
                                    x:Name="ItemBorder"
                                    Margin="0,0,0,12"
                                    Padding="15"
                                    Background="#FFFFFF"
                                    BorderBrush="#F1F5F9"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Avatar tròn icon sách  -->
                                        <Border
                                            Grid.Column="0"
                                            Width="48"
                                            Height="48"
                                            Margin="0,0,15,0"
                                            Background="#F0F9FF"
                                            CornerRadius="24">
                                            <ui:SymbolIcon
                                                FontSize="22"
                                                Foreground="#0EA5E9"
                                                Symbol="BookStar24" />
                                        </Border>

                                        <!--  Thông tin sách & Pill số lượng  -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="15"
                                                FontWeight="Bold"
                                                Foreground="#0F172A"
                                                Text="{Binding Title}"
                                                TextTrimming="CharacterEllipsis" />

                                            <!--  Pill Badge số lượng bán  -->
                                            <Border
                                                Margin="0,6,0,0"
                                                Padding="8,3"
                                                HorizontalAlignment="Left"
                                                Background="#F1F5F9"
                                                CornerRadius="6">
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="#475569"
                                                    Text="{Binding TotalSold, StringFormat='{}🛒 {0} units'}" />
                                            </Border>
                                        </StackPanel>

                                        <!--  Pill Badge Doanh thu nổi bật  -->
                                        <Border
                                            Grid.Column="2"
                                            Margin="10,0,0,0"
                                            Padding="12,8"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Background="#DCFCE7"
                                            CornerRadius="8">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="Black"
                                                Foreground="#15803D"
                                                Text="{Binding RevenueGenerated, StringFormat='{}{0:N0} đ'}" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <!--  Hiệu ứng khi rê chuột vào Card sách  -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#F8FAFC" />
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#E2E8F0" />
                                        <Setter TargetName="ItemBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect
                                                    BlurRadius="12"
                                                    Opacity="0.04"
                                                    ShadowDepth="3"
                                                    Color="#000000" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>