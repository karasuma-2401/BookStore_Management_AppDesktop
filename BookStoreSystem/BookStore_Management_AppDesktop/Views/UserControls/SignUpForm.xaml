<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.SignUpForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BookStore_Management_AppDesktop.Views.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock
            Margin="0,0,0,10"
            HorizontalAlignment="Center"
            FontSize="32"
            FontWeight="ExtraBold"
            Foreground="{DynamicResource TextPrimaryBrush}"
            Text="SIGN UP" />
        <TextBlock
            Margin="0,0,0,30"
            HorizontalAlignment="Center"
            FontSize="14"
            Foreground="{DynamicResource TextSecondBrush}"
            Text="CREATE A NEW ACCOUNT" />

        <ui:TextBox
            Margin="0,0,0,15"
            Padding="12"
            FontSize="15"
            Icon="ContactCard24"
            PlaceholderText="Fullname"
            PreviewKeyDown="MoveFocusOnEnter_PreviewKeyDown"
            Text="{Binding SignUpFullName, UpdateSourceTrigger=PropertyChanged}" />
        <ui:TextBox
            Margin="0,0,0,15"
            Padding="12"
            FontSize="15"
            Icon="Person24"
            PlaceholderText="Username"
            PreviewKeyDown="MoveFocusOnEnter_PreviewKeyDown"
            Text="{Binding SignUpUsername, UpdateSourceTrigger=PropertyChanged}" />
        <ui:PasswordBox
            Margin="0,0,0,15"
            Padding="12"
            FontSize="15"
            Icon="Key24"
            Password="{Binding SignUpPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            PasswordChar="●"
            PlaceholderText="Password"
            PreviewKeyDown="MoveFocusOnEnter_PreviewKeyDown" />
        <ui:PasswordBox
            Margin="0,0,0,25"
            Padding="12"
            FontSize="15"
            Icon="CheckmarkLock24"
            Password="{Binding SignUpConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            PasswordChar="●"
            PlaceholderText="Confirm Password"
            PreviewKeyDown="MoveFocusOnEnter_PreviewKeyDown" />
        <TextBlock
            Margin="0,0,0,15"
            HorizontalAlignment="Center"
            FontWeight="SemiBold"
            Text="{Binding ErrorMessage}"
            TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccessMessage}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource SuccessPrimaryBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <ui:ProgressRing
            Margin="0,0,0,15"
            IsIndeterminate="True"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
        <ui:Button
            Padding="0,14"
            HorizontalAlignment="Stretch"
            Appearance="Primary"
            Background="{DynamicResource NavyAccentBrush}"
            Command="{Binding SignUpCommand}"
            Content="Complete Registration"
            CornerRadius="8"
            FontSize="16"
            FontWeight="Bold"
            Foreground="{DynamicResource NavyPrimaryBrush}" />

        <StackPanel
            Margin="0,25,0,0"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="14"
                Foreground="{DynamicResource TextSecondBrush}"
                Text="Already have an account? " />
            <ui:Button
                Padding="5,0"
                Appearance="Transparent"
                Command="{Binding SwitchToLoginCommand}"
                Content="Back to Login "
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{DynamicResource NavyAccentBrush}" />
        </StackPanel>
    </StackPanel>
</UserControl>
