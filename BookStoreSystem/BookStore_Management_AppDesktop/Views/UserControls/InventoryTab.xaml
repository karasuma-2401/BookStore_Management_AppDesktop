<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.InventoryTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <Style x:Key="CustomDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Padding" Value="15,0,10,0" />
            <Setter Property="Height" Value="45" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="CustomDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border
                            Padding="15,0,10,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F4F7F9" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0F2FE" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0F2FE" />
                    <Setter Property="BorderBrush" Value="#0078D4" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="350" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Border
                    Width="40"
                    Height="40"
                    Margin="0,0,12,0"
                    Background="#E0F2FE"
                    CornerRadius="8">
                    <ui:SymbolIcon
                        FontSize="20"
                        Foreground="#0078D4"
                        Symbol="DataHistogram24" />
                </Border>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#0F172A">
                    <Run Text="Inventory Overview (" />
                    <Run Text="{Binding SelectedMonth}" />
                    <Run Text="/" />
                    <Run Text="{Binding SelectedYear}" />
                    <Run Text=")" />
                </TextBlock>
            </StackPanel>

            <Border
                Grid.Column="1"
                Padding="6"
                Background="#FFFFFF"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <ui:SymbolIcon
                        Margin="10,0,8,0"
                        FontSize="18"
                        Foreground="#64748B"
                        Symbol="CalendarLtr24" />

                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Foreground="#64748B"
                        Text="Month" />
                    <ComboBox
                        Width="70"
                        Height="32"
                        Margin="0,0,15,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1.5"
                        Foreground="#0F172A"
                        ItemsSource="{Binding Months}"
                        SelectedItem="{Binding SelectedMonth}" />

                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontWeight="Medium"
                        Foreground="#64748B"
                        Text="Year" />
                    <ComboBox
                        Width="80"
                        Height="32"
                        Margin="0,0,15,0"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1.5"
                        Foreground="#0F172A"
                        ItemsSource="{Binding Years}"
                        SelectedItem="{Binding SelectedYear}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0,0,0,20"
            Padding="15"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.03"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>
            <lvc:CartesianChart
                x:Name="InventoryChart"
                Series="{Binding InventorySeries}"
                TooltipPosition="Top"
                XAxes="{Binding InventoryXAxes}"
                YAxes="{Binding InventoryYAxes}" />
        </Border>

        <Border
            Grid.Row="2"
            Padding="15"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.03"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>
            <ui:DataGrid
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserReorderColumns="False"
                CellStyle="{StaticResource CustomDataGridCellStyle}"
                ColumnHeaderStyle="{StaticResource CustomDataGridHeaderStyle}"
                Foreground="#1E293B"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#E2E8F0"
                IsReadOnly="True"
                ItemsSource="{Binding InventoryReports}"
                LoadingRow="DataGrid_LoadingRow"
                RowHeight="50"
                RowStyle="{StaticResource CustomDataGridRowStyle}">
                <ui:DataGrid.Columns>
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="No." />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding BookId}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Book Id" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding OpeningStock}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Opening Stock" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ChangeAmount}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Change Amount" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding ClosingStock}"
                        ElementStyle="{StaticResource DataGridTextStyle}"
                        Header="Closing Stock" />
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Border>
    </Grid>
</UserControl>