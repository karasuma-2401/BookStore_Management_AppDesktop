<UserControl
    x:Class="BookStore_Management_AppDesktop.Views.UserControls.ForgotPasswordForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BookStore_Management_AppDesktop.Views.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock
            Margin="0,0,0,10"
            HorizontalAlignment="Center"
            FontSize="32"
            FontWeight="ExtraBold"
            Foreground="{DynamicResource TextPrimaryBrush}"
            Text="RESET PASSWORD" />
        <TextBlock
            Margin="0,0,0,30"
            HorizontalAlignment="Center"
            FontSize="14"
            Foreground="{DynamicResource TextSecondBrush}"
            Text="Enter your email to receive a OTP code" />

        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ForgotPasswordStep}" Value="1">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <ui:TextBox
                Margin="0,0,0,25"
                Padding="12"
                FontSize="15"
                Icon="Mail24"
                PlaceholderText="Email address"
                Text="{Binding ResetEmail, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,15"
                HorizontalAlignment="Center"
                FontWeight="SemiBold"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccessMessage}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SuccessPrimaryBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <ui:Button
                Padding="0,14"
                HorizontalAlignment="Stretch"
                Appearance="Primary"
                Background="{DynamicResource NavyAccentBrush}"
                Command="{Binding VerifyEmailCommand}"
                Content="Continue"
                CornerRadius="8"
                FontSize="16"
                FontWeight="Bold"
                Foreground="{DynamicResource NavyPrimaryBrush}" />
        </StackPanel>

        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ForgotPasswordStep}" Value="2">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <ui:TextBox
                Margin="0,0,0,25"
                Padding="12"
                HorizontalContentAlignment="Center"
                FontSize="15"
                Icon="Password24"
                MaxLength="6"
                PlaceholderText="Enter 6 digit"
                Text="{Binding OtpCode, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,15"
                HorizontalAlignment="Center"
                FontWeight="SemiBold"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccessMessage}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SuccessPrimaryBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <ui:Button
                Padding="0,14"
                HorizontalAlignment="Stretch"
                Appearance="Primary"
                Background="{DynamicResource NavyAccentBrush}"
                Command="{Binding VerifyOtpCommand}"
                Content="Verify OTP"
                CornerRadius="8"
                FontSize="16"
                FontWeight="Bold"
                Foreground="{DynamicResource NavyPrimaryBrush}" />
        </StackPanel>

        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ForgotPasswordStep}" Value="3">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <ui:PasswordBox
                Margin="0,0,0,15"
                Padding="12"
                FontSize="15"
                Icon="Key24"
                Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PasswordChar="●"
                PlaceholderText="New Password" />
            <ui:PasswordBox
                Margin="0,0,0,25"
                Padding="12"
                FontSize="15"
                Icon="CheckmarkLock24"
                Password="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PasswordChar="●"
                PlaceholderText="Confirm New Password" />
            <TextBlock
                Margin="0,0,0,15"
                HorizontalAlignment="Center"
                FontWeight="SemiBold"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource ErrorPrimaryBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccessMessage}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource SuccessPrimaryBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <ui:Button
                Padding="0,14"
                HorizontalAlignment="Stretch"
                Appearance="Primary"
                Background="{DynamicResource NavyAccentBrush}"
                Command="{Binding ChangeToNewPasswordCommand}"
                Content="Update Password"
                CornerRadius="8"
                FontSize="16"
                FontWeight="Bold"
                Foreground="{DynamicResource NavyPrimaryBrush}" />
        </StackPanel>
        <StackPanel
            Margin="0,25,0,0"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <ui:Button
                Padding="5,0"
                Appearance="Transparent"
                Command="{Binding SwitchToLoginCommand}"
                Content="Back to Login"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{DynamicResource NavyAccentBrush}" />
        </StackPanel>
    </StackPanel>
</UserControl>
