<Window x:Class="BookStore_Management_AppDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="BookStore Management" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource NavyPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--#region SIDEBAR  -->
        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Column="0"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           OpenPaneLength="250"
                           Background="{StaticResource SidebarBackgroundBrush}">

            <ui:NavigationView.PaneHeader>
                <Grid Margin="15,20,0,20">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Library24" FontSize="28" Foreground="{StaticResource NavyAccentBrush}"/>
                        <TextBlock Text="BOOKSTORE" VerticalAlignment="Center" Margin="10,0,0,0"
                                   FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </ui:NavigationView.PaneHeader>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Quản Lý Sách" Tag="Books" Icon="{ui:SymbolIcon Book24}" />
                <ui:NavigationViewItem Content="Nhân Viên" Tag="Employees" Icon="{ui:SymbolIcon People24}" />
                <ui:NavigationViewItem Content="Khách Hàng" Tag="Customers" Icon="{ui:SymbolIcon Person24}" />
                <ui:NavigationViewItem Content="Hóa Đơn" Tag="Invoices" Icon="{ui:SymbolIcon Document24}" />
                <ui:NavigationViewItem Content="Kho Sách" Tag="Inventory" Icon="{ui:SymbolIcon Box24}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Cài Đặt" Tag="Settings" Icon="{ui:SymbolIcon Settings24}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
        <!--#endregion-->

        <!--#region CONTENT-->
        <Border Grid.Column="1" 
                Margin="10" 
                CornerRadius="8" 
                Background="{StaticResource ContentBackgroundBrush}">

            <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden"/>

        </Border>
        <!--#endregion-->
        
    </Grid>
</Window>