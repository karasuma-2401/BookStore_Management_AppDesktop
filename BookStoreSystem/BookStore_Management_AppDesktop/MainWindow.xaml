<Window x:Class="BookStore_Management_AppDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookStore_Management_AppDesktop"
        mc:Ignorable="d"
        Title="BookStore Management"
        Height="600" Width="1000">

    <!-- Grid chia giao diện thành 2 phần -->
    <Grid>

        <!-- Định nghĩa 2 cột -->
        <Grid.ColumnDefinitions>

            <!-- Sidebar menu -->
            <ColumnDefinition Width="220"/>

            <!-- Nội dung chính -->
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <StackPanel Grid.Column="0" Background="#2C3E50">

            <TextBlock Text="BookStore"
                       FontSize="22"
                       Foreground="White"
                       Margin="20"/>

            <Button Content="Dashboard" Margin="10"/>
            <Button Content="Books" Margin="10"/>
            <Button Content="Employees" Margin="10"/>
            <Button Content="Reports" Margin="10"/>

        </StackPanel>

        <!-- CONTENT AREA -->
        <Grid Grid.Column="1" Background="#ECF0F1">

            <TextBlock Text="Main Content Area"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"/>

        </Grid>

    </Grid>
</Window>
