{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "<ENTER_CONNECTION_STRING_INTO_USER_SECRETS>"
  },
  "JwtConfig": {
    "Issuer": "http://localhost:5099/",
    "Audience": "http://localhost:5099/",
    "Key": "<ENTER_SECRET_KEY_INTO_USER_SECRETS>",
    "TokenvalidityMins": 30
  },
  "EmailSettings": {
    "Email": "<ENTER_EMAIL_INTO_USER_SECRETS>",
    "Password": "<ENTER_APP_PASSWORD_INTO_USER_SECRETS>",
    "Host": "smtp.gmail.com",
    "Port": 587
  }
}